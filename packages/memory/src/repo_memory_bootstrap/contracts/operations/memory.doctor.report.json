{
  "schema_version": "agentic-workspace/operation/v1",
  "id": "memory.doctor.report",
  "command_surface": {
    "program": "agentic-memory",
    "command": "doctor",
    "format_option": "format"
  },
  "summary": "Read-only agentic-memory doctor report.",
  "classification": "read-only-report",
  "inputs": [
    {
      "name": "target",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "strict_doc_ownership",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "verbose",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "format",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "project_name",
      "source": "cli-option",
      "command_visibility": "runtime-only",
      "required": false,
      "description": "Runtime adapter compatibility value shared with lifecycle prompt/template operations; not exposed by doctor."
    },
    {
      "name": "project_purpose",
      "source": "cli-option",
      "command_visibility": "runtime-only",
      "required": false,
      "description": "Runtime adapter compatibility value shared with lifecycle prompt/template operations; not exposed by doctor."
    },
    {
      "name": "key_repo_docs",
      "source": "cli-option",
      "command_visibility": "runtime-only",
      "required": false,
      "description": "Runtime adapter compatibility value shared with lifecycle prompt/template operations; not exposed by doctor."
    },
    {
      "name": "key_subsystems",
      "source": "cli-option",
      "command_visibility": "runtime-only",
      "required": false,
      "description": "Runtime adapter compatibility value shared with lifecycle prompt/template operations; not exposed by doctor."
    },
    {
      "name": "primary_build_command",
      "source": "cli-option",
      "command_visibility": "runtime-only",
      "required": false,
      "description": "Runtime adapter compatibility value shared with lifecycle prompt/template operations; not exposed by doctor."
    },
    {
      "name": "primary_test_command",
      "source": "cli-option",
      "command_visibility": "runtime-only",
      "required": false,
      "description": "Runtime adapter compatibility value shared with lifecycle prompt/template operations; not exposed by doctor."
    },
    {
      "name": "other_key_commands",
      "source": "cli-option",
      "command_visibility": "runtime-only",
      "required": false,
      "description": "Runtime adapter compatibility value shared with lifecycle prompt/template operations; not exposed by doctor."
    },
    {
      "name": "policy_profile",
      "source": "cli-option",
      "command_visibility": "runtime-only",
      "required": false,
      "description": "Runtime adapter compatibility value shared with lifecycle prompt/template operations; not exposed by doctor."
    }
  ],
  "output": {
    "kind": "text-or-json"
  },
  "effects": {
    "read_only": true,
    "destructive": false,
    "idempotent": true,
    "writes_repo_state": false,
    "requires_preflight_gate": false
  },
  "locality": {
    "requires_repo": false,
    "network": "forbidden",
    "outside_repo_writes": "forbidden"
  },
  "reads": [
    {
      "surface": "package-local runtime state",
      "required": false
    },
    {
      "surface": "verbose flag for broad diagnostic output",
      "required": false
    }
  ],
  "writes": [],
  "steps": [
    {
      "id": "resolve_target_root",
      "uses": "path.target_root.resolve",
      "description": "Resolve the target root for target-local memory doctor checks."
    },
    {
      "id": "count_manifest_notes",
      "uses": "toml.table.counts",
      "description": "Count note records and relevance categories in the target memory manifest."
    },
    {
      "id": "assemble_doctor",
      "uses": "payload.assemble",
      "description": "Assemble the compact doctor payload from primitive outputs."
    },
    {
      "id": "load_verbose_or_text_doctor",
      "uses": "memory.bootstrap.doctor.load",
      "description": "Load the package-domain doctor report when verbose or text output is requested."
    },
    {
      "id": "emit_output",
      "uses": "output.emit",
      "description": "Emit report in the requested format."
    }
  ],
  "guards": [
    "doctor must remain read-only."
  ],
  "proof": [
    "operation contract validates against operation.schema.json",
    "process conformance remains compatible"
  ],
  "migration_status": "runtime-consumed",
  "ir_plan": {
    "status": "representative",
    "summary": "Memory doctor non-verbose JSON executes generated operation IR through codegen-owned portable primitives. Verbose/text doctor behavior remains package-domain source runtime.",
    "steps": [
      {
        "id": "resolve_target_root",
        "uses": "path.target_root.resolve",
        "description": "Resolve the target root for target-local memory doctor checks.",
        "when": {
          "all": [
            {
              "value": "format",
              "equals": "json"
            },
            {
              "value": "verbose",
              "equals": false
            }
          ]
        },
        "arguments": {
          "must_exist": true,
          "must_be_dir": true
        },
        "outputs": [
          "target_root"
        ],
        "on_error": "fail"
      },
      {
        "id": "count_manifest_notes",
        "uses": "toml.table.counts",
        "description": "Count note records and relevance categories in the target memory manifest.",
        "when": {
          "all": [
            {
              "value": "format",
              "equals": "json"
            },
            {
              "value": "verbose",
              "equals": false
            }
          ]
        },
        "arguments": {
          "base_value": "target_root",
          "path": ".agentic-workspace/memory/repo/manifest.toml",
          "table": "notes",
          "relevance_field": "task_relevance",
          "required_value": "required",
          "optional_value": "optional",
          "routing_only_field": "routing_only"
        },
        "outputs": [
          "table_counts",
          "table_present",
          "table_status"
        ],
        "on_error": "fail"
      },
      {
        "id": "assemble_doctor",
        "uses": "payload.assemble",
        "description": "Assemble the compact doctor payload from primitive outputs.",
        "when": {
          "all": [
            {
              "value": "format",
              "equals": "json"
            },
            {
              "value": "verbose",
              "equals": false
            }
          ]
        },
        "arguments": {
          "fields": {
            "template": {
              "target_root": {
                "$value": "target_root"
              },
              "dry_run": true,
              "mode": "",
              "message": "Doctor report",
              "health": {
                "$exists_status": {
                  "value": "table_present",
                  "present": "healthy",
                  "missing": "attention-needed"
                }
              },
              "detected_version": null,
              "bootstrap_version": null,
              "action_count": {
                "$exists_status": {
                  "value": "table_present",
                  "present": 0,
                  "missing": 1
                }
              },
              "actions": {
                "$exists_status": {
                  "value": "table_present",
                  "present": [],
                  "missing": [
                    {
                      "kind": {
                        "$value": "table_status"
                      },
                      "path": ".agentic-workspace/memory/repo/manifest.toml",
                      "detail": "memory manifest is not readable; run full doctor for remediation detail"
                    }
                  ]
                }
              },
              "active": {
                "$value": "table_counts"
              },
              "detail_command": "agentic-memory doctor --target . --verbose --format json"
            }
          }
        },
        "outputs": [
          "result"
        ],
        "on_error": "fail"
      },
      {
        "id": "load_verbose_or_text_doctor",
        "uses": "memory.bootstrap.doctor.load",
        "description": "Load the package-domain doctor report when verbose or text output is requested.",
        "when": {
          "not": {
            "all": [
              {
                "value": "format",
                "equals": "json"
              },
              {
                "value": "verbose",
                "equals": false
              }
            ]
          }
        },
        "arguments": {},
        "outputs": [
          "result"
        ],
        "on_error": "fail"
      },
      {
        "id": "emit_output",
        "uses": "output.emit",
        "description": "Emit the memory report payload in the requested format.",
        "arguments": {},
        "outputs": [
          "emitted"
        ],
        "on_error": "emit_usage_error"
      }
    ]
  }
}
