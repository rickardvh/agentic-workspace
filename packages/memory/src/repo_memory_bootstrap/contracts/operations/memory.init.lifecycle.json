{
  "schema_version": "agentic-workspace/operation/v1",
  "id": "memory.init.lifecycle",
  "command_surface": {
    "program": "agentic-memory",
    "command": "init",
    "format_option": "format"
  },
  "summary": "Initialize Memory bootstrap files in a repository.",
  "classification": "lifecycle-mutation",
  "inputs": [
    {
      "name": "target",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "dry_run",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "force",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "project_name",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "project_purpose",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "key_repo_docs",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "key_subsystems",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "primary_build_command",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "primary_test_command",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "other_key_commands",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "policy_profile",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "format",
      "source": "cli-option",
      "required": false
    }
  ],
  "output": {
    "kind": "text-or-json"
  },
  "effects": {
    "read_only": false,
    "destructive": false,
    "idempotent": true,
    "writes_repo_state": true,
    "requires_preflight_gate": false
  },
  "locality": {
    "requires_repo": true,
    "network": "forbidden",
    "outside_repo_writes": "forbidden"
  },
  "reads": [
    {
      "surface": "target repository Memory install state",
      "required": false
    }
  ],
  "writes": [
    {
      "surface": "target repository Memory managed surfaces",
      "required": false,
      "when": "not a dry run"
    }
  ],
  "steps": [
    {
      "id": "resolve_target_root",
      "uses": "path.target_root.resolve",
      "description": "Resolve the target root for declarative dry-run planning."
    },
    {
      "id": "plan_default_dry_run",
      "uses": "memory.payload.lifecycle-plan",
      "description": "Plan default dry-run init actions from declarative payload policy."
    },
    {
      "id": "apply_memory_lifecycle",
      "uses": "memory.init.apply",
      "description": "Apply or plan Memory bootstrap init through package runtime when mutation or customized install policy is required."
    },
    {
      "id": "emit_output",
      "uses": "memory.output.emit.install-result",
      "description": "Emit the init result in the requested format."
    }
  ],
  "guards": [
    "Generated code owns parser/help/dispatch shape; memory-owned lifecycle policy remains behind the declared primitive.",
    "Dry-run conformance must prove generated lifecycle adapters can execute without repository writes."
  ],
  "proof": [
    "operation contract validates against operation.schema.json",
    "generated memory init dry-run process conformance passes"
  ],
  "migration_status": "runtime-consumed",
  "ir_plan": {
    "status": "representative",
    "summary": "Default dry-run Memory init executes generated operation IR through AW/Memory-owned memory.payload.lifecycle-plan. Mutating and customized init policy paths remain package-domain runtime.",
    "steps": [
      {
        "id": "resolve_target_root",
        "uses": "path.target_root.resolve",
        "description": "Resolve the target root for declarative dry-run planning.",
        "when": {
          "all": [
            {
              "value": "dry_run",
              "equals": true
            },
            {
              "value": "force",
              "equals": false
            },
            {
              "value": "project_name",
              "equals": null
            },
            {
              "value": "project_purpose",
              "equals": null
            },
            {
              "value": "key_repo_docs",
              "equals": null
            },
            {
              "value": "key_subsystems",
              "equals": null
            },
            {
              "value": "primary_build_command",
              "equals": null
            },
            {
              "value": "primary_test_command",
              "equals": null
            },
            {
              "value": "other_key_commands",
              "equals": null
            },
            {
              "value": "policy_profile",
              "equals": "default"
            }
          ]
        },
        "arguments": {
          "must_exist": true,
          "must_be_dir": true
        },
        "outputs": [
          "target_root"
        ],
        "on_error": "fail"
      },
      {
        "id": "plan_default_dry_run",
        "uses": "memory.payload.lifecycle-plan",
        "description": "Plan default dry-run init actions from declarative payload policy.",
        "when": {
          "all": [
            {
              "value": "dry_run",
              "equals": true
            },
            {
              "value": "force",
              "equals": false
            },
            {
              "value": "project_name",
              "equals": null
            },
            {
              "value": "project_purpose",
              "equals": null
            },
            {
              "value": "key_repo_docs",
              "equals": null
            },
            {
              "value": "key_subsystems",
              "equals": null
            },
            {
              "value": "primary_build_command",
              "equals": null
            },
            {
              "value": "primary_test_command",
              "equals": null
            },
            {
              "value": "other_key_commands",
              "equals": null
            },
            {
              "value": "policy_profile",
              "equals": "default"
            }
          ]
        },
        "arguments": {
          "policy_root": "memory.contracts",
          "policy_path": "payload_verification.memory.json",
          "target_root_value": "target_root",
          "dry_run": true,
          "mode": "bootstrap",
          "message": "Install plan"
        },
        "outputs": [
          "result"
        ],
        "on_error": "fail"
      },
      {
        "id": "apply_memory_lifecycle",
        "uses": "memory.init.apply",
        "description": "Apply or plan Memory bootstrap init through package runtime when mutation or customized install policy is required.",
        "when": {
          "not": {
            "all": [
              {
                "value": "dry_run",
                "equals": true
              },
              {
                "value": "force",
                "equals": false
              },
              {
                "value": "project_name",
                "equals": null
              },
              {
                "value": "project_purpose",
                "equals": null
              },
              {
                "value": "key_repo_docs",
                "equals": null
              },
              {
                "value": "key_subsystems",
                "equals": null
              },
              {
                "value": "primary_build_command",
                "equals": null
              },
              {
                "value": "primary_test_command",
                "equals": null
              },
              {
                "value": "other_key_commands",
                "equals": null
              },
              {
                "value": "policy_profile",
                "equals": "default"
              }
            ]
          }
        },
        "arguments": {
          "target": {
            "value": "target"
          },
          "dry_run": {
            "value": "dry_run"
          },
          "force": {
            "value": "force"
          },
          "project_name": {
            "value": "project_name"
          },
          "project_purpose": {
            "value": "project_purpose"
          },
          "key_repo_docs": {
            "value": "key_repo_docs"
          },
          "key_subsystems": {
            "value": "key_subsystems"
          },
          "primary_build_command": {
            "value": "primary_build_command"
          },
          "primary_test_command": {
            "value": "primary_test_command"
          },
          "other_key_commands": {
            "value": "other_key_commands"
          },
          "policy_profile": {
            "value": "policy_profile"
          }
        },
        "outputs": [
          "result"
        ],
        "on_error": "fail"
      },
      {
        "id": "emit_output",
        "uses": "memory.output.emit.install-result",
        "description": "Emit the init result in the requested format.",
        "arguments": {},
        "outputs": [
          "emitted"
        ],
        "on_error": "emit_usage_error"
      }
    ]
  }
}
