{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/command-package-ir.schema.json",
  "title": "Agentic Workspace Command Package IR",
  "description": "Intermediate representation for generating command package metadata and language/runtime adapters.",
  "type": "object",
  "required": [
    "schema_version",
    "summary",
    "schema",
    "source_contracts",
    "generation_policy",
    "packages"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/command-package-ir/v1",
      "description": "Command package IR contract version."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Short summary of the generated command package boundary."
    },
    "schema": {
      "const": "schemas/command_package_ir.schema.json",
      "description": "Schema reference carried by the IR document."
    },
    "source_contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "One entry in the source contracts list."
      },
      "description": "Contract files that feed or constrain command package generation."
    },
    "generation_policy": {
      "type": "object",
      "required": [
        "authority_rule",
        "runtime_boundary",
        "ordinary_development_environment",
        "test_environment",
        "custom_codegen_boundary",
        "shell_adapter_policy",
        "direct_cli_edit_policy",
        "extraction_readiness",
        "generated_package_maturity",
        "python_cli_completion",
        "non_python_runtime_binding"
      ],
      "properties": {
        "authority_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Authority rule text value used by this contract."
        },
        "runtime_boundary": {
          "type": "string",
          "minLength": 1,
          "description": "Runtime boundary text value used by this contract."
        },
        "ordinary_development_environment": {
          "type": "string",
          "minLength": 1,
          "description": "Ordinary development environment text value used by this contract."
        },
        "test_environment": {
          "type": "string",
          "minLength": 1,
          "description": "Test environment text value used by this contract."
        },
        "custom_codegen_boundary": {
          "type": "string",
          "minLength": 1,
          "description": "Custom codegen boundary text value used by this contract."
        },
        "shell_adapter_policy": {
          "type": "string",
          "minLength": 1,
          "description": "Shell adapter policy text value used by this contract."
        },
        "direct_cli_edit_policy": {
          "type": "string",
          "minLength": 1,
          "description": "Direct cli edit policy text value used by this contract."
        },
        "extraction_readiness": {
          "type": "object",
          "required": [
            "status",
            "owner",
            "rule",
            "accepted_couplings"
          ],
          "properties": {
            "status": {
              "enum": [
                "ready",
                "ready-with-inventoried-product-coupling",
                "blocked"
              ],
              "description": "Extraction readiness status for reusable command-generation code."
            },
            "owner": {
              "type": "string",
              "minLength": 1,
              "description": "Issue, lane, or owner responsible for this extraction boundary."
            },
            "rule": {
              "type": "string",
              "minLength": 1,
              "description": "Mechanical rule the extraction-readiness audit enforces."
            },
            "accepted_couplings": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "kind",
                  "paths",
                  "owner",
                  "reason",
                  "migration_path"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z0-9][a-z0-9-]*$",
                    "description": "Stable accepted coupling id."
                  },
                  "kind": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Coupling class."
                  },
                  "paths": {
                    "$ref": "#/$defs/non_empty_strings",
                    "description": "Repo-relative source paths where the coupling is allowed."
                  },
                  "owner": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Issue, lane, or module that owns retiring or preserving this coupling."
                  },
                  "reason": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Why this coupling is currently accepted."
                  },
                  "migration_path": {
                    "type": "string",
                    "minLength": 1,
                    "description": "How this coupling should move if it stops being accepted."
                  }
                },
                "additionalProperties": false,
                "description": "One explicitly accepted command-generation extraction coupling."
              },
              "description": "Explicit inventory of remaining product coupling in reusable command-generation code."
            }
          },
          "additionalProperties": false,
          "description": "Mechanical extraction-readiness boundary for the command-generation package."
        },
        "generated_package_maturity": {
          "type": "object",
          "required": [
            "routing_rule",
            "levels"
          ],
          "properties": {
            "routing_rule": {
              "type": "string",
              "minLength": 1,
              "description": "Routing rule text value used by this contract."
            },
            "levels": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/maturity_level",
                "description": "One entry in the levels list."
              },
              "description": "Ordered levels entries used by this contract."
            }
          },
          "additionalProperties": false,
          "description": "Generated package maturity details used by this contract."
        },
        "python_cli_completion": {
          "type": "object",
          "required": [
            "finish_line",
            "current_state",
            "allowed_hand_owned_cli_responsibilities",
            "must_move_behind_contracts_or_generation",
            "proof_requirements",
            "completion_gate"
          ],
          "properties": {
            "finish_line": {
              "type": "string",
              "minLength": 1,
              "description": "Finish line text value used by this contract."
            },
            "current_state": {
              "type": "string",
              "minLength": 1,
              "description": "Current state text value used by this contract."
            },
            "allowed_hand_owned_cli_responsibilities": {
              "$ref": "#/$defs/non_empty_strings",
              "description": "Python CLI responsibilities that may stay hand-owned."
            },
            "must_move_behind_contracts_or_generation": {
              "$ref": "#/$defs/non_empty_strings",
              "description": "Python CLI responsibilities that cannot be treated as complete while hand-owned."
            },
            "proof_requirements": {
              "$ref": "#/$defs/non_empty_strings",
              "description": "Proof requirements before Python generated CLI completion can be claimed."
            },
            "completion_gate": {
              "type": "object",
              "required": [
                "state",
                "scope",
                "satisfied_by"
              ],
              "properties": {
                "state": {
                  "enum": [
                    "pending",
                    "satisfied"
                  ],
                  "description": "Whether Python generated CLI completion prerequisites are satisfied."
                },
                "scope": {
                  "const": "python-only",
                  "description": "Completion scope; this gate must not claim TypeScript, Bash, PowerShell, or full codegen epic completion."
                },
                "satisfied_by": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "evidence",
                      "proof"
                    ],
                    "properties": {
                      "id": {
                        "type": "string",
                        "pattern": "^[a-z0-9][a-z0-9-]*$",
                        "description": "Stable completion prerequisite id."
                      },
                      "evidence": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Evidence showing the prerequisite is satisfied."
                      },
                      "proof": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Command, checker, or test surface that proves this prerequisite."
                      }
                    },
                    "additionalProperties": false,
                    "description": "One satisfied Python completion prerequisite."
                  },
                  "description": "Evidence items required before full Python generated CLI completion can be claimed."
                }
              },
              "additionalProperties": false,
              "description": "Schema-backed gate that separates full Python generated CLI completion from generated adapter maturity."
            }
          },
          "additionalProperties": false,
          "description": "Python generated CLI completion criteria distinct from adapter maturity."
        },
        "non_python_runtime_binding": {
          "type": "object",
          "required": [
            "selected_model",
            "default_runtime_command",
            "scope",
            "universal_contract_owns",
            "target_projection_owns",
            "runtime_owns",
            "error_mapping"
          ],
          "properties": {
            "selected_model": {
              "type": "string",
              "minLength": 1,
              "description": "Selected model text value used by this contract."
            },
            "default_runtime_command": {
              "type": "string",
              "minLength": 1,
              "description": "Default runtime command text value used by this contract."
            },
            "scope": {
              "type": "string",
              "minLength": 1,
              "description": "Scope text value used by this contract."
            },
            "universal_contract_owns": {
              "$ref": "#/$defs/non_empty_strings",
              "description": "Universal contract owns referenced contract shape used by this contract."
            },
            "target_projection_owns": {
              "$ref": "#/$defs/non_empty_strings",
              "description": "Target projection owns referenced contract shape used by this contract."
            },
            "runtime_owns": {
              "$ref": "#/$defs/non_empty_strings",
              "description": "Runtime owns referenced contract shape used by this contract."
            },
            "error_mapping": {
              "$ref": "#/$defs/non_empty_strings",
              "description": "Error mapping referenced contract shape used by this contract."
            }
          },
          "additionalProperties": false,
          "description": "Non python runtime binding details used by this contract."
        }
      },
      "additionalProperties": false,
      "description": "Policy for what generation owns, what runtime code owns, and how adapters stay safe."
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/package",
        "description": "One entry in the packages list."
      },
      "description": "Generated command packages and their command bindings."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "package": {
      "type": "object",
      "required": [
        "id",
        "program",
        "package_role",
        "version_metadata",
        "operation_contract_root",
        "targets",
        "commands"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]*$",
          "description": "Stable identifier used to reference this record."
        },
        "program": {
          "type": "string",
          "minLength": 1,
          "description": "Program text value used by this contract."
        },
        "package_role": {
          "enum": [
            "root-workspace-cli",
            "planning-module-cli",
            "memory-module-cli"
          ],
          "description": "Allowed package role value for routing or validation."
        },
        "version_metadata": {
          "type": "object",
          "required": [
            "source",
            "distribution",
            "fallback_version"
          ],
          "properties": {
            "source": {
              "const": "python-package-metadata",
              "description": "Version source used by generated Python CLI --version output."
            },
            "distribution": {
              "type": "string",
              "minLength": 1,
              "description": "Python distribution name queried through importlib.metadata."
            },
            "fallback_version": {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+.*$",
              "description": "Contract fallback used when package metadata is unavailable in a source checkout."
            }
          },
          "additionalProperties": false,
          "description": "Contract-backed source for generated Python CLI version output."
        },
        "operation_contract_root": {
          "type": "string",
          "minLength": 1,
          "description": "Repository-relative contract root that owns this package's operation artifacts."
        },
        "python_runtime_binding": {
          "type": "object",
          "required": [
            "entrypoint",
            "runtime_module_file"
          ],
          "properties": {
            "entrypoint": {
              "type": "string",
              "minLength": 1,
              "description": "Generated CLI entrypoint used by generic command_generation console handoff."
            },
            "runtime_module_file": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "description": "Generated sibling runtime module file imported by generated Python package bridge code."
            },
            "render_runtime_module": {
              "type": "boolean",
              "description": "Whether command-generation should render the runtime handler module instead of treating it as a hand-owned compatibility file."
            },
            "runtime_module_exports": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "import_module"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                  },
                  "import_module": {
                    "type": "string",
                    "minLength": 1
                  },
                  "function": {
                    "type": "string",
                    "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                  }
                },
                "additionalProperties": false
              },
              "description": "Compatibility functions re-exported by a generated runtime handler module for older internal callers while behavior lives in module runtime APIs."
            },
            "runtime_module_handlers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "operation_id",
                  "import_module",
                  "function"
                ],
                "properties": {
                  "operation_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "import_module": {
                    "type": "string",
                    "minLength": 1
                  },
                  "function": {
                    "type": "string",
                    "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                  }
                },
                "additionalProperties": false
              },
              "description": "Operation handlers rendered into a generated runtime handler map by importing named runtime primitive functions."
            },
            "resource_copies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "source_root",
                  "generated_root"
                ],
                "properties": {
                  "source_root": {
                    "type": "string",
                    "minLength": 1
                  },
                  "generated_root": {
                    "type": "string",
                    "minLength": 1
                  },
                  "required_marker": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false
              },
              "description": "Package product resources copied into the generated Python target so context roots do not depend on source package path helpers."
            },
            "local_runtime_bindings": {
              "type": "array",
              "description": "Generated-local runtime facade modules for remaining package-owned source delegates. Exported wrappers perform live source-module lookup at call time; monkeypatches applied to the facade stay local to that facade and are not patch-forwarded into source modules.",
              "items": {
                "type": "object",
                "required": [
                  "source_import_module",
                  "module_file"
                ],
                "properties": {
                  "source_import_module": {
                    "type": "string",
                    "minLength": 1
                  },
                  "module_file": {
                    "type": "string",
                    "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$"
                  },
                  "generated_function_overrides": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "function",
                        "implementation"
                      ],
                      "properties": {
                        "function": {
                          "type": "string",
                          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                        },
                        "implementation": {
                          "type": "string",
                          "enum": [
                            "target_root_resolve",
                            "sectioned_payload_select",
                            "json_resource_load",
                            "json_output_with_source_fallback"
                          ]
                        },
                        "generated_root": {
                          "type": "string",
                          "minLength": 1
                        },
                        "required_marker": {
                          "type": "string",
                          "minLength": 1
                        },
                        "payload_value": {
                          "type": "string",
                          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                        },
                        "source_command": {
                          "type": "string",
                          "minLength": 1
                        },
                        "common_sections": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "minLength": 1
                          }
                        },
                        "relative_path": {
                          "type": "string",
                          "minLength": 1
                        },
                        "table_name": {
                          "type": "string",
                          "minLength": 1
                        },
                        "relevance_field": {
                          "type": "string",
                          "minLength": 1
                        },
                        "required_value": {
                          "type": "string",
                          "minLength": 1
                        },
                        "optional_value": {
                          "type": "string",
                          "minLength": 1
                        },
                        "routing_only_field": {
                          "type": "string",
                          "minLength": 1
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1
                        },
                        "dry_run": {
                          "type": "boolean"
                        },
                        "detail_command": {
                          "type": "string",
                          "minLength": 1
                        },
                        "unhealthy_detail": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              },
              "description": "Package-owned runtime modules that should be projected behind generated-local facade modules instead of imported directly by generated commands or operation executors."
            },
            "operation_executor": {
              "$ref": "#/$defs/python_operation_executor_binding",
              "description": "Optional binding data used to render a generated Python operation IR executor module."
            }
          },
          "additionalProperties": false,
          "description": "Python-specific generated runtime binding data supplied by IR rather than hard-coded in the generator."
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/target",
            "description": "One entry in the targets list."
          },
          "description": "Ordered targets entries used by this contract."
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/command",
            "description": "One entry in the commands list."
          },
          "description": "Commands associated with this check, proof, or workflow step."
        }
      },
      "additionalProperties": false,
      "description": "Package details used by this contract."
    },
    "python_operation_executor_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_file",
        "supported_operation_ids",
        "initial_values",
        "handlers"
      ],
      "properties": {
        "module_file": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$"
        },
        "supported_operation_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "initial_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/python_operation_executor_initial_value"
          }
        },
        "context_roots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/python_operation_executor_context_root"
          },
          "default": []
        },
        "handlers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/python_operation_executor_handler"
          }
        }
      }
    },
    "python_operation_executor_initial_value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "arg"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "arg": {
          "type": "string",
          "minLength": 1
        },
        "default": {}
      }
    },
    "python_operation_executor_context_root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "import_module": {
          "type": "string",
          "minLength": 1
        },
        "function": {
          "type": "string",
          "minLength": 1
        },
        "generated_root": {
          "type": "string",
          "minLength": 1
        },
        "required_marker": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "python_operation_executor_handler": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primitive",
            "handler",
            "function"
          ],
          "properties": {
            "primitive": {
              "type": "string",
              "minLength": 1
            },
            "handler": {
              "const": "runtime_handler"
            },
            "function": {
              "type": "string",
              "minLength": 1
            },
            "import_module": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primitive",
            "handler",
            "import_module",
            "function",
            "kwargs"
          ],
          "properties": {
            "primitive": {
              "type": "string",
              "minLength": 1
            },
            "handler": {
              "const": "function_call"
            },
            "import_module": {
              "type": "string",
              "minLength": 1
            },
            "function": {
              "type": "string",
              "minLength": 1
            },
            "kwargs": {
              "$ref": "#/$defs/python_operation_executor_kwargs"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primitive",
            "handler",
            "condition_value",
            "if_true",
            "if_false"
          ],
          "properties": {
            "primitive": {
              "type": "string",
              "minLength": 1
            },
            "handler": {
              "const": "conditional_function_call"
            },
            "condition_value": {
              "type": "string",
              "minLength": 1
            },
            "if_true": {
              "$ref": "#/$defs/python_operation_executor_call"
            },
            "if_false": {
              "$ref": "#/$defs/python_operation_executor_call"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primitive",
            "handler",
            "project_markers"
          ],
          "properties": {
            "primitive": {
              "type": "string",
              "minLength": 1
            },
            "handler": {
              "const": "generated_target_root_resolve"
            },
            "project_markers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primitive",
            "handler",
            "runtime_function",
            "result_value",
            "format_value",
            "default_format"
          ],
          "properties": {
            "primitive": {
              "type": "string",
              "minLength": 1
            },
            "handler": {
              "const": "runtime_emit"
            },
            "runtime_function": {
              "type": "string",
              "minLength": 1
            },
            "result_value": {
              "type": "string",
              "minLength": 1
            },
            "format_value": {
              "type": "string",
              "minLength": 1
            },
            "default_format": {
              "type": "string",
              "minLength": 1
            },
            "dict_text_function": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "python_operation_executor_call": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "import_module",
        "function",
        "kwargs"
      ],
      "properties": {
        "import_module": {
          "type": "string",
          "minLength": 1
        },
        "function": {
          "type": "string",
          "minLength": 1
        },
        "kwargs": {
