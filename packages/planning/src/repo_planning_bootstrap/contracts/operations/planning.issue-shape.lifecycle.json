{
  "schema_version": "agentic-workspace/operation/v1",
  "id": "planning.issue-shape.lifecycle",
  "command_surface": {"program": "agentic-planning", "command": "issue-shape", "format_option": "format"},
  "summary": "Shape a durable issue-to-lane relation without activating work.",
  "classification": "lifecycle-mutation",
  "inputs": [
    {"name": "issue", "source": "cli-option", "required": false},
    {"name": "external_ref", "source": "cli-option", "required": false},
    {"name": "lane", "source": "cli-option", "required": false},
    {"name": "priority", "source": "cli-option", "required": false},
    {"name": "depends_on", "source": "cli-option", "required": false},
    {"name": "rationale", "source": "cli-option", "required": false},
    {"name": "maturity", "source": "cli-option", "required": false},
    {"name": "target", "source": "cli-option", "required": false},
    {"name": "expect_relation_revision", "source": "cli-option", "required": false},
    {"name": "expect_planning_revision", "source": "cli-option", "required": false},
    {"name": "dry_run", "source": "cli-option", "required": false},
    {"name": "format", "source": "cli-option", "required": false}
  ],
  "output": {"kind": "module-result"},
  "effects": {"read_only": false, "destructive": false, "idempotent": true, "writes_repo_state": true, "requires_preflight_gate": false},
  "locality": {"requires_repo": false, "network": "forbidden", "outside_repo_writes": "forbidden"},
  "reads": [
    {"surface": ".agentic-workspace/planning/issue-relations/<issue>.issue-relation.json", "required": false},
    {"surface": ".agentic-workspace/planning/schemas/planning-issue-relation.schema.json", "required": true}
  ],
  "writes": [
    {"surface": ".agentic-workspace/planning/issue-relations/<issue>.issue-relation.json", "required": false, "when": "not a dry run"}
  ],
  "steps": [
    {"id": "apply_issue_relation", "uses": "planning.issue-shape.apply", "description": "Create or field-scope update one strategic issue relation."},
    {"id": "emit_output", "uses": "output.emit", "description": "Emit the exact semantic delta and preserved invariants."}
  ],
  "guards": [
    "Never activate, queue, close, or select execution work from shaping.",
    "Do not rewrite state.toml, lane records, execplans, proof, progress, PR state, or external tracker state.",
    "Editing an existing relation requires the current relation revision."
  ],
  "proof": ["planning branch-safe tests cover non-activation, disjoint merge composition, same-relation conflict, and generated command exposure"],
  "migration_status": "runtime-consumed",
  "ir_plan": {
    "status": "representative",
    "summary": "Generated targets own parser and dispatch parity while Planning owns strategic issue relation semantics.",
    "steps": [
      {"id": "apply_issue_relation", "uses": "planning.issue-shape.apply", "description": "Create or field-scope update one strategic issue relation.", "arguments": {}, "outputs": ["result"], "on_error": "emit_usage_error"},
      {"id": "emit_output", "uses": "output.emit", "description": "Emit the exact semantic delta and preserved invariants.", "arguments": {}, "outputs": ["emitted"], "on_error": "emit_usage_error"}
    ]
  }
}
