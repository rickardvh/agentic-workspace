{
  "schema_version": "agentic-workspace/operation/v1",
  "id": "planning.front-door",
  "command_surface": {
    "command": "planning",
    "format_option": "format",
    "subcommands": [
      "close-item",
      "create-review"
    ]
  },
  "summary": "Show Planning help or dispatch Planning subcommands through the workspace front door.",
  "classification": "lifecycle-mutation",
  "inputs": [
    {
      "name": "target",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "format",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "subcommand",
      "source": "derived",
      "required": false
    }
  ],
  "output": {
    "kind": "text-or-json"
  },
  "effects": {
    "read_only": false,
    "destructive": false,
    "idempotent": false,
    "writes_repo_state": true,
    "requires_preflight_gate": false
  },
  "locality": {
    "requires_repo": false,
    "network": "forbidden",
    "outside_repo_writes": "forbidden"
  },
  "reads": [
    {
      "surface": "planning module runtime state",
      "required": false
    }
  ],
  "writes": [
    {
      "surface": "planning module managed state",
      "required": false
    }
  ],
  "steps": [
    {
      "id": "dispatch_planning_front_door",
      "uses": "planning.front_door.dispatch",
      "description": "Route the generated root planning command to the existing module runtime front door."
    },
    {
      "id": "emit_output",
      "uses": "output.emit",
      "description": "Emit module help or delegated command output."
    }
  ],
  "guards": [
    "Generated code owns parser/help/dispatch shape; module runtime owns package policy and command effects."
  ],
  "proof": [
    "operation contract validates against operation.schema.json",
    "generated command package parser accepts the root front-door command",
    "runtime adapter boundary remains thin"
  ],
  "migration_status": "draft-contract-only"
}
