    {"name": "mode", "source": "cli-option", "required": false},
    {"name": "reason", "source": "cli-option", "required": false},
    {"name": "current_work_id", "source": "cli-option", "required": false},
    {"name": "expect_planning_revision", "source": "cli-option", "required": false},
    {"name": "expect_current_work_revision", "source": "cli-option", "required": false},
    {"name": "dry_run", "source": "cli-option", "required": false},
    {"name": "format", "source": "cli-option", "required": false}
