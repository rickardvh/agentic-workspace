{
  "classification": "derived-output",
  "command_surface": {
    "command": "prompt",
    "subcommand": "upgrade"
  },
  "effects": {
    "destructive": false,
    "idempotent": true,
    "read_only": true,
    "requires_preflight_gate": false,
    "writes_repo_state": false
  },
  "guards": [
    "Prompt rendering must not mutate repository state."
  ],
  "id": "prompt.upgrade",
  "inputs": [
    {
      "name": "target",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "module",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "preset",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "format",
      "required": false,
      "source": "cli-option"
    }
  ],
  "ir_plan": {
    "status": "representative",
    "steps": [
      {
        "arguments": {},
        "description": "Resolve target, selected modules, preset, descriptors, and workspace config for prompt rendering.",
        "id": "resolve_selection",
        "on_error": "emit_usage_error",
        "outputs": [
          "selection"
        ],
        "uses": "workspace.selection.resolve"
      },
      {
        "arguments": {},
        "description": "Render the requested lifecycle handoff prompt payload.",
        "id": "render_prompt",
        "on_error": "fail",
        "outputs": [
          "result"
        ],
        "uses": "prompt.render"
      },
      {
        "arguments": {},
        "description": "Emit prompt text or JSON payload in the requested format.",
        "id": "emit_output",
        "on_error": "emit_usage_error",
        "outputs": [
          "emitted"
        ],
        "uses": "output.emit"
      }
    ],
    "summary": "Render the workspace upgrade handoff prompt from generated operation IR while workspace runtime supplies module selection and prompt text compatibility."
  },
  "locality": {
    "network": "forbidden",
    "outside_repo_writes": "forbidden",
    "requires_repo": false
  },
  "migration_status": "runtime-consumed",
  "output": {
    "kind": "text"
  },
  "proof": [
    "operation contract validates against operation.schema.json",
    "prompt upgrade tests remain compatible"
  ],
  "reads": [
    {
      "required": true,
      "surface": "module descriptors"
    },
    {
      "required": true,
      "surface": "workspace defaults"
    }
  ],
  "schema_version": "agentic-workspace/operation/v1",
  "steps": [
    {
      "description": "Resolve selected modules.",
      "id": "resolve_selection",
      "uses": "workspace.selection.resolve"
    },
    {
      "description": "Render upgrade handoff prompt.",
      "id": "render_prompt",
      "uses": "prompt.render"
    },
    {
      "description": "Emit prompt text.",
      "id": "emit_output",
      "uses": "output.emit"
    }
  ],
  "summary": "Print the workspace upgrade handoff prompt.",
  "writes": []
