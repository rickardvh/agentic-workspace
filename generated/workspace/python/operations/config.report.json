{
  "classification": "read-only-report",
  "command_surface": {
    "command": "config",
    "format_option": "format"
  },
  "effects": {
    "destructive": false,
    "idempotent": true,
    "read_only": true,
    "requires_preflight_gate": false,
    "writes_repo_state": false
  },
  "guards": [
    "Report config without writing repo state.",
    "Treat missing repo config as product-default resolution.",
    "Prefer --select for exact field drill-down and --verbose only for broad diagnostics."
  ],
  "id": "config.report",
  "inputs": [
    {
      "name": "target",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "format",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "select",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "verbose",
      "required": false,
      "source": "cli-option"
    }
  ],
  "ir_plan": {
    "fragments": [
      {
        "description": "Reusable report tail that projects requested fields and emits the command output.",
        "id": "select-and-emit-report",
        "inputs": [
          "result",
          "select",
          "format"
        ],
        "outputs": [
          "result",
          "emitted"
        ],
        "steps": [
          {
            "arguments": {
              "selected_output_kind": "agentic-workspace/selected-output/v1",
              "selector_detail_command": "agentic-workspace config --target . --select selector_inventory --format json",
              "selector_inventory_command": "agentic-workspace config --target . --select selector_inventory --format json",
              "source": "result",
              "source_command": "config"
            },
            "description": "Project requested exact fields from the config payload.",
            "id": "select_fields",
            "outputs": [
              "result"
            ],
            "uses": "payload.project"
          },
          {
            "arguments": {
              "text_views": [
                {
                  "id": "config.selected-output.text",
                  "lines": [
                    "Kind: {kind}",
                    "Source command: {source_command}",
                    "Values:",
                    {
                      "json": "values"
                    },
                    {
                      "lines": [
                        "Missing:",
                        {
                          "for_each": {
                            "path": "missing",
                            "template": "- {}"
                          }
                        }
                      ],
                      "when": "missing"
                    }
                  ],
                  "match": {
                    "kind": "agentic-workspace/selected-output/v1"
                  }
                },
                {
                  "id": "config.tiny.text",
                  "lines": [
                    "Target: {target}",
                    "Config path: {config_path}",
                    "AW enabled: {workspace.enabled} ({workspace.enabled_source})",
                    "Enabled modules: {workspace.enabled_modules|join:, |empty:(none)}",
                    "Improvement latitude: {workspace.improvement_latitude}",
                    "Optimization bias: {workspace.optimization_bias}",
                    "Delegation mode: {local_runtime.delegation_mode.value}",
                    "Safe to auto-run commands: {local_runtime.safe_to_auto_run_commands.value}",
                    "Select fields: {next_detail.select}",
                    "Verbose diagnostics: {next_detail.verbose}"
                  ],
                  "match": {
                    "kind": "agentic-workspace/config-tiny/v1"
                  }
                },
                {
                  "id": "config.compact.text",
                  "lines": [
                    "Target: {target}",
                    "Config path: {config_path}",
                    "Exists: {exists}",
                    "AW enabled: {workspace.enabled} ({workspace.enabled_source})",
                    "Enabled modules: {workspace.enabled_modules|join:, |empty:(none)}",
                    "Improvement latitude: {workspace.improvement_latitude}",
                    "Optimization bias: {workspace.optimization_bias}",
                    "Workflow obligations: {workspace.workflow_obligations|len} configured",
                    "Delegation mode: {local_runtime.delegation_mode.value}",
                    "Safe to auto-run commands: {local_runtime.safe_to_auto_run_commands.value}",
                    "Full profile: {full_profile_command}"
                  ],
                  "match": {
                    "profile": "compact"
                  }
                },
                {
                  "default": true,
                  "id": "config.full.text",
                  "lines": [
                    "Target: {target}",
                    "Config path: {config_path}",
                    "Exists: {exists}",
                    "AW enabled: {workspace.enabled} ({workspace.enabled_source})",
                    "Reference: {edit_reference.reference_doc}",
                    "Schema: {edit_reference.source_schema}",
                    "Check command: {edit_reference.check_command}",
                    {
                      "lines": [
                        "Warnings:",
                        {
                          "for_each": {
                            "path": "warnings",
                            "template": "- {}"
                          }
                        }
                      ],
                      "when": "warnings"
                    },
                    "Enabled modules: {workspace.enabled_modules|join:, |empty:(none)}",
                    "Agent instructions file: {workspace.agent_instructions_file} ({workspace.agent_instructions_file_source})",
                    "Workflow artifact profile: {workspace.workflow_artifact_profile} ({workspace.workflow_artifact_profile_source})",
                    "Agent configuration substrate: {workspace.agent_configuration_substrate.canonical_doc} ({workspace.agent_configuration_substrate.owner_surface})",
                    "System-intent sources: {workspace.system_intent.sources|join:, |empty:none} ({workspace.system_intent.sources_source})",
                    "Workflow obligations: {workspace.workflow_obligations|len} configured",
                    "Improvement latitude: {workspace.improvement_latitude} ({workspace.improvement_latitude_source})",
                    "Optimization bias: {workspace.optimization_bias} ({workspace.optimization_bias_source})",
                    "Advanced features: {workspace.advanced_features|join:, |empty:none} ({workspace.advanced_features_source})",
                    "CLI invoke: {workspace.cli_invoke} ({workspace.cli_invoke_source})",
                    "Wrapper rule: {update.wrapper_rule}",
                    "Update modules:",
                    {
                      "for_each": {
                        "lines": [
                          "- {module}: {source_type} {source_ref}",
                          "  label: {source_label}",
                          "  metadata: {metadata_path} ({sync_status})"
                        ],
                        "path": "update.modules"
                      }
                    },
                    "Mixed-agent:",
                    "- rule: {mixed_agent.rule}",
                    "- repo policy: {mixed_agent.repo_policy.path} ({mixed_agent.repo_policy.source})",
                    "- local override: {mixed_agent.local_override.path} ({mixed_agent.local_override.status})",
                    "- local integration area: {mixed_agent.local_integration_area.root} ({mixed_agent.local_integration_area.status})",
                    "- effective posture: internal delegation={mixed_agent.effective_posture.supports_internal_delegation.value}, strong planner={mixed_agent.effective_posture.strong_planner_available.value}, cheap bounded executor={mixed_agent.effective_posture.cheap_bounded_executor_available.value}",
                    "- delegation targets: {mixed_agent.delegation_targets.profiles|len} configured",
                    "- delegation outcome evidence: {mixed_agent.delegation_targets.outcome_artifact.path} ({mixed_agent.delegation_targets.outcome_artifact.status})"
                  ]
                }
              ]
            },
            "description": "Emit config output through portable output.emit using declared config text views.",
            "id": "emit_config",
            "outputs": [
              "emitted"
            ],
            "uses": "output.emit"
          }
        ]
      }
    ],
    "status": "representative",
    "steps": [
      {
        "arguments": {},
        "description": "Resolve and validate the target root for config lookup.",
        "id": "resolve_root",
        "outputs": [
          "target_root"
        ],
        "uses": "workspace.target-root.resolve"
      },
      {
        "arguments": {
          "include_payload": true
        },
        "description": "Load workspace config, defaults, local overrides, valid module metadata, and full config payload.",
        "id": "load_config",
        "outputs": [
          "config",
          "result"
        ],
        "uses": "workspace.config.load"
      },
      {
        "description": "Project requested fields and emit report output through a reusable operation-local fragment.",
        "id": "select_and_emit",
        "uses_fragment": "select-and-emit-report"
      }
    ],
    "summary": "Config report executes generated operation IR through codegen-owned primitive dataflow; payload.project owns exact selected-output projection and output.emit consumes contract-declared config text views."
  },
  "locality": {
    "network": "forbidden",
    "outside_repo_writes": "forbidden",
    "requires_repo": false
  },
  "migration_status": "runtime-consumed",
  "output": {
    "kind": "text-or-json"
  },
  "projections": {
    "cli": {
      "command_ref": "config"
    },
    "mcp": {
      "destructive_hint": false,
      "idempotent_hint": true,
      "read_only_hint": true,
      "tool_name": "agentic_workspace_config_report"
    },
    "skill": {
      "activation": [
        "resolved workspace config",
        "workspace policy"
      ],
      "instruction_summary": "Use this operation when an agent needs the effective workspace config."
    }
  },
  "proof": [
    "operation contract validates against operation.schema.json",
    "json output remains compatible with existing config command tests",
    "config.report uses command-generation-owned payload.project and output.emit text_views for exact field projection"
  ],
  "reads": [
    {
      "required": false,
      "surface": ".agentic-workspace/config.toml"
    },
    {
      "required": false,
      "surface": ".agentic-workspace/config.local.toml"
    },
    {
      "required": true,
      "surface": "product defaults"
    },
    {
      "required": false,
      "surface": "verbose flag for broad diagnostic output"
    },
    {
      "required": false,
      "surface": "field selector for exact JSON drill-down"
    }
  ],
  "schema_version": "agentic-workspace/operation/v1",
  "steps": [
    {
      "description": "Resolve the effective target root.",
      "id": "resolve_root",
      "uses": "workspace.target-root.resolve"
    },
    {
      "description": "Load workspace config, defaults, local override state, and the full config payload.",
      "id": "load_config",
      "uses": "workspace.config.load"
    },
    {
      "description": "Return only requested JSON fields when --select is provided.",
      "id": "select_fields",
      "uses": "payload.project"
    },
    {
      "description": "Emit resolved config with contract-declared text views or JSON.",
      "id": "emit_config",
      "uses": "output.emit"
    }
  ],
  "summary": "Show the resolved repo-owned workspace config layered onto product defaults.",
  "writes": []
}
