{
  "classification": "read-only-report",
  "command_surface": {
    "command": "config",
    "format_option": "format"
  },
  "effects": {
    "destructive": false,
    "idempotent": true,
    "read_only": true,
    "requires_preflight_gate": false,
    "writes_repo_state": false
  },
  "guards": [
    "Report config without writing repo state.",
    "Treat missing repo config as product-default resolution.",
    "Prefer --select for exact field drill-down and --verbose only for broad diagnostics."
  ],
  "id": "config.report",
  "inputs": [
    {
      "name": "target",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "format",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "select",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "verbose",
      "required": false,
      "source": "cli-option"
    }
  ],
  "ir_plan": {
    "fragments": [
      {
        "description": "Reusable report tail that selects requested fields and emits the command output.",
        "id": "select-and-emit-report",
        "inputs": [
          "config",
          "select",
          "format"
        ],
        "outputs": [
          "result",
          "emitted"
        ],
        "steps": [
          {
            "arguments": {},
            "description": "Select the requested config profile or exact field projection.",
            "id": "select_fields",
            "outputs": [
              "result"
            ],
            "uses": "output.fields.select"
          },
          {
            "arguments": {},
            "description": "Emit config output in the requested format.",
            "id": "emit_config",
            "outputs": [
              "emitted"
            ],
            "uses": "workspace.config.emit"
          }
        ]
      }
    ],
    "status": "representative",
    "steps": [
      {
        "arguments": {},
        "description": "Resolve and validate the target root for config lookup.",
        "id": "resolve_root",
        "outputs": [
          "target_root"
        ],
        "uses": "workspace.root.resolve"
      },
      {
        "arguments": {},
        "description": "Load workspace config, defaults, local overrides, and valid preset metadata.",
        "id": "load_config",
        "outputs": [
          "config"
        ],
        "uses": "workspace.config.load"
      },
      {
        "description": "Select and emit report output through a reusable operation-local fragment.",
        "id": "select_and_emit",
        "uses_fragment": "select-and-emit-report"
      }
    ],
    "summary": "Config report executes generated operation IR through codegen-owned primitive dataflow, using an operation-local report emission fragment while workspace runtime supplies config loading and text compatibility formatting."
  },
  "locality": {
    "network": "forbidden",
    "outside_repo_writes": "forbidden",
    "requires_repo": false
  },
  "migration_status": "runtime-consumed",
  "output": {
    "kind": "text-or-json"
  },
  "projections": {
    "cli": {
      "command_ref": "config"
    },
    "mcp": {
      "destructive_hint": false,
      "idempotent_hint": true,
      "read_only_hint": true,
      "tool_name": "agentic_workspace_config_report"
    },
    "skill": {
      "activation": [
        "resolved workspace config",
        "workspace policy"
      ],
      "instruction_summary": "Use this operation when an agent needs the effective workspace config."
    }
  },
  "proof": [
    "operation contract validates against operation.schema.json",
    "json output remains compatible with existing config command tests",
    "config.report uses an operation-local emit fragment executed by generated Python and TypeScript targets"
  ],
  "reads": [
    {
      "required": false,
      "surface": ".agentic-workspace/config.toml"
    },
    {
      "required": false,
      "surface": ".agentic-workspace/config.local.toml"
    },
    {
      "required": true,
      "surface": "product defaults"
    },
    {
      "required": false,
      "surface": "verbose flag for broad diagnostic output"
    },
    {
      "required": false,
      "surface": "field selector for exact JSON drill-down"
    }
  ],
  "schema_version": "agentic-workspace/operation/v1",
  "steps": [
    {
      "description": "Resolve the effective target root.",
      "id": "resolve_root",
      "uses": "workspace.root.resolve"
    },
    {
      "description": "Load workspace config, defaults, and local override state.",
      "id": "load_config",
      "uses": "workspace.config.load"
    },
    {
      "description": "Return only requested JSON fields when --select is provided.",
      "id": "select_fields",
      "uses": "output.fields.select"
    },
    {
      "description": "Emit resolved config in the requested format.",
      "id": "emit_config",
      "uses": "workspace.config.emit"
    }
  ],
  "summary": "Show the resolved repo-owned workspace config layered onto product defaults.",
  "writes": []
