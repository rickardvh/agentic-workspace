{
  "classification": "lifecycle-mutation",
  "command_surface": {
    "command": "upgrade"
  },
  "effects": {
    "destructive": false,
    "idempotent": true,
    "read_only": false,
    "requires_preflight_gate": true,
    "writes_repo_state": true
  },
  "guards": [
    "Enforce strict preflight when configured.",
    "Respect dry-run mode by avoiding writes.",
    "Keep legacy scratch cleanup explicit and scoped to guarded entries under .agentic-workspace/local/scratch."
  ],
  "id": "upgrade.lifecycle",
  "inputs": [
    {
      "name": "target",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "module",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "dry_run",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "legacy_scratch_cleanup",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "apply_legacy_scratch_cleanup",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "repair_managed_local_instructions",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "to_payload_target",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "format",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "preflight_token",
      "required": false,
      "source": "cli-option"
    }
  ],
  "ir_plan": {
    "status": "complete",
    "steps": [
      {
        "arguments": {
          "operation_id": "upgrade.lifecycle"
        },
        "description": "Execute the operation through the generated TypeScript domain operation table.",
        "id": "execute_typescript_domain_operation",
        "on_error": "fail",
        "outputs": [
          "result"
        ],
        "uses": "typescript.domain.execute"
      },
      {
        "arguments": {},
        "description": "Emit the TypeScript-native operation result.",
        "id": "emit_output",
        "on_error": "emit_usage_error",
        "outputs": [
          "emitted"
        ],
        "uses": "output.emit"
      }
    ],
    "summary": "Generated TypeScript native runtime binding for a command whose source operation has not yet been decomposed into portable IR."
  },
  "locality": {
    "network": "forbidden",
    "outside_repo_writes": "forbidden",
    "requires_repo": true
  },
  "migration_status": "draft-contract-only",
  "output": {
    "kind": "module-result"
  },
  "proof": [
    "operation contract validates against operation.schema.json",
    "upgrade lifecycle tests remain compatible",
    "upgrade.lifecycle.dry-run.process proves dry-run plan shape and no filesystem writes",
    "upgrade.lifecycle.strict-preflight-refusal.process proves strict preflight refuses before mutation without writes"
  ],
  "reads": [
    {
      "required": false,
      "surface": "workspace config"
    },
    {
      "required": true,
      "surface": "selected module payloads"
    },
    {
      "required": false,
      "surface": "target repository managed surfaces"
    }
  ],
  "schema_version": "agentic-workspace/operation/v1",
  "steps": [
    {
      "description": "Resolve the target repository.",
      "id": "resolve_root",
      "uses": "workspace.target-root.resolve"
    },
    {
      "description": "Load config defaults and selection policy.",
      "id": "load_config",
      "uses": "workspace.config.load"
    },
    {
      "description": "Resolve selected modules.",
      "id": "resolve_selection",
      "uses": "workspace.selection.resolve"
    },
    {
      "description": "Plan upgrade changes or explicit legacy scratch cleanup when selected.",
      "id": "plan_lifecycle",
      "uses": "workspace.lifecycle.plan"
    },
    {
      "description": "Apply upgrade changes when not a dry run; apply legacy scratch cleanup only when explicitly requested.",
      "id": "apply_lifecycle",
      "uses": "workspace.lifecycle.apply"
    },
    {
      "description": "Emit lifecycle result.",
      "id": "emit_output",
      "uses": "output.emit"
    }
  ],
  "summary": "Refresh managed surfaces for selected installed modules.",
  "writes": [
    {
      "required": true,
      "surface": "target repository managed workspace surfaces",
      "when": "not a dry run"
    }
  ]
}
