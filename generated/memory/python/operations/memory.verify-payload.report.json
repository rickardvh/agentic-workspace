{
  "classification": "read-only-report",
  "command_surface": {
    "command": "verify-payload",
    "format_option": "format",
    "program": "agentic-memory"
  },
  "effects": {
    "destructive": false,
    "idempotent": true,
    "read_only": true,
    "requires_preflight_gate": false,
    "writes_repo_state": false
  },
  "guards": [
    "Verification must remain read-only.",
    "Generated code owns parser/help/dispatch shape.",
    "Text and JSON output must execute payload verification through the AW/Memory-owned memory.payload.verify primitive and package-owned policy JSON."
  ],
  "id": "memory.verify-payload.report",
  "inputs": [
    {
      "name": "target",
      "required": false,
      "source": "cli-option"
    },
    {
      "name": "format",
      "required": false,
      "source": "cli-option"
    }
  ],
  "ir_plan": {
    "status": "representative",
    "steps": [
      {
        "arguments": {
          "must_be_dir": true,
          "must_exist": true
        },
        "description": "Resolve the target repository root for version detection and relative output paths.",
        "id": "resolve_target_root",
        "on_error": "emit_usage_error",
        "outputs": [
          "target_root"
        ],
        "uses": "path.target_root.resolve"
      },
      {
        "arguments": {
          "payload_root": "memory.package-payload",
          "policy_path": "payload_verification.memory.json",
          "policy_root": "memory.contracts",
          "target_root_value": "target_root"
        },
        "description": "Verify bundled memory payload files through package-owned payload verification policy.",
        "id": "verify_payload_policy",
        "on_error": "fail",
        "outputs": [
          "result"
        ],
        "uses": "memory.payload.verify"
      },
      {
        "arguments": {},
        "description": "Emit memory payload verification result in the requested format.",
        "id": "emit_output",
        "on_error": "emit_usage_error",
        "outputs": [
          "emitted"
        ],
        "uses": "memory.output.emit.install-result"
      }
    ],
    "summary": "Memory verify-payload text and JSON execute generated operation IR through codegen-owned primitive dataflow and package-owned payload verification policy."
  },
  "locality": {
    "network": "forbidden",
    "outside_repo_writes": "forbidden",
    "requires_repo": false
  },
  "migration_status": "runtime-consumed",
  "output": {
    "kind": "module-result"
  },
  "proof": [
    "operation contract validates against operation.schema.json",
    "generated memory verify-payload process conformance passes"
  ],
  "reads": [
    {
      "required": true,
      "surface": "memory package payload files"
    },
    {
      "required": true,
      "surface": "packages/memory/src/repo_memory_bootstrap/contracts/payload_verification.memory.json"
    }
  ],
  "schema_version": "agentic-workspace/operation/v1",
  "steps": [
    {
      "description": "Resolve the target repository root for version detection and relative output paths.",
      "id": "resolve_target_root",
      "uses": "path.target_root.resolve"
    },
    {
      "description": "Verify bundled memory payload files through package-owned payload verification policy.",
      "id": "verify_payload_policy",
      "uses": "memory.payload.verify"
    },
    {
      "description": "Emit memory payload verification result in the requested format.",
      "id": "emit_output",
      "uses": "memory.output.emit.install-result"
    }
  ],
  "summary": "Verify bundled memory payload and generated operation resources against the package-owned declarative payload verification policy.",
  "writes": []
