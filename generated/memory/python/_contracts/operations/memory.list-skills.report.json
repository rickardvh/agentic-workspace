{
  "schema_version": "agentic-workspace/operation/v1",
  "id": "memory.list-skills.report",
  "command_surface": {
    "program": "agentic-memory",
    "command": "list-skills",
    "format_option": "format"
  },
  "summary": "List bundled memory bootstrap lifecycle skills.",
  "classification": "read-only-report",
  "inputs": [
    {
      "name": "format",
      "source": "cli-option",
      "required": false
    }
  ],
  "output": {
    "kind": "text-or-json"
  },
  "effects": {
    "read_only": true,
    "destructive": false,
    "idempotent": true,
    "writes_repo_state": false,
    "requires_preflight_gate": false
  },
  "locality": {
    "requires_repo": false,
    "network": "forbidden",
    "outside_repo_writes": "forbidden"
  },
  "reads": [
    {
      "surface": "packaged memory bootstrap skill registry",
      "required": true
    }
  ],
  "writes": [],
  "steps": [
    {
      "id": "load_skill_registry",
      "uses": "filesystem.read",
      "description": "Read the packaged memory skill registry."
    },
    {
      "id": "parse_skill_registry",
      "uses": "json.parse",
      "description": "Parse the packaged memory skill registry."
    },
    {
      "id": "assemble_payload",
      "uses": "payload.assemble",
      "description": "Build the module-result payload containing bundled skill actions."
    },
    {
      "id": "emit_output",
      "uses": "output.emit",
      "description": "Emit skill list in the requested format."
    }
  ],
  "ir_plan": {
    "status": "complete",
    "summary": "Complete target-executor IR for a read-only package-resource command that loads a JSON registry and emits module-result output.",
    "steps": [
      {
        "id": "load_skill_registry",
        "uses": "filesystem.read",
        "description": "Read the packaged memory skill registry.",
        "arguments": {
          "root": "memory.package-skills",
          "path": "REGISTRY.json"
        },
        "reads": [
          "packaged memory bootstrap skill registry"
        ],
        "outputs": [
          "registry_text"
        ],
        "on_error": "fail"
      },
      {
        "id": "parse_skill_registry",
        "uses": "json.parse",
        "description": "Parse the packaged memory skill registry.",
        "inputs": [
          "registry_text"
        ],
        "outputs": [
          "registry"
        ],
        "on_error": "fail"
      },
      {
        "id": "assemble_payload",
        "uses": "payload.assemble",
        "description": "Build the module-result payload containing bundled skill actions.",
        "arguments": {
          "fields": {
            "dry_run": true,
            "message": "Bundled skills",
            "actions_from": "registry.skills",
            "mode": "skills",
            "bootstrap_version_from": "registry.bootstrap_version"
          }
        },
        "inputs": [
          "registry"
        ],
        "outputs": [
          "result"
        ],
        "on_error": "fail"
      },
      {
        "id": "emit_output",
        "uses": "output.emit",
        "description": "Emit the result as JSON or text according to the format option.",
        "inputs": [
          "result",
          "format"
        ],
        "outputs": [
          "emitted"
        ],
        "on_error": "emit_usage_error"
      }
    ],
    "portability_notes": [
      "Target executors can implement this complete plan with package-resource file reads, JSON parsing, payload assembly, and output emission.",
      "The generated Python command projection composes these primitive operations directly; remaining report commands stay on runtime-consumed operation execution until promoted."
    ]
  },
  "guards": [
    "List-skills must remain read-only."
  ],
  "proof": [
    "operation contract validates against operation.schema.json",
    "operation command parity checks agentic-memory live parser"
  ],
  "migration_status": "runtime-consumed"
}
