FROM python:3.12

WORKDIR /work

RUN python -m pip install --no-cache-dir jsonschema

COPY src ./src
COPY scripts ./scripts
COPY packages ./packages
COPY generated ./generated

ENV PYTHONPATH=/work/src:/work/packages/planning/src:/work/packages/memory/src:/work/packages/command-generation/src
ENV AGENTIC_GENERATED_CONFORMANCE_CONTAINER=python

CMD ["python", "scripts/check/check_generated_command_packages.py", "--python-conformance"]
