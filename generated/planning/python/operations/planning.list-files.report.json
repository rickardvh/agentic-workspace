{
  "classification": "read-only-report",
  "command_surface": {
    "command": "list-files",
    "format_option": "format",
    "program": "agentic-planning"
  },
  "effects": {
    "destructive": false,
    "idempotent": true,
    "read_only": true,
    "requires_preflight_gate": false,
    "writes_repo_state": false
  },
  "guards": [
    "Listing bundled files must remain read-only."
  ],
  "id": "planning.list-files.report",
  "inputs": [
    {
      "name": "format",
      "required": false,
      "source": "cli-option"
    }
  ],
  "ir_plan": {
    "status": "complete",
    "steps": [
      {
        "arguments": {
          "pattern": "**/*",
          "root": "planning.package-payload",
          "sort": "lexicographic"
        },
        "description": "List bundled planning payload files as stable relative paths.",
        "id": "list_payload_files",
        "on_error": "fail",
        "outputs": [
          "files"
        ],
        "uses": "filesystem.glob"
      },
      {
        "arguments": {
          "pattern": "**/*",
          "root": "planning.package-skills",
          "sort": "lexicographic"
        },
        "description": "List bundled planning skill files as stable relative paths.",
        "id": "list_bundled_skill_files",
        "on_error": "fail",
        "outputs": [
          "bundled_skill_files"
        ],
        "uses": "filesystem.glob"
      },
      {
        "arguments": {
          "fields": {
            "bundled_skill_files_from": "bundled_skill_files",
            "default_files": [
              "AGENTS.template.md",
              ".agentic-workspace/docs/execution-flow-contract.md",
              ".agentic-workspace/docs/system-intent-contract.md",
              ".agentic-workspace/docs/routing-contract.md",
              ".agentic-workspace/docs/minimum-operating-model.md",
              ".agentic-workspace/docs/lifecycle-and-config-contract.md",
              ".agentic-workspace/docs/workspace-config-contract.md",
              ".agentic-workspace/planning/execplans/README.md",
              ".agentic-workspace/planning/execplans/TEMPLATE.plan.json",
              ".agentic-workspace/planning/execplans/archive/README.md",
              ".agentic-workspace/planning/decompositions/README.md",
              ".agentic-workspace/planning/decompositions/TEMPLATE.decomposition.json",
              ".agentic-workspace/planning/schemas/planning-execplan.schema.json",
              ".agentic-workspace/planning/schemas/planning-decomposition.schema.json",
              ".agentic-workspace/planning/schemas/planning-review.schema.json",
              ".agentic-workspace/planning/schemas/planning-external-intent-evidence.schema.json",
              ".agentic-workspace/planning/schemas/planning-finished-work-evidence.schema.json",
              ".agentic-workspace/planning/UPGRADE-SOURCE.toml",
              ".agentic-workspace/planning/agent-manifest.json"
            ],
            "files_from": "files",
            "optional_enable_commands": [
              "agentic-planning install --include-optional",
              "agentic-planning adopt --include-optional",
              "agentic-planning upgrade --include-optional"
            ],
            "optional_files": [
              ".agentic-workspace/docs/capability-contract.json",
              ".agentic-workspace/planning/reviews/README.md",
              ".agentic-workspace/planning/reviews/TEMPLATE.review.json",
              ".agentic-workspace/planning/upstream-task-intake.md",
              ".agentic-workspace/planning/pre-ingestion-refinement.md"
            ],
            "payload_kind": "package-file-list"
          }
        },
        "description": "Build the planning list-files payload from package resources and static enablement commands.",
        "id": "assemble_payload",
        "inputs": [
          "files",
          "bundled_skill_files"
        ],
        "on_error": "fail",
        "outputs": [
          "result"
        ],
        "uses": "payload.assemble"
      },
      {
        "arguments": {},
        "description": "Emit the planning payload file list in the requested format.",
        "id": "emit_output",
        "on_error": "emit_usage_error",
        "outputs": [
          "emitted"
        ],
        "uses": "output.emit"
      }
    ],
    "summary": "Planning list-files is a complete generated command projection over package payload and skill resources without importing package runtime code or the generic operation IR runner."
  },
  "locality": {
    "network": "forbidden",
    "outside_repo_writes": "forbidden",
    "requires_repo": false
  },
  "migration_status": "runtime-consumed",
  "output": {
    "kind": "text-or-json"
  },
  "proof": [
    "operation contract validates against operation.schema.json",
    "generated list-files process conformance passes"
  ],
  "reads": [
    {
      "required": true,
      "surface": "planning package payload manifest"
    }
  ],
  "schema_version": "agentic-workspace/operation/v1",
  "steps": [
    {
      "description": "List bundled planning payload files as stable relative paths.",
      "id": "list_payload_files",
      "uses": "filesystem.glob"
    },
    {
      "description": "List bundled planning skill files as stable relative paths.",
      "id": "list_bundled_skill_files",
      "uses": "filesystem.glob"
    },
    {
      "description": "Build the list-files payload containing required, optional, bundled skill, and optional enablement data.",
      "id": "assemble_payload",
      "uses": "payload.assemble"
    },
    {
      "description": "Emit the planning payload file list in the requested format.",
      "id": "emit_output",
      "uses": "output.emit"
    }
  ],
  "summary": "List bundled planning payload files and optional payload enablement commands.",
  "writes": []
}
