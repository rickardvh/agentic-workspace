{
  "schema_version": "agentic-workspace/command-adapter-generation/v1",
  "summary": "Generator-facing bindings that join command shape, operation contracts, primitive refs, schemas, projection hints, and conformance refs without owning runtime primitive behavior.",
  "schema": "schemas/command_adapter_generation.schema.json",
  "projection_requirements": {
    "core_contract_rule": "Keep universal command truth in the generation contract and leave target-specific rendering, packaging, invocation, and transport details in projection metadata or generated adapters.",
    "universal_command_truth": [
      "stable command identity",
      "owning program or package surface",
      "visible command and subcommand names",
      "argument and option semantics",
      "operation id and registry path",
      "runtime primitive sequence",
      "input and output schema refs",
      "read/write/destructive/idempotence effects",
      "conformance refs"
    ],
    "adapter_specific_rendering": [
      "argv spelling and quoting",
      "help text layout",
      "exit-code mapping",
      "environment variable mapping",
      "package manager entrypoint wiring",
      "shell function or script wrapper shape",
      "transport envelope shape",
      "target-specific installation metadata"
    ],
    "future_target_kinds": [
      {
        "kind": "process-cli",
        "status": "supported-now",
        "requirements": [
          "render argv from command option semantics",
          "dispatch to runtime binding by adapter id",
          "preserve conformance checks as black-box process assertions"
        ]
      },
      {
        "kind": "npm-cli",
        "status": "requirements-baseline",
        "requirements": [
          "map stable command identity to package bin entrypoints",
          "preserve option semantics without assuming Python argparse",
          "keep runtime behavior behind package-local implementation bindings"
        ]
      },
      {
        "kind": "posix-shell",
        "status": "requirements-baseline",
        "requirements": [
          "derive wrapper invocation from universal command truth",
          "keep quoting and environment handling target-specific",
          "delegate runtime behavior instead of embedding primitives"
        ]
      },
      {
        "kind": "powershell",
        "status": "requirements-baseline",
        "requirements": [
          "derive command parameters from option semantics",
          "keep parameter binding and error rendering target-specific",
          "preserve read/write/effect hints for preflight decisions"
        ]
      },
      {
        "kind": "binary",
        "status": "requirements-baseline",
        "requirements": [
          "map command identity to compiled entrypoint metadata",
          "preserve schema refs and effect hints for generated docs and checks",
          "avoid embedding source-language runtime assumptions"
        ]
      },
      {
        "kind": "local-mcp-tool",
        "status": "requirements-baseline",
        "requirements": [
          "map operation input and output schemas to tool schemas",
          "preserve effect hints for tool safety declarations",
          "route implementation through runtime bindings outside the contract"
        ]
      },
      {
        "kind": "generated-skill",
        "status": "requirements-baseline",
        "requirements": [
          "derive user-facing invocation guidance from command semantics",
          "route canonical behavior to contracts and compact command outputs",
          "avoid duplicating doctrine in generated prose"
        ]
      }
    ],
    "pollution_guardrails": [
      "Do not add Python module paths to universal command truth.",
      "Do not add host tracker, repository, or agent assumptions to generated adapter requirements.",
      "Do not make adapter-specific rendering fields required for every target.",
      "Do not let generated prose adapters become canonical behavior."
    ]
  },
  "generated_outputs": [
    {
      "program": "agentic-workspace",
      "path": "src/agentic_workspace/generated_command_adapters.py"
    },
    {
      "program": "agentic-planning-bootstrap",
      "path": "packages/planning/src/repo_planning_bootstrap/generated_command_adapters.py"
    }
  ],
  "package_surface_migration": {
    "planning": {
      "program": "agentic-planning-bootstrap",
      "first_read_only_candidate": "status",
      "status": "first-read-only-generated",
      "next_step": "Use the planning status adapter proof before considering summary/report/handoff read-only adapters."
    },
    "memory": {
      "program": "agentic-memory-bootstrap",
      "first_read_only_candidate": "status",
      "status": "planned-next-package-surface",
      "next_step": "Add memory status as the next read-only package adapter only after multi-adapter projection requirements are explicit."
    }
  },
  "adapters": [
    {
      "id": "defaults.report.cli",
      "status": "generated",
      "command": {
        "program": "agentic-workspace",
        "name": "defaults",
        "command_manifest": "cli_commands.json",
        "option_group_manifest": "cli_option_groups.json"
      },
      "operation_ref": {
        "id": "defaults.report",
        "registry": "operation_contracts.json",
        "path": "operations/defaults.report.json"
      },
      "runtime_binding": {
        "kind": "operation-primitive-sequence",
        "primitive_refs": [
          "workspace.defaults.load",
          "workspace.defaults.select",
          "output.emit"
        ]
      },
      "schemas": {
        "input": [],
        "output": [
          "compact_contract_answer.schema.json"
        ]
      },
      "effect_hints": {
        "read_only": true,
        "destructive": false,
        "idempotent": true,
        "writes_repo_state": false,
        "requires_preflight_gate": false
      },
      "projection_hints": {
        "universal_fields": [
          "command.name",
          "command.options",
          "operation_ref.id",
          "runtime_binding.primitive_refs",
          "schemas.output",
          "effect_hints",
          "conformance_refs"
        ],
        "adapter_specific_fields": [
          {
            "kind": "process-cli",
            "fields": [
              "program",
              "argument rendering",
              "help rendering",
              "exit-code rendering"
            ]
          }
        ]
      },
      "generation_boundary": {
        "contract_owns": [
          "visible command name",
          "argument and option shape",
          "help and usage text source",
          "operation id",
          "effect/read/write hints",
          "schema refs",
          "conformance refs"
        ],
        "generated_adapter_owns": [
          "parser and usage wiring",
          "argument normalization into the operation input shape",
          "dispatch wiring from command id to runtime binding"
        ],
        "runtime_owns": [
          "primitive implementation",
          "live workspace inspection",
          "payload assembly",
          "output emission mechanics"
        ]
      },
      "conformance_refs": [
        "defaults.report.process"
      ]
    },
    {
      "id": "planning.status.cli",
      "status": "generated",
      "command": {
        "program": "agentic-planning-bootstrap",
        "name": "status",
        "command_manifest": "package:planning:cli",
        "option_group_manifest": "package:planning:cli"
      },
      "operation_ref": {
        "id": "planning.status.report",
        "registry": "operation_contracts.json",
        "path": "operations/planning.status.report.json"
      },
      "runtime_binding": {
        "kind": "operation-primitive-sequence",
        "primitive_refs": [
          "planning.bootstrap.status.load",
          "output.emit"
        ]
      },
      "schemas": {
        "input": [],
        "output": []
      },
      "effect_hints": {
        "read_only": true,
        "destructive": false,
        "idempotent": true,
        "writes_repo_state": false,
        "requires_preflight_gate": false
      },
      "projection_hints": {
        "universal_fields": [
          "command.program",
          "command.name",
          "operation_ref.id",
          "runtime_binding.primitive_refs",
          "effect_hints",
          "conformance_refs"
        ],
        "adapter_specific_fields": [
          {
            "kind": "process-cli",
            "fields": [
              "program",
              "argument rendering",
              "help rendering",
              "exit-code rendering"
            ]
          }
        ]
      },
      "generation_boundary": {
        "contract_owns": [
          "visible package command name",
          "operation id",
          "effect/read/write hints",
          "conformance refs"
        ],
        "generated_adapter_owns": [
          "dispatch wiring from command id to runtime binding"
        ],
        "runtime_owns": [
          "package-local primitive implementation",
          "live planning surface inspection",
          "payload assembly",
          "output emission mechanics"
        ]
      },
      "conformance_refs": [
        "planning.status.process"
      ]
    }
  ]
}
