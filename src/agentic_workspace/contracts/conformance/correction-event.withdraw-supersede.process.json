        {
          "equals": "agentic-workspace/correction-event-operation-result/v1",
          "path": [
            "kind"
          ]
        },
        {
          "equals": "stored",
          "path": [
            "status"
          ]
        }
      ],
      "format": "json"
    }
  },
  "fixtures": [
    {
      "files": {
        ".agentic-workspace/config.local.toml": "schema_version = 1\n\n[delegation]\ncurrent_target = \"user-local:fast-worker\"\n\n[local_memory]\ntarget_guidance_enabled = true\nuser_guidance_root = \"~/.agentic-workspace/target-guidance\"\ncorrection_events_path = \".agentic-workspace/local/correction-events.json\"\n\n[delegation_targets.fast_worker]\ntarget_id = \"user-local:fast-worker\"\ntarget_revision = \"rev-1\"\naliases = [\"fast\"]\nrevision_policy = \"preserve\"\nstrength = \"strong\"\nexecution_methods = [\"internal\"]\n",
        ".agentic-workspace/config.toml": "schema_version = 1\n[workspace]\ncli_invoke = \"agentic-workspace\"\n",
        ".git/.keep": "",
