      "--target",
      ".",
      "--delivery-id",
      "delivery-withdraw-1",
      "--target-identity-ref",
      "fast",
      "--target-revision",
      "rev-1",
      "--task-class",
      "mechanical-follow-through",
      "--scope-class",
      "narrow-code-change",
      "--invariant-id",
      "narrow-edits",
      "--behavior-class",
      "edit-scope",
      "--desired-behavior",
      "Prefer narrow edits.",
      "--replaced-behavior",
      "Broad edits.",
      "--source-ref",
      "agent-note-2",
