{
  "schema_version": "agentic-workspace/conformance/v1",
  "id": "planning.issue-shape.lifecycle.process",
  "operation_id": "planning.issue-shape.lifecycle",
  "adapter": {
    "kind": "process",
    "command_template": [
      "{agentic_planning_cli}",
      "issue-shape",
      "--issue",
      "tmp-issue",
      "--lane",
      "tmp-lane",
      "--priority",
      "p0",
      "--maturity",
      "shaped",
      "--target",
      ".",
      "--dry-run",
      "--format",
      "json"
    ],
    "cwd": "fixture_root"
  },
  "fixtures": [{"id": "issue-shape-dry-run", "files": {".git/.keep": ""}}],
  "expectations": {
    "exit": {"code": 0},
    "stdout": {
      "format": "json",
      "field_assertions": [
        {"path": ["dry_run"], "equals": true},
        {"path": ["operation_receipt", "outcome"], "equals": "dry-run"}
      ]
    },
    "stderr": {"allow_non_empty": false},
    "filesystem": {
      "allowed_write_paths": [],
      "required_paths": [".git/.keep"],
      "forbidden_paths": [".agentic-workspace/planning/issue-relations/tmp-issue.issue-relation.json"]
    },
    "idempotency": {"run_twice": true},
    "safety": {"no_writes_outside_repo_root": true}
  }
}
