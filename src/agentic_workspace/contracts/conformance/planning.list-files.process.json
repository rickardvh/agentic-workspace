{
  "schema_version": "agentic-workspace/conformance/v1",
  "id": "planning.list-files.process",
  "operation_id": "planning.list-files.report",
  "adapter": {
    "kind": "process",
    "command_template": [
      "{agentic_planning_cli}",
      "list-files",
      "--format",
      "json"
    ],
    "cwd": "fixture_root"
  },
  "fixtures": [
    {
      "id": "empty-fixture",
      "files": {
        ".git/.keep": ""
      }
    }
  ],
  "expectations": {
    "exit": {
      "code": 0
    },
    "stdout": {
      "format": "json",
      "field_assertions": [
        {
          "path": [
            "optional_enable_commands"
          ],
          "equals": [
            "agentic-planning install --include-optional",
            "agentic-planning adopt --include-optional",
            "agentic-planning upgrade --include-optional"
          ]
        }
      ]
    },
    "stderr": {
      "allow_non_empty": false
    },
    "filesystem": {
      "allowed_write_paths": [],
      "required_paths": [
        ".git/.keep"
      ],
      "forbidden_paths": [
        ".agentic-workspace"
      ]
    },
    "idempotency": {
      "run_twice": true
    },
    "safety": {
      "no_writes_outside_repo_root": true
    }
  }
}
