{
  "schema_version": "agentic-workspace/conformance/v1",
  "id": "planning.lane-create.lifecycle.dry-run.process",
  "operation_id": "planning.lane-create.lifecycle",
  "adapter": {
    "kind": "process",
    "command_template": [
      "{agentic_planning_cli}",
      "lane-create",
      "--id",
      "tmp-lane",
      "--title",
      "Tmp Lane",
      "--target",
      ".",
      "--dry-run",
      "--format",
      "json"
    ],
    "cwd": "fixture_root"
  },
  "fixtures": [{"id": "lane-create-dry-run", "files": {".git/.keep": ""}}],
  "expectations": {
    "exit": {"code": 0},
    "stdout": {"format": "json", "field_assertions": [{"path": ["dry_run"], "equals": true}]},
    "stderr": {"allow_non_empty": false},
    "filesystem": {"allowed_write_paths": [], "required_paths": [".git/.keep"], "forbidden_paths": [".agentic-workspace"]},
    "idempotency": {"run_twice": true},
    "safety": {"no_writes_outside_repo_root": true}
  }
}
