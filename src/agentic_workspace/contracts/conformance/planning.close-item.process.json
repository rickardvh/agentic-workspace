{
  "schema_version": "agentic-workspace/conformance/v1",
  "id": "planning.close-item.process",
  "operation_id": "planning.close-item.lifecycle",
  "adapter": {
    "kind": "process",
    "command_template": [
      "{agentic_planning_cli}",
      "close-item",
      "missing-item",
      "--dry-run",
      "--format",
      "json"
    ],
    "cwd": "fixture_root"
  },
  "fixtures": [
    {
      "id": "minimal-planning-repo",
      "files": {
        ".git/.keep": "",
        "README.md": "# Fixture\n"
      }
    }
  ],
  "expectations": {
    "exit": {
      "code": 0
    },
    "stdout": {
      "format": "json",
      "field_assertions": [
        {
          "path": [
            "dry_run"
          ],
          "equals": true
        },
        {
          "path": [
            "message"
          ],
          "equals": "Close planning item missing-item"
        }
      ]
    },
    "stderr": {
      "allow_non_empty": false
    },
    "filesystem": {
      "allowed_write_paths": [],
      "required_paths": [
        ".git/.keep",
        "README.md"
      ],
      "forbidden_paths": [
        ".agentic-workspace"
      ]
    },
    "idempotency": {
      "run_twice": true
    },
    "safety": {
      "no_writes_outside_repo_root": true
    }
  }
}
