{
  "schema_version": "agentic-workspace/conformance/v1",
  "id": "planning.new-plan.lifecycle.dry-run.process",
  "operation_id": "planning.new-plan.lifecycle",
  "adapter": {
    "kind": "process",
    "command_template": [
      "{agentic_planning_cli}",
      "new-plan",
      "--id",
      "tmp-plan",
      "--title",
      "Tmp Plan",
      "--target",
      ".",
      "--dry-run",
      "--format",
      "json"
    ],
    "cwd": "fixture_root"
  },
  "fixtures": [
    {
      "id": "new-plan-dry-run",
      "files": {
        ".git/.keep": ""
      }
    }
  ],
  "expectations": {
    "exit": {
      "code": 0
    },
    "stdout": {
      "format": "json",
      "field_assertions": [
        {
          "path": [
            "dry_run"
          ],
          "equals": true
        },
        {
          "path": [
            "outcome"
          ],
          "equals": "noop"
        },
        {
          "path": [
            "mutation_applied"
          ],
          "equals": false
        },
        {
          "path": [
            "reason_code"
          ],
          "equals": "dry-run"
        }
      ]
    },
    "stderr": {
      "allow_non_empty": false
    },
    "filesystem": {
      "allowed_write_paths": [],
      "required_paths": [
        ".git/.keep"
      ],
      "forbidden_paths": [
        ".agentic-workspace"
      ]
    },
    "idempotency": {
      "run_twice": true
    },
    "safety": {
      "no_writes_outside_repo_root": true
    }
  }
}
