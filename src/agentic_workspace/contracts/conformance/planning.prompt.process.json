{
  "schema_version": "agentic-workspace/conformance/v1",
  "id": "planning.prompt.process",
  "operation_id": "planning.prompt.render",
  "adapter": {
    "kind": "process",
    "command_template": [
      "{agentic_planning_cli}",
      "prompt",
      "install",
      "--target",
      "."
    ],
    "cwd": "fixture_root"
  },
  "fixtures": [
    {
      "id": "empty-fixture",
      "files": {
        ".git/.keep": ""
      }
    }
  ],
  "expectations": {
    "exit": {
      "code": 0
    },
    "stdout": {
      "format": "text",
      "field_assertions": []
    },
    "stderr": {
      "allow_non_empty": false
    },
    "filesystem": {
      "allowed_write_paths": [],
      "required_paths": [
        ".git/.keep"
      ],
      "forbidden_paths": [
        ".agentic-workspace"
      ]
    },
    "idempotency": {
      "run_twice": true
    },
    "safety": {
      "no_writes_outside_repo_root": true
    }
  }
}
