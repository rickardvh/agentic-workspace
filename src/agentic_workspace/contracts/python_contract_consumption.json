{
  "schema_version": "agentic-workspace/python-contract-consumption/v1",
  "loader_boundary": {
    "module": "agentic_workspace.contract_tooling",
    "generic_loader": "load_contract_json(relative_path)",
    "validated_loader": "load_validated_contract_json(relative_path, schema_relative_path)",
    "error_type": "ContractValidationError"
  },
  "dynamic_validated_loader_boundary": [
    {
      "loader": "conformance_contract_manifest",
      "schema": "conformance.schema.json",
      "reason": "The contract path is selected from conformance_contracts.json at runtime, so only the schema side is static."
    }
  ],
  "validated_at_consumption": [
    {
      "contract": "proof_routes.json",
      "schema": "proof_routes_manifest.schema.json",
      "loader": "proof_routes_manifest",
      "consumer": "scripts/check/check_contract_tooling_surfaces.py"
    },
    {
      "contract": "proof_selection_rules.json",
      "schema": "proof_selection_rules.schema.json",
      "loader": "proof_selection_rules_manifest",
      "consumer": "agentic_workspace.cli:_proof_selection_for_changed_paths"
