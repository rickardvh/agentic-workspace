{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/startup-context.schema.json",
  "title": "Startup Context Payload",
  "type": "object",
  "required": [
    "kind",
    "target",
    "invoked_cli_identity",
    "startup_sequence",
    "context_router",
    "feature_tier",
    "active_state_summary",
    "package_boundary",
    "authority_markers",
    "immediate_next_allowed_action",
    "workflow_obligations",
    "closeout_obligations"
  ],
  "properties": {
    "kind": {
      "const": "startup-context/v1"
    },
    "target": {
      "type": "string"
    },
    "invoked_cli_identity": {
      "$ref": "#/$defs/invoked_cli_identity"
    },
    "cli_compatibility": {
      "type": "object"
    },
    "startup_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "surface",
          "why"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": [
              "string",
              "null"
            ]
          },
          "surface": {
            "type": "string"
          },
          "why": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "feature_tier": {
      "type": "object"
    },
    "context_router": {
      "type": "object"
    },
    "active_state_summary": {
      "type": "object",
      "required": [
        "todo_active_count",
        "active_execplan",
        "planning_status"
      ],
      "properties": {
        "todo_active_count": {
          "type": "integer"
        },
        "active_execplan": {
          "type": [
            "string",
            "null"
          ]
        },
        "planning_status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "package_boundary": {
      "$ref": "#/$defs/package_boundary"
    },
    "authority_markers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/authority_marker"
      }
    },
    "immediate_next_allowed_action": {
      "type": "object",
      "required": [
        "action",
        "summary",
        "command",
        "run",
        "risk",
        "required_inputs",
        "next_proof",
        "read_first",
        "open_execplan_only_when"
      ],
      "properties": {
        "action": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "run": {
          "type": [
            "string",
            "null"
          ]
        },
        "risk": {
          "type": "string"
        },
        "required_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_proof": {
          "type": "string"
        },
        "read_first": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_execplan_only_when": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "workflow_obligations": {
      "type": "object"
    },
    "closeout_obligations": {
      "type": "object"
    },
    "skill_routing": {
      "$ref": "#/$defs/skill_routing"
    },
    "proof": {
      "type": "object"
    },
    "path_boundaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path_boundary"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "invoked_cli_identity": {
      "type": "object",
      "required": [
        "kind",
        "package",
        "version",
        "source_class",
        "module_path",
        "target_relation",
        "compatibility"
      ],
      "properties": {
        "kind": {
          "const": "agentic-workspace/invoked-cli-identity/v1"
        },
        "package": {
          "const": "agentic-workspace"
        },
        "version": {
          "type": "string"
        },
        "source_class": {
          "enum": [
            "source-checkout",
            "installed-package",
            "unknown"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "module_path": {
          "type": "string"
        },
        "package_root": {
          "type": [
            "string",
            "null"
          ]
        },
        "python_executable": {
          "type": "string"
        },
        "argv0": {
          "type": "string"
        },
        "argv0_path": {
          "type": "string"
        },
        "path_executable": {
          "type": "string"
        },
        "target_relation": {
          "enum": [
            "inside-target",
            "outside-target",
            "no-target"
          ]
        },
        "compatibility": {
          "const": "not-evaluated"
        },
        "expectation_source": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "authority_marker": {
      "type": "object",
      "required": [
        "path",
        "authority",
        "canonical_source",
        "safe_to_edit",
        "refresh_command"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "authority": {
          "type": "string"
        },
        "canonical_source": {
          "type": "string"
        },
        "safe_to_edit": {
          "type": "boolean"
        },
        "refresh_command": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "package_boundary": {
      "type": "object",
      "required": [
        "status",
        "cwd",
        "warning"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "warning": {
          "type": [
            "string",
            "null"
          ]
        },
        "package_root": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "path_boundary": {
      "type": "object",
      "required": [
        "path",
        "authority",
        "warning",
        "requires_attention"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "authority": {
          "type": "string"
        },
        "warning": {
          "type": [
            "string",
            "null"
          ]
        },
        "requires_attention": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "skill_routing": {
      "type": "object",
      "required": [
        "status",
        "rule",
        "query",
        "preferred_routes"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "rule": {
          "type": "string"
        },
        "query": {
          "type": "string"
        },
        "advanced_route_rule": {
          "type": "string"
        },
        "available_advanced_route_command": {
          "type": "string"
        },
        "enabled_advanced_routes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_when_skills_unavailable": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_when_skills_unavailable_count": {
          "type": "integer",
          "minimum": 0
        },
        "fallback_detail": {
          "type": "string"
        },
        "preferred_routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "task_shape",
              "skill"
            ],
            "properties": {
              "task_shape": {
                "type": "string"
              },
              "skill": {
                "type": "string"
              },
              "fallback": {
                "type": "string"
              },
              "feature": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
