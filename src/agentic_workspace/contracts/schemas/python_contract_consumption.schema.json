{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/python-contract-consumption.schema.json",
  "title": "Python Contract Consumption Policy",
  "type": "object",
  "required": [
    "schema_version",
    "loader_boundary",
    "dynamic_validated_loader_boundary",
    "validated_at_consumption",
    "model_derivation_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/python-contract-consumption/v1"
    },
    "loader_boundary": {
      "type": "object",
      "required": [
        "module",
        "generic_loader",
        "validated_loader",
        "error_type"
      ],
      "properties": {
        "module": {
          "type": "string"
        },
        "generic_loader": {
          "type": "string"
        },
        "validated_loader": {
          "type": "string"
        },
        "error_type": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "validated_at_consumption": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "contract",
          "schema",
          "loader",
          "consumer"
        ],
        "properties": {
          "contract": {
            "type": "string"
          },
          "schema": {
            "type": "string"
          },
          "loader": {
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "consumer": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "dynamic_validated_loader_boundary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "loader",
          "schema",
          "reason"
        ],
        "properties": {
          "loader": {
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "schema": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "model_derivation_policy": {
      "type": "object",
      "required": [
        "authority_rule",
        "first_schema_derived_target",
        "handwritten_model_boundary"
      ],
      "properties": {
        "authority_rule": {
          "type": "string"
        },
        "first_schema_derived_target": {
          "type": "string"
        },
        "handwritten_model_boundary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
