{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/view-spec.schema.json",
  "type": "object",
  "required": [
    "kind",
    "id",
    "operation_id",
    "output_profile",
    "primitive_refs",
    "fields"
  ],
  "properties": {
    "kind": {
      "const": "agentic-workspace/view-spec/v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "output_profile": {
      "type": "string",
      "minLength": 1
    },
    "primitive_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "source"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
