{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/authority-markers.schema.json",
  "title": "Authority Marker Policy",
  "description": "Schema for Authority Marker Policy.",
  "type": "object",
  "required": [
    "schema_version",
    "markers"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/authority-markers/v1",
      "description": "The schema version constant field in Authority Marker Policy."
    },
    "markers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "authority",
          "canonical_source",
          "safe_to_edit",
          "refresh_command",
          "representative_paths"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The id string field in Authority Marker Policy."
          },
          "authority": {
            "enum": [
              "adapter",
              "generated-adapter",
              "canonical",
              "payload",
              "source",
              "managed",
              "repo-owned"
            ],
            "description": "The authority enumerated value field in Authority Marker Policy."
          },
          "canonical_source": {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "enum": [
                  "fixed",
                  "path",
                  "package-root-source"
                ],
                "description": "The kind enumerated value field in Authority Marker Policy."
              },
              "value": {
                "type": "string",
                "description": "The value string field in Authority Marker Policy."
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "kind": {
                      "const": "fixed"
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "required": [
                    "value"
                  ]
                }
              },
              {
                "if": {
                  "properties": {
                    "kind": {
                      "enum": [
                        "path",
                        "package-root-source"
                      ]
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "not": {
                    "required": [
                      "value"
                    ]
                  }
                }
              }
            ],
            "additionalProperties": false,
            "description": "The canonical source object field in Authority Marker Policy."
          },
          "safe_to_edit": {
            "type": "boolean",
            "description": "The safe to edit boolean field in Authority Marker Policy."
          },
          "refresh_command": {
            "type": [
              "string",
              "null"
            ],
            "description": "The refresh command string or null field in Authority Marker Policy."
          },
          "representative_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "description": "Item string accepted by representative paths in Authority Marker Policy."
            },
            "description": "The representative paths array field in Authority Marker Policy."
          }
        },
        "additionalProperties": false,
        "description": "Item object accepted by markers in Authority Marker Policy."
      },
      "description": "The markers array field in Authority Marker Policy."
    }
  },
  "additionalProperties": false,
  "x-agentic-workspace-doc-role": "contract-reference"
}
