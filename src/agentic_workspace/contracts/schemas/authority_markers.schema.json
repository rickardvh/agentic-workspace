{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/authority-markers.schema.json",
  "title": "Authority Marker Policy",
  "description": "Authority marker policy for identifying generated, adapter, repo-owned, and safe-to-edit surfaces.",
  "type": "object",
  "required": [
    "schema_version",
    "markers"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/authority-markers/v1",
      "description": "Contract version for this document."
    },
    "markers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "authority",
          "canonical_source",
          "safe_to_edit",
          "refresh_command",
          "representative_paths"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier used to reference this record."
          },
          "authority": {
            "enum": [
              "adapter",
              "generated-adapter",
              "canonical",
              "payload",
              "source",
              "managed",
              "repo-owned"
            ],
            "description": "Authority level or owner for this surface."
          },
          "canonical_source": {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "enum": [
                  "fixed",
                  "path",
                  "package-root-source"
                ],
                "description": "Discriminator identifying the payload or record shape."
              },
              "value": {
                "type": "string",
                "description": "Value text value used by this contract."
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "kind": {
                      "const": "fixed"
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "required": [
                    "value"
                  ]
                }
              },
              {
                "if": {
                  "properties": {
                    "kind": {
                      "enum": [
                        "path",
                        "package-root-source"
                      ]
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                "then": {
                  "not": {
                    "required": [
                      "value"
                    ]
                  }
                }
              }
            ],
            "additionalProperties": false,
            "description": "Source of truth for this generated, derived, or adapter surface."
          },
          "safe_to_edit": {
            "type": "boolean",
            "description": "Whether agents may edit this surface under the declared authority rules."
          },
          "refresh_command": {
            "type": [
              "string",
              "null"
            ],
            "description": "Command used to refresh this generated or managed surface."
          },
          "representative_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "description": "One entry in the representative paths list."
            },
            "description": "Ordered representative paths entries used by this contract."
          }
        },
        "additionalProperties": false,
        "description": "One entry in the markers list."
      },
      "description": "Ordered markers entries used by this contract."
    }
  },
  "additionalProperties": false,
  "x-agentic-workspace-doc-role": "contract-reference"
}
