{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/improvement-signal-contract.schema.json",
  "title": "Agentic Workspace Improvement Signal Contract",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "role",
    "rule",
    "candidate_kind",
    "required_fields",
    "kinds",
    "likely_remediations",
    "validation_failure_classes",
    "validation_remedy_order",
    "confidence",
    "recurrence",
    "immediate_actions",
    "retention",
    "destinations",
    "closeout_statuses",
    "guardrails"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/improvement-signal-contract/v1"
    },
    "kind": {
      "const": "workspace-improvement-signal-contract/v1"
    },
    "role": {
      "const": "candidate-shape-not-backlog"
    },
    "rule": {
      "type": "string",
      "minLength": 1
    },
    "candidate_kind": {
      "const": "workspace-improvement-signal-candidate/v1"
    },
    "required_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "kinds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "likely_remediations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_failure_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "class",
          "signal_rule",
          "route",
          "preferred_remediations"
        ],
        "properties": {
          "class": {
            "enum": [
              "user_or_content_error",
              "environment_or_dependency_error",
              "interface_design_error",
              "unclear_proof_contract"
            ]
          },
          "signal_rule": {
            "type": "string",
            "minLength": 1
          },
          "route": {
            "type": "string",
            "minLength": 1
          },
          "preferred_remediations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "validation_remedy_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "low",
          "medium",
          "high"
        ]
      }
    },
    "recurrence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "first_seen",
          "repeated",
          "human_confirmed"
        ]
      }
    },
    "immediate_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "fix_now",
          "route",
          "review",
          "remember",
          "dismiss"
        ]
      }
    },
    "retention": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "shrink_after_fix",
          "delete_after_fix",
          "keep_with_justification"
        ]
      }
    },
    "destinations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "closeout_statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "found",
          "fixed",
          "routed",
          "dismissed",
          "none"
        ]
      }
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
