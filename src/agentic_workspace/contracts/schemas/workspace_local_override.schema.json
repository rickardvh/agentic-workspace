{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/workspace-local-override.schema.json",
  "title": "Agentic Workspace Local Mixed-Agent Override",
  "type": "object",
  "required": [
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "runtime": {
      "type": "object",
      "properties": {
        "supports_internal_delegation": {
          "type": "boolean"
        },
        "strong_planner_available": {
          "type": "boolean"
        },
        "cheap_bounded_executor_available": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "properties": {
        "prefer_internal_delegation_when_available": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "properties": {
        "safe_to_auto_run_commands": {
          "type": "boolean"
        },
        "requires_human_verification_on_pr": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "delegation_targets": {
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "type": "object",
          "required": [
            "strength",
            "execution_methods"
          ],
          "properties": {
            "strength": {
              "type": "string",
              "enum": [
                "strong",
                "medium",
                "weak"
              ]
            },
            "location": {
              "type": "string",
              "enum": [
                "local",
                "external",
                "either"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "task_fit": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "capability_classes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "boundary-shaping",
                  "reasoning-heavy",
                  "mixed",
                  "mechanical-follow-through"
                ]
              }
            },
            "execution_methods": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "internal",
                  "cli",
                  "api"
                ]
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
