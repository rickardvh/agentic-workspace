{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/cli-option-groups.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "option_groups"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/cli-option-groups/v1"
    },
    "option_groups": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "uses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/option"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "option": {
      "type": "object",
      "required": [
        "name",
        "flags"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "flags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "action": {
          "type": "string"
        },
        "choices": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "integer",
              "number",
              "boolean"
            ]
          }
        },
        "choices_ref": {
          "type": "string"
        },
        "default": {},
        "default_ref": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "help": {
          "type": "string"
        },
        "help_template": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
