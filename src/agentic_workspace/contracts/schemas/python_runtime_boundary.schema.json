{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/python-runtime-boundary.schema.json",
  "title": "Python Runtime Boundary",
  "type": "object",
  "required": [
    "schema_version",
    "parent_issue",
    "purpose",
    "classification_values",
    "boundaries",
    "root_cli_authority_audit"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/python-runtime-boundary/v1"
    },
    "parent_issue": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "classification_values": {
      "type": "array",
      "items": {
        "enum": [
          "procedural-owned",
          "live-inspection-owned",
          "operation-contract-covered",
          "deferred-extractable"
        ]
      },
      "minItems": 4,
      "uniqueItems": true
    },
    "boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "classification",
          "owner_modules",
          "runtime_surfaces",
          "why_python_owned",
          "contract_surfaces",
          "remaining_extractable_content"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "classification": {
            "enum": [
              "procedural-owned",
              "live-inspection-owned",
              "operation-contract-covered",
              "deferred-extractable"
            ]
          },
          "owner_modules": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "runtime_surfaces": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "why_python_owned": {
            "type": "string"
          },
          "contract_surfaces": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "remaining_extractable_content": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "summary",
                "tracking_issue",
                "status"
              ],
              "properties": {
                "summary": {
                  "type": "string"
                },
                "tracking_issue": {
                  "type": "string",
                  "pattern": "^#[0-9]+$"
                },
                "status": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "root_cli_authority_audit": {
      "type": "object",
      "required": [
        "command",
        "rule",
        "responsibility_classes",
        "current_audit",
        "next_extraction_or_guard_candidates",
        "direct_cli_edit_routing"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "rule": {
          "type": "string"
        },
        "responsibility_classes": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": [
              "id",
              "authority_class",
              "allowed_owner",
              "route_when",
              "extract_or_guard_when"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "authority_class": {
                "enum": [
                  "allowed-root-runtime",
                  "derived-renderer",
                  "generated-dispatch-bridge",
                  "remaining-interface-authority"
                ]
              },
              "allowed_owner": {
                "type": "string"
              },
              "route_when": {
                "type": "string"
              },
              "extract_or_guard_when": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "current_audit": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "responsibility_class",
              "status",
              "evidence",
              "next_review"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "responsibility_class": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "status": {
                "enum": [
                  "legitimate-runtime-ownership",
                  "guarded-interface-authority",
                  "extract-or-guard-candidate"
                ]
              },
              "evidence": {
                "type": "string"
              },
              "next_review": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "next_extraction_or_guard_candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "candidate_type",
              "owner_surface",
              "why",
              "tracking_issue"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "candidate_type": {
                "enum": [
                  "extract-interface-authority",
                  "add-guard-check",
                  "expand-generated-adapter"
                ]
              },
              "owner_surface": {
                "type": "string"
              },
              "why": {
                "type": "string"
              },
              "tracking_issue": {
                "type": "string",
                "pattern": "^#[0-9]+$"
              }
            },
            "additionalProperties": false
          }
        },
        "direct_cli_edit_routing": {
          "type": "object",
          "required": [
            "allowed_when",
            "route_to_contract_when",
            "review_requires"
          ],
          "properties": {
            "allowed_when": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "route_to_contract_when": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "review_requires": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
