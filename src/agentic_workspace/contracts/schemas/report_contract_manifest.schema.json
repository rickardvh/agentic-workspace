{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/report-contract-manifest.schema.json",
  "title": "Report Contract Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "canonical_doc",
    "command",
    "shared_fields",
    "report_principles"
  ],
  "properties": {
    "schema_version": {
      "const": "workspace-reporting-schema/v1"
    },
    "canonical_doc": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "shared_fields": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "report_principles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
