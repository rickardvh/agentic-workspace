{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/module-registry.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "package_footprint",
    "component_model",
    "module_profiles",
    "feature_tiers",
    "advanced_features",
    "module_command_args",
    "modules"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/module-registry/v1"
    },
    "module_command_args": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      }
    },
    "package_footprint": {
      "type": "object",
      "required": [
        "decision",
        "status",
        "python_package_dependency_model",
        "repo_footprint_rule",
        "why",
        "bounded_by",
        "future_options",
        "must_preserve"
      ],
      "properties": {
        "decision": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "python_package_dependency_model": {
          "type": "string"
        },
        "repo_footprint_rule": {
          "type": "string"
        },
        "why": {
          "type": "string"
        },
        "bounded_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "future_options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "must_preserve": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "component_model": {
      "type": "object",
      "required": [
        "schema_version",
        "alignment",
        "runtime_dependency",
        "source_of_truth",
        "rule",
        "component_classes",
        "adapter_boundary"
      ],
      "properties": {
        "schema_version": {
          "const": "agentic-workspace/module-components/v1"
        },
        "alignment": {
          "type": "string"
        },
        "runtime_dependency": {
          "const": "none"
        },
        "source_of_truth": {
          "type": "string"
        },
        "rule": {
          "type": "string"
        },
        "component_classes": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": [
              "id",
              "maps_to",
              "semantics",
              "required_fields"
            ],
            "properties": {
              "id": {
                "enum": [
                  "resource",
                  "tool",
                  "prompt",
                  "schema",
                  "root"
                ]
              },
              "maps_to": {
                "type": "string"
              },
              "semantics": {
                "type": "string"
              },
              "required_fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "adapter_boundary": {
          "type": "object",
          "required": [
            "future_adapter",
            "adapter_consumes",
            "adapter_must_not",
            "blocking_prerequisites"
          ],
          "properties": {
            "future_adapter": {
              "type": "string"
            },
            "adapter_consumes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "adapter_must_not": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "blocking_prerequisites": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "module_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "profile_kind",
          "selected_modules",
          "preset",
          "default_active",
          "activation",
          "cost_model",
          "selection_rule"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "profile_kind": {
            "enum": [
              "root-routing",
              "installer-preset",
              "module-selection"
            ]
          },
          "selected_modules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preset": {
            "type": [
              "string",
              "null"
            ]
          },
          "default_active": {
            "type": "boolean"
          },
          "activation": {
            "type": "string"
          },
          "cost_model": {
            "type": "string"
          },
          "selection_rule": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "feature_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "modules",
          "preset",
          "default_active",
          "activation",
          "cost_model"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "modules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preset": {
            "type": [
              "string",
              "null"
            ]
          },
          "default_active": {
            "type": "boolean"
          },
          "activation": {
            "type": "string"
          },
          "cost_model": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "advanced_features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "tier",
          "default_enabled",
          "activation",
          "default_surface_policy",
          "selector_hint"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          },
          "default_enabled": {
            "type": "boolean"
          },
          "activation": {
            "type": "string"
          },
          "default_surface_policy": {
            "type": "string"
          },
          "selector_hint": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "description",
          "selection_rank",
          "include_in_full_preset",
          "install_signals",
          "workflow_surfaces",
          "generated_artifacts",
          "startup_steps",
          "sources_of_truth",
          "root_agents_cleanup_blocks",
          "capabilities",
          "dependencies",
          "conflicts",
          "components",
          "result_contract"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "selection_rank": {
            "type": "integer"
          },
          "include_in_full_preset": {
            "type": "boolean"
          },
          "install_signals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "workflow_surfaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "generated_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "startup_steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sources_of_truth": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "root_agents_cleanup_blocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "block",
                "start_marker",
                "end_marker",
                "label"
              ],
              "properties": {
                "block": {
                  "type": "string"
                },
                "start_marker": {
                  "type": "string"
                },
                "end_marker": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "conflicts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "components": {
            "$ref": "#/$defs/module_components"
          },
          "result_contract": {
            "type": "object",
            "required": [
              "schema_version",
              "guaranteed_fields",
              "action_fields",
              "warning_fields"
            ],
            "properties": {
              "schema_version": {
                "type": "string"
              },
              "guaranteed_fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "action_fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "warning_fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "module_components": {
      "type": "object",
      "required": [
        "resources",
        "tools",
        "prompts",
        "schemas",
        "roots"
      ],
      "properties": {
        "resources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource_component"
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tool_component"
          }
        },
        "prompts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prompt_component"
          }
        },
        "schemas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/schema_component"
          }
        },
        "roots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/root_component"
          }
        }
      },
      "additionalProperties": false
    },
    "resource_component": {
      "type": "object",
      "required": [
        "uri",
        "description",
        "read_only",
        "source",
        "command",
        "result_schema"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9+.-]*://"
        },
        "description": {
          "type": "string"
        },
        "read_only": {
          "const": true
        },
        "source": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "result_schema": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "tool_component": {
      "type": "object",
      "required": [
        "name",
        "description",
        "command",
        "read_only",
        "destructive",
        "idempotent",
        "requires_dry_run",
        "input_schema",
        "result_schema",
        "safety"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
        },
        "description": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "read_only": {
          "type": "boolean"
        },
        "destructive": {
          "type": "boolean"
        },
        "idempotent": {
          "type": "boolean"
        },
        "requires_dry_run": {
          "type": "boolean"
        },
        "input_schema": {
          "type": "string"
        },
        "result_schema": {
          "type": "string"
        },
        "safety": {
          "type": "object",
          "required": [
            "requires_approval_when",
            "owned_paths",
            "dry_run_command"
          ],
          "properties": {
            "requires_approval_when": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "owned_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "dry_run_command": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "prompt_component": {
      "type": "object",
      "required": [
        "name",
        "description",
        "template",
        "prompt_kind"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
        },
        "description": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "prompt_kind": {
          "enum": [
            "skill",
            "handoff",
            "template"
          ]
        }
      },
      "additionalProperties": false
    },
    "schema_component": {
      "type": "object",
      "required": [
        "id",
        "path",
        "schema_kind"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "schema_kind": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "root_component": {
      "type": "object",
      "required": [
        "id",
        "path",
        "ownership"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "ownership": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
