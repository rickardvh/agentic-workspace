{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/module-registry.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "module_command_args",
    "modules"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/module-registry/v1"
    },
    "module_command_args": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "description",
          "selection_rank",
          "include_in_full_preset",
          "install_signals",
          "workflow_surfaces",
          "generated_artifacts",
          "startup_steps",
          "sources_of_truth",
          "root_agents_cleanup_blocks",
          "capabilities",
          "dependencies",
          "conflicts",
          "result_contract"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "selection_rank": {
            "type": "integer"
          },
          "include_in_full_preset": {
            "type": "boolean"
          },
          "install_signals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "workflow_surfaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "generated_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "startup_steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sources_of_truth": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "root_agents_cleanup_blocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "block",
                "start_marker",
                "end_marker",
                "label"
              ],
              "properties": {
                "block": {
                  "type": "string"
                },
                "start_marker": {
                  "type": "string"
                },
                "end_marker": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "conflicts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "result_contract": {
            "type": "object",
            "required": [
              "schema_version",
              "guaranteed_fields",
              "action_fields",
              "warning_fields"
            ],
            "properties": {
              "schema_version": {
                "type": "string"
              },
              "guaranteed_fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "action_fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "warning_fields": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
