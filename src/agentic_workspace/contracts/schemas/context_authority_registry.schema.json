{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/context-authority-registry.schema.json",
  "title": "Agentic Workspace Context Authority Registry",
  "description": "Versioned source of truth for ordinary operating-decision authority surfaces and consumer requirements.",
  "type": "object",
  "required": ["kind", "schema_version", "rule", "ordinary_decision_consumers", "consumer_requirements", "surfaces"],
  "properties": {
    "kind": {
      "const": "agentic-workspace/context-authority-registry/v1",
      "description": "Schema discriminator for the operating-decision authority registry."
    },
    "schema_version": {"type": "integer", "minimum": 1, "description": "Monotonic registry schema version."},
    "rule": {"type": "string", "minLength": 1, "description": "Contract rule explaining how runtime must consume the registry."},
    "ordinary_decision_consumers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true,
      "description": "Ordinary AW consumers that must have measured authority coverage."
    },
    "consumer_requirements": {
      "type": "object",
      "description": "Required authority surfaces for each ordinary decision consumer.",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string", "minLength": 1},
        "uniqueItems": true,
        "description": "Authority surfaces required by this consumer."
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "description": "Declared authority surfaces available to ordinary operating decisions.",
      "items": {
        "type": "object",
        "required": [
          "surface",
          "owner",
          "authority_class",
          "consumers",
          "activation",
          "editable_by",
          "stale_when",
          "proof_route",
          "disposition",
          "revision_fields"
        ],
        "properties": {
          "surface": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "authority_class": {
            "type": "string",
            "enum": ["canonical", "derived", "advisory", "historical/evidence", "local-only", "temporary", "generated", "hard-gate"]
          },
          "consumers": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
          "activation": {"type": "string", "minLength": 1},
          "editable_by": {"type": "string", "minLength": 1},
          "stale_when": {"type": "string", "minLength": 1},
          "proof_route": {"type": "string", "minLength": 1},
          "disposition": {"type": "string", "minLength": 1},
          "revision_fields": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "x-agentic-workspace-doc-role": "contract-reference"
}
