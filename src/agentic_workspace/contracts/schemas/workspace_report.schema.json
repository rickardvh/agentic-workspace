{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/workspace-report.schema.json",
  "title": "Workspace Report",
  "type": "object",
  "required": [
    "kind",
    "schema",
    "command",
    "target",
    "invoked_cli_identity",
    "selected_modules",
    "installed_modules",
    "feature_tier",
    "health",
    "report_profile",
    "output_contract",
    "config_enforcement",
    "branch_workflow_posture",
    "local_memory",
    "agent_aids",
    "agent_configuration_system",
    "agent_configuration_queries",
    "workflow_obligations",
    "product_managed_enclave",
    "surface_value_guardrail",
    "effective_authority",
    "maintenance_pressure",
    "operational_compression",
    "closeout_trust",
    "external_work_reconciliation",
    "external_work_delta",
    "findings",
    "next_action",
    "discovery",
    "standing_intent",
    "improvement_intake",
    "repo_friction",
    "registry",
    "config",
    "reports",
    "module_reports"
  ],
  "properties": {
    "kind": {
      "const": "workspace-report/v1"
    },
    "schema": {
      "type": "object",
      "required": [
        "schema_version",
        "canonical_doc",
        "command",
        "shared_fields",
        "report_principles"
      ],
      "properties": {
        "schema_version": {
          "const": "workspace-reporting-schema/v1"
        },
        "canonical_doc": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "shared_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "report_principles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "command": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "invoked_cli_identity": {
      "$ref": "#/$defs/invoked_cli_identity"
    },
    "selected_modules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "installed_modules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "feature_tier": {
      "type": "object"
    },
    "health": {
      "type": "string"
    },
    "report_profile": {
      "type": "object"
    },
    "output_contract": {
      "type": "object"
    },
    "config_enforcement": {
      "type": "object"
    },
    "branch_workflow_posture": {
      "type": "object"
    },
    "local_memory": {
      "type": "object"
    },
    "agent_aids": {
      "type": "object"
    },
    "agent_configuration_system": {
      "type": "object"
    },
    "agent_configuration_queries": {
      "type": "object"
    },
    "system_intent_mirror": {
      "type": "object"
    },
    "workflow_obligations": {
      "type": "object"
    },
    "product_managed_enclave": {
      "type": "object"
    },
    "surface_value_guardrail": {
      "type": "object"
    },
    "effective_authority": {
      "type": "object"
    },
    "operational_compression": {
      "type": "object"
    },
    "maintenance_pressure": {
      "type": "object"
    },
    "closeout_trust": {
      "type": "object"
    },
    "external_work_reconciliation": {
      "type": "object"
    },
    "external_work_delta": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "next_action": {
      "type": "object"
    },
    "discovery": {
      "type": "object"
    },
    "standing_intent": {
      "type": "object"
    },
    "improvement_intake": {
      "type": "object"
    },
    "repo_friction": {
      "type": "object"
    },
    "registry": {
      "type": "array"
    },
    "config": {
      "type": "object"
    },
    "reports": {
      "type": "array"
    },
    "module_reports": {
      "type": "array"
    },
    "execution_shape": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "invoked_cli_identity": {
      "type": "object",
      "required": [
        "kind",
        "package",
        "version",
        "source_class",
        "module_path",
        "target_relation",
        "compatibility"
      ],
      "properties": {
        "kind": {
          "const": "agentic-workspace/invoked-cli-identity/v1"
        },
        "package": {
          "const": "agentic-workspace"
        },
        "version": {
          "type": "string"
        },
        "source_class": {
          "enum": [
            "source-checkout",
            "installed-package",
            "unknown"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "module_path": {
          "type": "string"
        },
        "package_root": {
          "type": [
            "string",
            "null"
          ]
        },
        "python_executable": {
          "type": "string"
        },
        "argv0": {
          "type": "string"
        },
        "argv0_path": {
          "type": "string"
        },
        "path_executable": {
          "type": "string"
        },
        "target_relation": {
          "enum": [
            "inside-target",
            "outside-target",
            "no-target"
          ]
        },
        "compatibility": {
          "const": "not-evaluated"
        },
        "expectation_source": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
