{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/context-templates.schema.json",
  "title": "Context Templates",
  "type": "object",
  "required": [
    "schema_version",
    "startup_context",
    "implementer_context"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/context-templates/v1"
    },
    "startup_context": {
      "type": "object",
      "required": [
        "startup_sequence",
        "fallback_next_action",
        "open_execplan_only_when"
      ],
      "properties": {
        "startup_sequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "command",
              "surface",
              "why"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "command": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "surface": {
                "type": "string"
              },
              "why": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "fallback_next_action": {
          "type": "string"
        },
        "open_execplan_only_when": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "implementer_context": {
      "type": "object",
      "required": [
        "unknown_scope_proof",
        "default_inspect_files",
        "files_to_avoid",
        "handoff_requirements",
        "next_allowed_action"
      ],
      "properties": {
        "unknown_scope_proof": {
          "type": "object",
          "required": [
            "kind",
            "changed_paths",
            "selected_lanes",
            "required_commands",
            "optional_commands",
            "broaden_when",
            "escalate_when"
          ],
          "properties": {
            "kind": {
              "const": "proof-selection/v1"
            },
            "changed_paths": {
              "type": "array",
              "maxItems": 0
            },
            "selected_lanes": {
              "type": "array",
              "maxItems": 0
            },
            "required_commands": {
              "type": "array",
              "maxItems": 0
            },
            "optional_commands": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "broaden_when": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "escalate_when": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          },
          "additionalProperties": false
        },
        "default_inspect_files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "files_to_avoid": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "handoff_requirements": {
          "type": "object",
          "required": [
            "before_handoff",
            "stop_when"
          ],
          "properties": {
            "before_handoff": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "stop_when": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          },
          "additionalProperties": false
        },
        "next_allowed_action": {
          "type": "object",
          "required": [
            "attention",
            "default"
          ],
          "properties": {
            "attention": {
              "type": "string"
            },
            "default": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
