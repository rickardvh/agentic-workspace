{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/prose-surface-inventory.schema.json",
  "title": "Prose Surface Inventory",
  "type": "object",
  "required": [
    "kind",
    "schema_version",
    "rule",
    "classifications",
    "target_statuses",
    "entries",
    "top_follow_up_candidates"
  ],
  "properties": {
    "kind": {
      "const": "agentic-workspace/prose-surface-inventory/v1"
    },
    "schema_version": {
      "const": "prose-surface-inventory/v1"
    },
    "rule": {
      "type": "string",
      "minLength": 1
    },
    "classifications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "essential-explanatory-prose",
          "constrained-template-prose",
          "generated-prose-adapter",
          "structured-field-replacement-candidate",
          "archive-evidence-only",
          "remove-or-shrink"
        ]
      },
      "uniqueItems": true
    },
    "target_statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "keep",
          "constrain",
          "generate",
          "structure",
          "shrink",
          "remove",
          "archive-only"
        ]
      },
      "uniqueItems": true
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "surface",
          "owner",
          "purpose",
          "ordinary_startup",
          "classification",
          "target_status",
          "recurring_patterns",
          "structured_owner",
          "prose_role",
          "follow_up_issues",
          "validation_refs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "surface": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "ordinary_startup": {
            "type": "boolean"
          },
          "classification": {
            "type": "string",
            "enum": [
              "essential-explanatory-prose",
              "constrained-template-prose",
              "generated-prose-adapter",
              "structured-field-replacement-candidate",
              "archive-evidence-only",
              "remove-or-shrink"
            ]
          },
          "target_status": {
            "type": "string",
            "enum": [
              "keep",
              "constrain",
              "generate",
              "structure",
              "shrink",
              "remove",
              "archive-only"
            ]
          },
          "recurring_patterns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "structured_owner": {
            "type": "string",
            "minLength": 1
          },
          "prose_role": {
            "type": "string",
            "minLength": 1
          },
          "follow_up_issues": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^#[0-9]+$"
            },
            "uniqueItems": true
          },
          "validation_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "top_follow_up_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "issue",
          "intent",
          "surface_ids",
          "preferred_remedy",
          "why_first"
        ],
        "properties": {
          "issue": {
            "type": "string",
            "pattern": "^#[0-9]+$"
          },
          "intent": {
            "type": "string",
            "minLength": 1
          },
          "surface_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            "uniqueItems": true
          },
          "preferred_remedy": {
            "type": "string",
            "enum": [
              "constrain-template",
              "generate-from-structured-state",
              "add-structured-metadata",
              "shrink-or-remove",
              "keep-as-explanation"
            ]
          },
          "why_first": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
