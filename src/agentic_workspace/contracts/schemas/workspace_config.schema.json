{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/workspace-config.schema.json",
  "title": "Agentic Workspace Repo Config",
  "type": "object",
  "required": [
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "workspace": {
      "type": "object",
      "x-agentic-workspace-unknown-properties": "warn",
      "properties": {
        "default_preset": {
          "enum": [
            "memory",
            "planning",
            "full"
          ]
        },
        "agent_instructions_file": {
          "enum": [
            "AGENTS.md",
            "GEMINI.md"
          ]
        },
        "workflow_artifact_profile": {
          "enum": [
            "repo-owned",
            "gemini"
          ]
        },
        "improvement_latitude": {
          "enum": [
            "none",
            "reporting",
            "conservative",
            "balanced",
            "proactive"
          ]
        },
        "optimization_bias": {
          "enum": [
            "agent-efficiency",
            "balanced",
            "human-legibility"
          ]
        },
        "advanced_features": {
          "type": "array",
          "items": {
            "enum": [
              "review_artifacts",
              "external_adapters"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "update": {
      "type": "object",
      "x-agentic-workspace-unknown-properties": "warn",
      "properties": {
        "modules": {
          "type": "object",
          "properties": {
            "planning": {
              "$ref": "#/$defs/module_update_policy"
            },
            "memory": {
              "$ref": "#/$defs/module_update_policy"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "workflow_obligations": {
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "$ref": "#/$defs/workflow_obligation"
        }
      },
      "additionalProperties": false
    },
    "system_intent": {
      "type": "object",
      "x-agentic-workspace-unknown-properties": "warn",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "preferred_source": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "x-agentic-workspace-unknown-properties": "warn",
  "additionalProperties": true,
  "$defs": {
    "module_update_policy": {
      "type": "object",
      "properties": {
        "source_type": {
          "enum": [
            "git",
            "local"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_label": {
          "type": "string",
          "minLength": 1
        },
        "recommended_upgrade_after_days": {
          "type": "integer"
        }
      },
      "x-agentic-workspace-unknown-properties": "warn",
      "additionalProperties": true
    },
    "workflow_obligation": {
      "type": "object",
      "required": [
        "summary",
        "stage",
        "scope_tags",
        "commands"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "enum": [
            "pre-work",
            "before-claiming-completion",
            "before-commit",
            "review",
            "closeout"
          ]
        },
        "scope_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "review_hint": {
          "type": "string",
          "minLength": 1
        }
      },
      "x-agentic-workspace-unknown-properties": "warn",
      "additionalProperties": true
    }
  }
}
