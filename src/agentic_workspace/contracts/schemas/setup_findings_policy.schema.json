{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/setup-findings-policy.schema.json",
  "title": "Setup Findings Promotion Policy",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_path",
    "accepted_kind",
    "promotion_confidence_threshold",
    "accepted_classes",
    "secondary"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/setup-findings-policy/v1"
    },
    "artifact_path": {
      "type": "string"
    },
    "accepted_kind": {
      "type": "string"
    },
    "promotion_confidence_threshold": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "accepted_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "class",
          "summary",
          "promote_to",
          "preserve_when",
          "transient_when",
          "required_for_promotion"
        ],
        "properties": {
          "class": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "promote_to": {
            "type": "string"
          },
          "preserve_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "transient_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_for_promotion": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "path_or_refs",
                "next_action"
              ]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "secondary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
