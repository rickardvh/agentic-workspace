{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/operational-affordance-roles.schema.json",
  "title": "Operational Affordance Roles",
  "description": "Classifies first-contact commands, advisory warnings, and report sections by next-action value.",
  "type": "object",
  "required": [
    "schema_version",
    "principle",
    "command_roles",
    "warning_roles",
    "report_section_roles",
    "closeout_writer_direction"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/operational-affordance-roles/v1",
      "description": "Contract version for this document."
    },
    "principle": {
      "type": "string",
      "minLength": 1,
      "description": "Operating principle that motivates the role classifications."
    },
    "command_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command_role"
      },
      "description": "Command role classifications for ordinary startup, changed-path startup, recovery, diagnostics, reference detail, and fallback projection."
    },
    "warning_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/warning_role"
      },
      "description": "Advisory warning classifications by root cause and preferred remedy."
    },
    "report_section_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/report_section_role"
      },
      "description": "Report section classifications by next-action value and default visibility."
    },
    "closeout_writer_direction": {
      "type": "object",
      "description": "Current and intended ownership for ordinary Planning closeout writing.",
      "required": [
        "ordinary_path",
        "candidate_command",
        "interim_owner",
        "source_issue"
      ],
      "properties": {
        "ordinary_path": {
          "const": "command_owned_writer",
          "description": "Direction that ordinary closeout should be performed by a command-owned writer."
        },
        "candidate_command": {
          "type": "string",
          "minLength": 1,
          "description": "Candidate future command or affordance that should own ordinary closeout writing."
        },
        "interim_owner": {
          "type": "string",
          "minLength": 1,
          "description": "Existing command or affordance that owns the closest current closeout path."
        },
        "source_issue": {
          "pattern": "^#[0-9]+$",
          "type": "string",
          "description": "Issue that owns the remaining closeout-writer implementation work."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "command_role": {
      "type": "object",
      "required": [
        "command",
        "role",
        "first_line",
        "primary_next_action"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "ordinary_first_contact",
            "changed_path_first_contact",
            "recovery_takeover",
            "active_planning_state",
            "diagnostic_router",
            "reference_detail",
            "task_behavior_routing",
            "no_cli_fallback_projection"
          ]
        },
        "first_line": {
          "type": "boolean"
        },
        "primary_next_action": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "warning_role": {
      "type": "object",
      "required": [
        "warning_class",
        "role",
        "preferred_remedy"
      ],
      "properties": {
        "warning_class": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "diagnostic",
            "external_manual_drift",
            "source_boundary_fix_candidate",
            "missing_helper",
            "ambiguous_output",
            "historical_residue",
            "obsolete_or_merge_candidate"
          ]
        },
        "preferred_remedy": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "report_section_role": {
      "type": "object",
      "required": [
        "section",
        "role",
        "default_visibility"
      ],
      "properties": {
        "section": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "primary_action",
            "blocker",
            "proof",
            "owner",
            "detail",
            "diagnostic",
            "inventory",
            "historical"
          ]
        },
        "default_visibility": {
          "enum": [
            "first_line",
            "selector_or_verbose"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "x-agentic-workspace-doc-role": "contract-reference"
}
