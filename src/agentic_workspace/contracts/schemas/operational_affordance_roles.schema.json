{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/operational-affordance-roles.schema.json",
  "title": "Operational Affordance Roles",
  "description": "Classifies first-contact commands, advisory warnings, and report sections by next-action value.",
  "type": "object",
  "required": [
    "schema_version",
    "principle",
    "command_roles",
    "warning_roles",
    "report_section_roles",
    "provenance_policy",
    "source_boundary_review",
    "closeout_writer_direction"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/operational-affordance-roles/v1",
      "description": "Contract version for this document."
    },
    "principle": {
      "type": "string",
      "minLength": 1,
      "description": "Operating principle that motivates the role classifications."
    },
    "command_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command_role"
      },
      "description": "Command role classifications for ordinary startup, changed-path startup, recovery, diagnostics, reference detail, and fallback projection."
    },
    "warning_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/warning_role"
      },
      "description": "Advisory warning classifications by root cause and preferred remedy."
    },
    "report_section_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/report_section_role"
      },
      "description": "Report section classifications by next-action value and default visibility."
    },
    "provenance_policy": {
      "type": "object",
      "description": "Current product role for Planning mutation provenance.",
      "required": [
        "surface",
        "role",
        "normal_operation_rule",
        "recovery_rule",
        "warning_scope",
        "exit_condition",
        "source_issue"
      ],
      "properties": {
        "surface": {
          "const": ".agentic-workspace/planning/mutation-provenance.json",
          "description": "Planning-managed provenance file whose role is classified by this policy."
        },
        "role": {
          "enum": [
            "normal_operation_evidence",
            "exceptional_recovery_evidence",
            "transitional_recovery_aid",
            "removal_candidate"
          ],
          "description": "Current operational classification for the provenance file."
        },
        "normal_operation_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Rule for how normal command-owned planning mutations should treat provenance evidence."
        },
        "recovery_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Rule for how takeover or recovery workflows should use provenance evidence."
        },
        "warning_scope": {
          "type": "string",
          "minLength": 1,
          "description": "Warning class or diagnostic scope that provenance evidence is allowed to support."
        },
        "exit_condition": {
          "type": "string",
          "minLength": 1,
          "description": "Condition under which the transitional provenance policy can be retired or changed."
        },
        "source_issue": {
          "pattern": "^#[0-9]+$",
          "type": "string",
          "description": "Issue that records the provenance-policy decision."
        }
      },
      "additionalProperties": false
    },
    "source_boundary_review": {
      "type": "object",
      "description": "Post-closeout-writer review result for remaining compensating detectors.",
      "required": [
        "status",
        "review_issue",
        "reviewed_after",
        "demoted_warning_classes",
        "retained_diagnostics",
        "routed_followups",
        "closure_rule"
      ],
      "properties": {
        "status": {
          "enum": [
            "remaining-followups-routed",
            "ready-to-close",
            "blocked"
          ],
          "description": "Current review status for the source-boundary warning lane."
        },
        "review_issue": {
          "pattern": "^#[0-9]+$",
          "type": "string",
          "description": "Issue that owns the source-boundary review."
        },
        "reviewed_after": {
          "type": "array",
          "items": {
            "pattern": "^(#|PR #)[0-9]+$",
            "type": "string"
          },
          "description": "Issues or PRs whose landed work was included in the review."
        },
        "demoted_warning_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Warning classes that are no longer treated as active helper gaps after review."
        },
        "retained_diagnostics": {
          "type": "array",
          "description": "Diagnostics intentionally retained after review, with their trigger and role.",
          "items": {
            "type": "object",
            "required": [
              "warning_class",
              "role",
              "trigger"
            ],
            "properties": {
              "warning_class": {
                "type": "string",
                "minLength": 1
              },
              "role": {
                "type": "string",
                "minLength": 1
              },
              "trigger": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "routed_followups": {
          "type": "array",
          "description": "Follow-up issues opened or identified for unresolved warning classes.",
          "items": {
            "type": "object",
            "required": [
              "issue",
              "warning_class",
              "reason"
            ],
            "properties": {
              "issue": {
                "pattern": "^#[0-9]+$",
                "type": "string"
              },
              "warning_class": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "closure_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Condition that determines when the parent source-boundary lane can close."
        }
      },
      "additionalProperties": false
    },
    "closeout_writer_direction": {
      "type": "object",
      "description": "Current and intended ownership for ordinary Planning closeout writing.",
      "required": [
        "ordinary_path",
        "candidate_command",
        "interim_owner",
        "source_issue"
      ],
      "properties": {
        "ordinary_path": {
          "const": "command_owned_writer",
          "description": "Direction that ordinary closeout should be performed by a command-owned writer."
        },
        "candidate_command": {
          "type": "string",
          "minLength": 1,
          "description": "Candidate future command or affordance that should own ordinary closeout writing."
        },
        "interim_owner": {
          "type": "string",
          "minLength": 1,
          "description": "Existing command or affordance that owns the closest current closeout path."
        },
        "source_issue": {
          "pattern": "^#[0-9]+$",
          "type": "string",
          "description": "Issue that owns the remaining closeout-writer implementation work."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "command_role": {
      "type": "object",
      "required": [
        "command",
        "role",
        "first_line",
        "primary_next_action"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "ordinary_first_contact",
            "changed_path_first_contact",
            "recovery_takeover",
            "active_planning_state",
            "diagnostic_router",
            "reference_detail",
            "task_behavior_routing",
            "no_cli_fallback_projection"
          ]
        },
        "first_line": {
          "type": "boolean"
        },
        "primary_next_action": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "warning_role": {
      "type": "object",
      "required": [
        "warning_class",
        "role",
        "preferred_remedy"
      ],
      "properties": {
        "warning_class": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "diagnostic",
            "external_manual_drift",
            "source_boundary_fix_candidate",
            "missing_helper",
            "ambiguous_output",
            "historical_residue",
            "obsolete_or_merge_candidate"
          ]
        },
        "preferred_remedy": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "report_section_role": {
      "type": "object",
      "required": [
        "section",
        "role",
        "default_visibility"
      ],
      "properties": {
        "section": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "primary_action",
            "blocker",
            "proof",
            "owner",
            "detail",
            "diagnostic",
            "inventory",
            "historical"
          ]
        },
        "default_visibility": {
          "enum": [
            "first_line",
            "selector_or_verbose"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "x-agentic-workspace-doc-role": "contract-reference"
}
