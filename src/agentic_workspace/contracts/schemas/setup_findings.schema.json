{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/setup-findings.schema.json",
  "title": "Agentic Workspace Setup Findings",
  "type": "object",
  "required": [
    "kind",
    "findings"
  ],
  "properties": {
    "kind": {
      "const": "workspace-setup-findings/v1"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "class",
          "summary"
        ],
        "properties": {
          "class": {
            "type": "string",
            "enum": [
              "repo_friction_evidence",
              "planning_candidate"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "refs": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          },
          "observed_during": {
            "type": "string",
            "minLength": 1
          },
          "signal_kind": {
            "type": "string",
            "enum": [
              "workflow_cost",
              "architecture_cost",
              "footprint_cost",
              "validation_friction",
              "docs_routing",
              "module_boundary",
              "repeated_human_steering",
              "weak_agent_failure",
              "shipped_footprint",
              "default_feature_creep"
            ]
          },
          "cost": {
            "type": "string",
            "minLength": 1
          },
          "suspected_owner": {
            "type": "string",
            "minLength": 1
          },
          "likely_remediation": {
            "type": "string",
            "enum": [
              "docs",
              "tests",
              "validation",
              "command",
              "scaffold",
              "writer_helper",
              "alias",
              "lifecycle_command",
              "agent_aid",
              "skill",
              "refactor",
              "module_split",
              "remove",
              "make_optional",
              "unship",
              "unknown"
            ]
          },
          "recurrence": {
            "type": "string",
            "enum": [
              "first_seen",
              "repeated",
              "human_confirmed"
            ]
          },
          "validation_failure_class": {
            "type": "string",
            "enum": [
              "user_or_content_error",
              "environment_or_dependency_error",
              "interface_design_error",
              "unclear_proof_contract"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
