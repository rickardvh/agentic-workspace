{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/setup-findings.schema.json",
  "title": "Agentic Workspace Setup Findings",
  "description": "Setup findings payload for post-bootstrap issues that may need promotion into planning, docs, config, or follow-up work.",
  "type": "object",
  "required": [
    "kind",
    "findings"
  ],
  "properties": {
    "kind": {
      "const": "workspace-setup-findings/v1",
      "description": "Discriminator for setup findings payloads."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "class",
          "summary"
        ],
        "properties": {
          "class": {
            "type": "string",
            "enum": [
              "repo_friction_evidence",
              "planning_candidate"
            ],
            "description": "Classification used for routing, filtering, or policy selection."
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "Short human-readable summary for this entry."
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Confidence contract value used by this contract."
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Path segments or repository path used by this contract."
          },
          "refs": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "string",
              "minLength": 1,
              "description": "One entry in the refs list."
            },
            "description": "References that help interpret or verify this record."
          },
          "next_action": {
            "type": "string",
            "minLength": 1,
            "description": "Next action text value used by this contract."
          },
          "why": {
            "type": "string",
            "minLength": 1,
            "description": "Why text value used by this contract."
          },
          "observed_during": {
            "type": "string",
            "minLength": 1,
            "description": "Observed during text value used by this contract."
          },
          "signal_kind": {
            "type": "string",
            "enum": [
              "workflow_cost",
              "architecture_cost",
              "footprint_cost",
              "validation_friction",
              "docs_routing",
              "module_boundary",
              "repeated_human_steering",
              "weak_agent_failure",
              "shipped_footprint",
              "default_feature_creep"
            ],
            "description": "Allowed signal kind value for routing or validation."
          },
          "cost": {
            "type": "string",
            "minLength": 1,
            "description": "Cost text value used by this contract."
          },
          "suspected_owner": {
            "type": "string",
            "minLength": 1,
            "description": "Suspected owner text value used by this contract."
          },
          "likely_remediation": {
            "type": "string",
            "enum": [
              "docs",
              "tests",
              "validation",
              "command",
              "scaffold",
              "writer_helper",
              "alias",
              "lifecycle_command",
              "agent_aid",
              "skill",
              "refactor",
              "module_split",
              "remove",
              "make_optional",
              "unship",
              "unknown"
            ],
            "description": "Allowed likely remediation value for routing or validation."
          },
          "recurrence": {
            "type": "string",
            "enum": [
              "first_seen",
              "repeated",
              "human_confirmed"
            ],
            "description": "Allowed recurrence value for routing or validation."
          },
          "validation_failure_class": {
            "type": "string",
            "enum": [
              "user_or_content_error",
              "environment_or_dependency_error",
              "interface_design_error",
              "unclear_proof_contract"
            ],
            "description": "Allowed validation failure class value for routing or validation."
          }
        },
        "additionalProperties": false,
        "description": "One entry in the findings list."
      },
      "description": "Setup findings discovered during install, doctor, or setup review."
    }
  },
  "additionalProperties": false,
  "x-agentic-workspace-doc-role": "contract-reference"
}
