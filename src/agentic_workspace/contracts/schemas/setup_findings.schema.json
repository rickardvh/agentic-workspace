{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/setup-findings.schema.json",
  "title": "Agentic Workspace Setup Findings",
  "type": "object",
  "required": [
    "kind",
    "findings"
  ],
  "properties": {
    "kind": {
      "const": "workspace-setup-findings/v1"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "class",
          "summary"
        ],
        "properties": {
          "class": {
            "type": "string",
            "enum": [
              "repo_friction_evidence",
              "planning_candidate"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "refs": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
