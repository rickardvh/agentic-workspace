{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/conformance.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "operation_id",
    "adapter",
    "fixtures",
    "expectations"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/conformance/v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "adapter": {
      "type": "object",
      "required": [
        "kind",
        "command_template",
        "cwd"
      ],
      "properties": {
        "kind": {
          "const": "process"
        },
        "command_template": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cwd": {
          "enum": [
            "fixture_root",
            "repo_root"
          ]
        }
      },
      "additionalProperties": false
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "files"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "files": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "expectations": {
      "type": "object",
      "required": [
        "exit",
        "stdout",
        "stderr",
        "filesystem",
        "idempotency",
        "safety"
      ],
      "properties": {
        "exit": {
          "type": "object",
          "required": [
            "code"
          ],
          "properties": {
            "code": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "stdout": {
          "type": "object",
          "required": [
            "format",
            "field_assertions"
          ],
          "properties": {
            "format": {
              "enum": [
                "json",
                "text"
              ]
            },
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "field_assertions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/field_assertion"
              }
            }
          },
          "additionalProperties": false
        },
        "stderr": {
          "type": "object",
          "required": [
            "allow_non_empty"
          ],
          "properties": {
            "allow_non_empty": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "filesystem": {
          "type": "object",
          "required": [
            "allowed_write_paths",
            "required_paths",
            "forbidden_paths"
          ],
          "properties": {
            "allowed_write_paths": {
              "$ref": "#/$defs/path_list"
            },
            "required_paths": {
              "$ref": "#/$defs/path_list"
            },
            "forbidden_paths": {
              "$ref": "#/$defs/path_list"
            }
          },
          "additionalProperties": false
        },
        "idempotency": {
          "type": "object",
          "required": [
            "run_twice"
          ],
          "properties": {
            "run_twice": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "safety": {
          "type": "object",
          "required": [
            "no_writes_outside_repo_root"
          ],
          "properties": {
            "no_writes_outside_repo_root": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "field_assertion": {
      "type": "object",
      "required": [
        "path",
        "equals"
      ],
      "properties": {
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "equals": {}
      },
      "additionalProperties": false
    },
    "path_list": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
