{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/contract-inventory.schema.json",
  "title": "Workspace Contract Inventory",
  "type": "object",
  "required": [
    "schema_version",
    "canonical_doc",
    "owner_choice_model",
    "areas"
  ],
  "properties": {
    "schema_version": {
      "const": "workspace-contract-inventory/v1"
    },
    "canonical_doc": {
      "type": "string"
    },
    "owner_choice_model": {
      "type": "object",
      "required": [
        "purpose",
        "review_questions",
        "concern_classes"
      ],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "review_questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "concern_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "owner_surface",
              "authority_class",
              "route_when",
              "avoid_when"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "owner_surface": {
                "type": "string",
                "minLength": 1
              },
              "authority_class": {
                "type": "string",
                "minLength": 1
              },
              "route_when": {
                "type": "string",
                "minLength": 1
              },
              "avoid_when": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "areas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "area",
          "classification",
          "owner_surface",
          "consumers",
          "notes"
        ],
        "properties": {
          "area": {
            "type": "string"
          },
          "classification": {
            "enum": [
              "declarative",
              "procedural",
              "procedural-contract",
              "derived"
            ]
          },
          "owner_surface": {
            "type": "string"
          },
          "consumers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
