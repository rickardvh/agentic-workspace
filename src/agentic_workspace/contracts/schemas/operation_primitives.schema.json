{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/operation-primitives.schema.json",
  "title": "Agentic Workspace Operation Primitives Registry",
  "description": "Registry of implementation primitives referenced by operation contracts.",
  "type": "object",
  "required": [
    "schema_version",
    "summary",
    "primitives"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/operation-primitives/v1",
      "description": "Contract version for this document."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable summary for this entry."
    },
    "ir_model": {
      "type": "object",
      "required": [
        "purpose",
        "boundary_rules"
      ],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1,
          "description": "Why this primitive registry exists as an operation IR boundary."
        },
        "boundary_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Rules that keep the primitive set from becoming an ad hoc programming language."
        },
        "defer_when": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Signals that behavior should remain a named runtime primitive instead of being decomposed further."
        }
      },
      "additionalProperties": false,
      "description": "Contract-level explanation of the target-executor IR model."
    },
    "module_ir_ownership": {
      "type": "object",
      "required": [
        "namespaces"
      ],
      "properties": {
        "rule": {
          "type": "string",
          "minLength": 1,
          "description": "Boundary rule for module-owned operation IR namespaces."
        },
        "namespaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "operation_id_prefix",
              "contract_owner"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_-]*$"
              },
              "operation_id_prefix": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_.-]*$"
              },
              "contract_owner": {
                "type": "string",
                "minLength": 1
              },
              "current_contract_root": {
                "type": "string",
                "minLength": 1
              },
              "future_contract_root": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "description": "Module namespaces that may own operation IR without making codegen package behavior module-specific."
        }
      },
      "additionalProperties": false,
      "description": "Ownership boundary for module-owned operation IR namespaces."
    },
    "primitive_extension_boundary": {
      "type": "object",
      "required": [
        "portable_support_rule",
        "module_extension_rule",
        "target_support_rule",
        "target_support_matrix"
      ],
      "properties": {
        "portable_support_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Rule for when target-executor primitives count as portable shared primitive coverage."
        },
        "module_extension_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Rule for keeping module-specific primitives explicit as domain-runtime extensions."
        },
        "target_support_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Rule requiring each generated target to implement shared primitives or visibly report unsupported/deferred behavior."
        },
        "target_support_matrix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "target",
              "status",
              "conformance_ref",
              "unsupported_behavior"
            ],
            "properties": {
              "target": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_-]*$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "implemented",
                  "unsupported-reported",
                  "deferred"
                ]
              },
              "implemented_shared_primitives": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9_.-]*$"
                }
              },
              "domain_runtime_extension_behavior": {
                "type": "string",
                "minLength": 1
              },
              "conformance_ref": {
                "type": "string",
                "minLength": 1
              },
              "unsupported_behavior": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "description": "Target support or explicit unsupported reporting for shared primitives and module/domain-runtime extensions."
        }
      },
      "additionalProperties": false,
      "description": "Rules that separate shared codegen primitives from module-specific primitive extensions."
    },
    "primitive_taxonomy": {
      "type": "object",
      "required": [
        "classification_rule",
        "tier_definitions",
        "tier_2_required_audit_fields",
        "generic_behavior_rule"
      ],
      "properties": {
        "classification_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Rule used to classify each primitive into a completion tier."
        },
        "tier_definitions": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": [
              "id",
              "summary",
              "blocks_full_python_completion"
            ],
            "properties": {
              "id": {
                "enum": [
                  "tier-1-portable-codegen",
                  "tier-2-package-domain",
                  "tier-3-deferred-or-out-of-scope"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "blocks_full_python_completion": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "description": "Completion tiers that separate portable codegen primitives, package-domain primitives, and deferred or out-of-scope debt."
        },
        "tier_2_required_audit_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Audit fields that every Tier 2 package-domain primitive must carry."
        },
        "generic_behavior_rule": {
          "type": "string",
          "minLength": 1,
          "description": "Rule preventing generic deterministic behavior from being hidden behind package-domain primitive classification."
        }
      },
      "additionalProperties": false,
      "description": "Completion-tier taxonomy for primitive references used by operation contracts."
    },
    "primitives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$",
            "description": "Stable identifier used to reference this record."
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "Short human-readable summary for this entry."
          },
          "kind": {
            "type": "string",
            "enum": [
              "filesystem",
              "structured-data",
              "record",
              "validation",
              "rendering",
              "output",
              "check",
              "workspace-runtime",
              "planning-runtime",
              "memory-runtime",
              "external-runtime",
              "usage-control"
            ],
            "description": "Portable primitive category or runtime-bridge category."
          },
          "portability": {
            "type": "string",
            "enum": [
              "target-executor",
              "domain-runtime",
              "external-adapter"
            ],
            "description": "Whether target runtimes are expected to implement this primitive directly or bridge it explicitly."
          },
          "semantics": {
            "type": "string",
            "description": "Concise execution semantics for target-executor primitives."
          },
          "input_schema_ref": {
            "type": "string",
            "pattern": "^schemas/primitives/[a-z0-9_.-]+\\.schema\\.json$",
            "description": "Primitive-specific input schema for target-executor implementations."
          },
          "output_schema_ref": {
            "type": "string",
            "pattern": "^schemas/primitives/[a-z0-9_.-]+\\.schema\\.json$",
            "description": "Primitive-specific output schema for target-executor implementations."
          },
          "taxonomy_tier": {
            "enum": [
              "tier-1-portable-codegen",
              "tier-2-package-domain",
              "tier-3-deferred-or-out-of-scope"
            ],
            "description": "Completion-tier classification for operation-step references."
          },
          "tier_owner": {
            "type": "string",
            "minLength": 1
          },
          "tier_reason": {
            "type": "string",
            "minLength": 1
          },
          "conformance_ref": {
            "type": "string",
            "minLength": 1
          },
          "migration_path": {
            "type": "string",
            "minLength": 1
          },
          "generic_behavior_audit": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false,
        "description": "One entry in the primitives list."
      },
      "description": "Ordered primitives entries used by this contract."
    }
  },
  "additionalProperties": false,
  "x-agentic-workspace-doc-role": "contract-reference"
}
