{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/operation-primitives.schema.json",
  "title": "Agentic Workspace Operation Primitives Registry",
  "type": "object",
  "required": [
    "schema_version",
    "summary",
    "primitives"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/operation-primitives/v1"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "primitives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
