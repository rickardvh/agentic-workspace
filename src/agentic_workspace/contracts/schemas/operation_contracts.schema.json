{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/operation-contracts.schema.json",
  "title": "Agentic Workspace Operation Contracts Registry",
  "description": "Registry of operation contracts exposed by workspace commands or adapters.",
  "type": "object",
  "required": [
    "schema_version",
    "summary",
    "primitive_registry",
    "schema",
    "mutation_outcome_contract",
    "operations"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/operation-contracts/v1",
      "description": "Contract version for this document."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable summary for this entry."
    },
    "primitive_registry": {
      "const": "operation_primitives.json",
      "description": "Fixed primitive registry value required by this contract."
    },
    "schema": {
      "const": "schemas/operation.schema.json",
      "description": "Schema reference or schema metadata for this payload."
    },
    "mutation_outcome_contract": {
      "type": "object",
      "required": ["schema_version", "applicability", "outcomes", "fields", "explicit_exceptions", "proof_requirements"],
      "properties": {
        "schema_version": {"const": "agentic-workspace/mutation-outcome/v1"},
        "applicability": {"const": "Every registered operation with effects.writes_repo_state=true must emit this result contract unless listed in explicit_exceptions."},
        "outcomes": {
          "type": "array",
          "prefixItems": [
            {"const": "applied"},
            {"const": "noop"},
            {"const": "blocked"},
            {"const": "failed"}
          ],
          "items": false
        },
        "fields": {
          "type": "array",
          "prefixItems": [
            {"const": "outcome"},
            {"const": "mutation_applied"},
            {"const": "reason_code"},
            {"const": "conflict_owner"},
            {"const": "recovery_command"}
          ],
          "items": false
        },
        "explicit_exceptions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["operation_id", "reason", "proof"],
            "properties": {
              "operation_id": {"type": "string", "minLength": 1},
              "reason": {"type": "string", "minLength": 1},
              "proof": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "proof_requirements": {
          "type": "array",
          "contains": {"const": "Representative applied, noop, blocked, and failed behavior must pass for Python and TypeScript generated targets."}
        }
      },
      "additionalProperties": false,
      "description": "Authoritative shared result invariant and inventory rule for mutating operation IR."
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "command",
          "migration_status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$",
            "description": "Stable identifier used to reference this record."
          },
          "path": {
            "type": "string",
            "pattern": "^operations/[a-z0-9_.-]+\\.json$",
            "description": "Path segments or repository path used by this contract."
          },
          "command": {
            "type": "string",
            "minLength": 1,
            "description": "Command string or command name used by this contract."
          },
          "migration_status": {
            "type": "string",
            "enum": [
              "draft-contract-only",
              "validated-contract",
              "runtime-consumed"
            ],
            "description": "Maturity or migration state for this contract entry."
          }
        },
        "additionalProperties": false,
        "description": "One entry in the operations list."
      },
      "description": "Ordered operations entries used by this contract."
    }
  },
  "additionalProperties": false,
  "x-agentic-workspace-doc-role": "contract-reference"
}
