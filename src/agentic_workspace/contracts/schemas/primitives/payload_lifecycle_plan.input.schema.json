{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/primitives/payload_lifecycle_plan.input.schema.json",
  "title": "payload.lifecycle-plan input",
  "type": "object",
  "required": [
    "policy_root",
    "policy_path",
    "target_root_value",
    "dry_run"
  ],
  "properties": {
    "policy_root": {
      "type": "string",
      "minLength": 1
    },
    "policy_path": {
      "type": "string",
      "minLength": 1
    },
    "target_root_value": {
      "type": "string",
      "minLength": 1
    },
    "dry_run": {
      "const": true
    },
    "mode": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "missing_kind": {
      "type": "string"
    },
    "missing_detail": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
