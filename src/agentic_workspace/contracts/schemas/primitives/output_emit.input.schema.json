{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/primitives/output_emit.input.schema.json",
  "title": "output.emit input",
  "type": "object",
  "properties": {
    "payload": {
      "type": [
        "object",
        "array",
        "string",
        "number",
        "boolean",
        "null"
      ],
      "description": "Structured payload to emit."
    },
    "format": {
      "type": "string",
      "enum": [
        "json",
        "text"
      ],
      "description": "Requested output format."
    },
    "text_views": {
      "type": "array",
      "description": "Declared host-neutral text rendering views consumed by portable output.emit implementations.",
      "items": {
        "$ref": "#/$defs/text_view"
      }
    }
  },
  "oneOf": [
    {
      "required": [
        "payload"
      ]
    },
    {
      "required": [
        "result"
      ]
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "text_view": {
      "type": "object",
      "required": [
        "id",
        "lines"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "match": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null"
            ]
          }
        },
        "default": {
          "type": "boolean"
        },
        "lines": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/text_line"
          }
        }
      },
      "additionalProperties": false
    },
    "text_line": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "literal"
          ],
          "properties": {
            "literal": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "template"
          ],
          "properties": {
            "template": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "json"
          ],
          "properties": {
            "json": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "when",
            "lines"
          ],
          "properties": {
            "when": {
              "type": "string"
            },
            "lines": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/text_line"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "for_each"
          ],
          "properties": {
            "for_each": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string"
                },
                "template": {
                  "type": "string"
                },
                "lines": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/text_line"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
