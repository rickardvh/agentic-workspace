{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic-workspace/operation-artifact-registry.schema.json",
  "title": "Operation Artifact Registry",
  "description": "Registry mapping operation contracts to implementation artifacts, adapters, wrapper surfaces, conformance cases, and proof routing.",
  "type": "object",
  "required": [
    "schema_version",
    "summary",
    "schema",
    "source_role",
    "artifacts",
    "proof_routing"
  ],
  "properties": {
    "schema_version": {
      "const": "agentic-workspace/operation-artifact-registry/v1",
      "description": "Operation artifact registry contract version."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Short summary of the registry boundary."
    },
    "schema": {
      "const": "schemas/operation_artifact_registry.schema.json",
      "description": "Schema reference carried by the registry document."
    },
    "source_role": {
      "type": "object",
      "required": [
        "surface",
        "ordinary_startup_visibility",
        "rule"
      ],
      "properties": {
        "surface": {
          "const": "source/proof",
          "description": "Classifies the registry as a source/proof surface."
        },
        "ordinary_startup_visibility": {
          "const": "not-startup-workflow",
          "description": "Confirms that artifact registry data is hidden from ordinary startup routing."
        },
        "rule": {
          "type": "string",
          "minLength": 1,
          "description": "Routing rule for how proof tooling should treat this registry."
        }
      },
      "additionalProperties": false,
      "description": "Visibility and workflow posture for the registry."
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "description": "Executable artifacts that claim to implement operation contracts.",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "operation_id",
          "package_id",
          "target",
          "adapter_id",
          "proof_role",
          "source_ref",
          "wrapper_refs",
          "case_ids",
          "path_refs",
          "stale_when"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$",
            "description": "Stable artifact identifier."
          },
          "operation_id": {
            "type": "string",
            "minLength": 1,
            "description": "Operation contract implemented by the artifact."
          },
          "package_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$",
            "description": "Command package owning the artifact."
          },
          "target": {
            "enum": [
              "python",
              "typescript"
            ],
            "description": "Generated target family for the artifact."
          },
          "adapter_id": {
            "enum": [
              "python.function",
              "typescript.function",
              "cli.process"
            ],
            "description": "Adapter used to execute the artifact."
          },
          "proof_role": {
            "enum": [
              "operation-conformance",
              "wrapper-smoke"
            ],
            "description": "Whether the artifact proves operation semantics or only wrapper boundary smoke."
          },
          "symbol": {
            "type": "string",
            "minLength": 1,
            "description": "Importable symbol for direct function adapters."
          },
          "source_ref": {
            "type": "string",
            "minLength": 1,
            "description": "Canonical source reference that owns artifact generation."
          },
          "wrapper_refs": {
            "$ref": "#/$defs/strings",
            "description": "Wrapper surfaces delegating to this artifact."
          },
          "case_ids": {
            "$ref": "#/$defs/non_empty_strings",
            "description": "Operation conformance case ids that apply to this artifact."
          },
          "path_refs": {
            "$ref": "#/$defs/non_empty_strings",
            "description": "Generated or contract paths whose changes should select this artifact."
          },
          "stale_when": {
            "$ref": "#/$defs/non_empty_strings",
            "description": "Conditions that make this artifact registry entry stale."
          }
        },
        "additionalProperties": false
      }
    },
    "proof_routing": {
      "type": "object",
      "required": [
        "rule",
        "routes"
      ],
      "properties": {
        "rule": {
          "type": "string",
          "minLength": 1,
          "description": "General changed-path proof routing rule."
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "description": "Changed-surface to proof-layer routing table.",
          "items": {
            "type": "object",
            "required": [
              "changed_surface",
              "proof"
            ],
            "properties": {
              "changed_surface": {
                "enum": [
                  "operation-contract",
                  "implementation-artifact",
                  "implementation-adapter",
                  "cli-wrapper",
                  "mcp-wrapper",
                  "schema",
                  "generated-artifact-freshness"
                ],
                "description": "Changed surface class."
              },
              "proof": {
                "$ref": "#/$defs/non_empty_strings",
                "description": "Proof layers selected for this surface."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false,
      "description": "Proof routing from changed surfaces to validation layers."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "strings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_empty_strings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "x-agentic-workspace-doc-role": "contract-reference"
}
