{
  "schema_version": "agentic-workspace/operation-conformance-test-ir/v1",
  "summary": "Schema-coupled behavioral conformance cases for operation contracts and their implementation artifacts.",
  "schema": "schemas/operation_conformance_test_ir.schema.json",
  "source_role": {
    "surface": "source/proof",
    "ordinary_startup_visibility": "not-startup-workflow",
    "rule": "Operation conformance test IR is consumed by proof and migration tooling only; it must not become an ordinary agent startup surface."
  },
  "source_contracts": [
    "command_package_ir.json",
    "operation_contracts.json",
    "operation_primitives.json",
    "conformance_contracts.json",
    "contracts/conformance/*.process.json"
  ],
  "migration_policy": {
    "preserve": [
      "black-box operation behavior",
      "operation and schema expectations",
      "representative success, error, and cross-target parity semantics",
      "user-visible output and failure contracts"
    ],
    "do_not_preserve": [
      "one-for-one handwritten regression-test bulk",
      "old fixture helper names",
      "target-specific implementation details when a simpler IR case preserves the contract",
      "duplicate primitive assertions inside composite operation tests",
      "CLI invocation style when a direct implementation adapter can preserve the same contract"
    ],
    "composition_rule": "Primitive behavior is tested once at its own level; composite operation cases assume declared primitive contracts work and assert only the higher-level composition, routing, selection, aggregation, ordering, and boundary behavior.",
    "first_migration_tranche": [
      "selected-output operation cases already represented by conformance contracts",
      "structured operation error contracts for declared inputs",
      "Python/TypeScript parity for generated operation artifacts with stable JSON output"
    ],
    "handwritten_retention_boundary": [
      "runtime primitive implementation tests",
      "live workspace inspection and mutation orchestration tests",
      "generator internals and target adapter mechanics",
      "CLI boundary tests whose behavior is wrapper-specific rather than operation conformance"
    ]
  },
  "adapter_model": {
    "default_semantic_path": "direct implementation adapters execute JSON-shaped operation inputs and normalize JSON results before comparison; argv/stdout/stderr cases are wrapper-smoke proof until a generated operation-shaped callable exists.",
    "adapter_kinds": [
      {
        "id": "python.function",
        "boundary": "operation",
        "default_for_semantic_proof": true,
        "description": "Import a generated Python function, call it with JSON-shaped data, and normalize the return value or structured error."
      },
      {
        "id": "typescript.function",
        "boundary": "operation",
        "default_for_semantic_proof": true,
        "description": "Invoke a generated TypeScript/JavaScript function through Node and normalize the returned JSON or structured error."
      },
      {
        "id": "cli.process",
        "boundary": "wrapper",
        "default_for_semantic_proof": false,
        "description": "Invoke argv/stdout/stderr only when the CLI wrapper boundary is the artifact under test."
      }
    ],
    "normalization_rule": "Normalization is declared by the case or operation contract where possible; adapters remain thin invocation and serialization shims."
  },
  "semantic_coverage_classes": [
    {
      "id": "success",
      "intent": "An operation artifact accepts declared JSON-shaped input and returns schema-coupled canonical JSON output.",
      "minimum_case_shape": [
        "operation_ref",
        "input",
        "fixture",
        "expected canonical result"
      ]
    },
    {
      "id": "error",
      "intent": "An operation artifact rejects invalid declared input through a structured JSON error contract.",
      "minimum_case_shape": [
        "operation_ref",
        "input",
        "expected structured error"
      ]
    },
    {
      "id": "cross-target-parity",
      "intent": "Implementation artifacts preserve the same operation-level behavior after target-specific normalization.",
      "minimum_case_shape": [
        "operation_ref",
        "two or more artifacts",
        "normalization rule",
        "canonical JSON fields compared for parity"
      ]
    },
    {
      "id": "boundary",
      "intent": "An operation or wrapper artifact respects safety, freshness, or ownership boundaries without retesting primitive internals.",
      "minimum_case_shape": [
        "operation_ref",
        "artifact refs",
        "boundary assertion",
        "freshness source",
        "explicit retained handwritten-test rationale when not migrated"
      ]
    }
  ],
  "target_matrix": [
    {
      "kind": "python",
      "status": "required",
      "adapter_id": "python.function",
      "fallback_adapter_id": "cli.process",
      "runner": "scripts/check/run_operation_conformance_tests.py --target python"
    },
    {
      "kind": "typescript",
      "status": "required",
      "adapter_id": "typescript.function",
      "fallback_adapter_id": "cli.process",
      "runner": "scripts/check/run_operation_conformance_tests.py --target typescript --require-node"
    }
  ],
  "proof_output": {
    "kind": "operation-conformance-proof/v1",
    "states": [
      "pass",
      "fail",
      "stale",
      "unavailable",
      "skipped"
    ],
    "required_case_fields": [
      "case id",
      "behavioral class",
      "operation id",
      "artifact id",
      "adapter id",
      "conformance ref when present",
      "targets attempted",
      "state",
      "failure classification or skip reason"
    ],
    "routing_rule": "Changed operation contract, schema, conformance, implementation artifact, adapter, or generated target paths should route to scripts/check/run_operation_conformance_tests.py before closeout when they touch migrated operation behavior; wrapper-shaped cases remain wrapper-smoke proof and must not be presented as default semantic operation proof."
  },
  "initial_cases": [
