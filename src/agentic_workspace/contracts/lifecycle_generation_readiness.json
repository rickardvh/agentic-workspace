  "primitive_review": [
    "workspace.root.resolve and workspace.selection.resolve are adapter-adjacent but runtime-owned because they inspect local context.",
    "workspace.lifecycle.plan must be the shared dry-run and apply planner.",
    "workspace.lifecycle.apply must own repo mutations and deletion safeguards.",
    "A future workspace.lifecycle.verify primitive should be explicit before mutating lifecycle adapters are generated.",
    "module.status.inspect and module.payload.render remain useful candidate primitive families but are not yet required for this slice."
  ],
  "output_contract": [
    "Lifecycle output should distinguish plan, apply, verify, and refusal results.",
    "Dry-run output must be a plan result, not a separate command-specific rendering path.",
    "Detailed diagnostics should remain behind report/doctor detail fields rather than becoming adapter interface truth.",
    "Every result should carry dry_run, actions, warnings, and target_root when applicable."
  ],
  "conformance_fixture_plan": [
    "empty repo install dry-run has no filesystem effects and reports planned creates",
    "existing repo adopt dry-run preserves repo-owned files",
    "installed repo status is read-only and idempotent",
    "installed repo upgrade dry-run uses planner without writes",
    "ambiguous ownership uninstall refuses without deletion",
    "local-only state is preserved by install, upgrade, and uninstall",
    "strict preflight blocks high-risk mutation when configured"
  ],
  "generation_decision": [
    "Read-only doctor/status lifecycle surfaces may be generated after output contracts are explicit.",
    "install/init/adopt/upgrade remain deferred mutation surfaces until lifecycle.verify and plan/apply output contracts are explicit.",
    "uninstall remains deferred destructive until refusal fixtures and ownership checks are black-box conformance-covered.",
    "Generated adapters may own command shape and dispatch only; runtime primitives own planning, mutation, verification, and local inspection."
  ]
}
