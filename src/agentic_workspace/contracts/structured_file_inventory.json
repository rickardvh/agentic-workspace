      "status": "typed-validator-backed",
      "schema_or_validator": "uv/build-backend packaging validation",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Package metadata is validated by Python packaging tools."
    },
    {
      "pattern": "packages/*/src/**/_ownership.toml",
      "format": "toml",
      "owner": "package-lifecycle",
      "status": "typed-validator-backed",
      "schema_or_validator": "package payload ownership checks",
      "editable_by_agents": true,
      "generated": false,
