    },
    {
      "pattern": "packages/memory/tests/fixtures/**/*.toml",
      "format": "toml",
      "owner": "memory-tests",
      "status": "source-checkout-diagnostic",
      "schema_or_validator": "pytest fixture assertions",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Fixture TOML is test data, not shipped runtime policy."
    },
    {
      "pattern": "packages/planning/bootstrap/.agentic-workspace/planning/execplans/*.plan.json",
      "format": "json",
      "owner": "planning-payload",
      "status": "freeform-prohibited-gap",
      "schema_or_validator": "planning execplan JSON schema pending",
      "editable_by_agents": true,
      "generated": false,
      "routed_to": "#505",
      "notes": "Bootstrap execplan templates share the execplan schema gap."
    },
    {
      "pattern": "packages/planning/bootstrap/.agentic-workspace/planning/reviews/*.review.json",
      "format": "json",
      "owner": "planning-payload",
      "status": "freeform-prohibited-gap",
      "schema_or_validator": "planning review JSON schema pending",
      "editable_by_agents": true,
      "generated": false,
      "routed_to": "#505",
      "notes": "Bootstrap review templates share the review schema gap."
    },
    {
      "pattern": "packages/planning/bootstrap/**/*.json",
      "format": "json",
      "owner": "planning-payload",
      "status": "typed-validator-backed",
      "schema_or_validator": "planning payload verification",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Planning bootstrap JSON is covered by package payload verification."
    },
    {
      "pattern": "packages/planning/skills/REGISTRY.json",
      "format": "json",
      "owner": "planning-skills",
      "status": "typed-validator-backed",
      "schema_or_validator": "agentic-workspace skills discovery and planning payload verification",
      "editable_by_agents": true,
