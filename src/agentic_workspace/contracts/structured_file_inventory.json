      "owner": "memory-skills",
      "status": "source-checkout-diagnostic",
      "schema_or_validator": "OpenAI agent skill metadata convention",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Agent-specific skill hints are optional source metadata."
    },
    {
      "pattern": "packages/*/bootstrap/.agentic-workspace/*/UPGRADE-SOURCE.toml",
      "format": "toml",
      "owner": "package-payload",
      "status": "typed-validator-backed",
      "schema_or_validator": "package upgrade/source checks",
      "editable_by_agents": false,
