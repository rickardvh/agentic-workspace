      "notes": "Package bootstrap upgrade-source metadata is payload-managed."
    },
    {
      "pattern": "packages/memory/tests/fixtures/**/*.json",
      "format": "json",
      "owner": "memory-tests",
      "status": "source-checkout-diagnostic",
