    },
    {
      "pattern": ".agentic-workspace/planning/external-intent-evidence.json",
      "format": "json",
      "owner": "planning-evidence",
      "status": "freeform-prohibited-gap",
      "schema_or_validator": "external intent evidence schema pending",
      "editable_by_agents": true,
      "generated": false,
      "routed_to": "#506",
      "notes": "External intent evidence needs a dedicated schema."
    },
    {
      "pattern": ".agentic-workspace/planning/finished-work-evidence.json",
      "format": "json",
      "owner": "planning-evidence",
      "status": "freeform-prohibited-gap",
      "schema_or_validator": "finished work evidence schema pending",
      "editable_by_agents": true,
      "generated": false,
      "routed_to": "#506",
      "notes": "Finished-work evidence needs a dedicated schema."
    },
    {
      "pattern": ".agentic-workspace/planning/agent-manifest.json",
      "format": "json",
      "owner": "planning-payload",
      "status": "typed-validator-backed",
      "schema_or_validator": "planning payload verification",
      "editable_by_agents": false,
      "generated": true,
      "notes": "Generated planning adapter manifest is payload-managed."
    },
    {
      "pattern": ".agentic-workspace/planning/UPGRADE-SOURCE.toml",
      "format": "toml",
      "owner": "planning-payload",
      "status": "typed-validator-backed",
      "schema_or_validator": "planning upgrade/source checks",
      "editable_by_agents": false,
      "generated": false,
      "notes": "Upgrade source metadata is payload-managed."
    },
    {
      "pattern": ".agentic-workspace/planning/skills/REGISTRY.json",
      "format": "json",
      "owner": "planning-skills",
      "status": "typed-validator-backed",
      "schema_or_validator": "agentic-workspace skills discovery",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Planning skill registry is consumed by skill discovery."
    },
    {
      "pattern": "tools/agent-manifest.json",
      "format": "json",
      "owner": "planning-payload",
      "status": "generated-derived",
      "schema_or_validator": "planning payload render/check surfaces",
      "editable_by_agents": false,
      "generated": true,
      "notes": "Root generated agent manifest is a compatibility adapter."
    },
    {
      "pattern": "tools/skills/REGISTRY.json",
      "format": "json",
      "owner": "workspace-skills",
      "status": "typed-validator-backed",
      "schema_or_validator": "agentic-workspace skills discovery",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Root tool skill registry is consumed by skill discovery."
    },
    {
      "pattern": "packages/memory/**/manifest.toml",
      "format": "toml",
      "owner": "memory",
      "status": "freeform-prohibited-gap",
      "schema_or_validator": "memory manifest typed validator pending",
      "editable_by_agents": true,
      "generated": false,
      "routed_to": "#504",
      "notes": "Memory package and payload manifests share the memory manifest contract gap."
    },
    {
      "pattern": "packages/memory/**/REGISTRY.json",
      "format": "json",
      "owner": "memory-skills",
      "status": "typed-validator-backed",
