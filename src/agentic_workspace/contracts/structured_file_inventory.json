      "editable_by_agents": false,
      "generated": false,
      "routed_to": "#505",
      "notes": "Archived execplan records need a dedicated schema."
    },
    {
      "pattern": ".agentic-workspace/planning/reviews/*.review.json",
      "format": "json",
      "owner": "planning-review",
      "status": "freeform-prohibited-gap",
