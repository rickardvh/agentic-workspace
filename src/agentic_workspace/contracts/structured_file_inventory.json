{
  "kind": "agentic-workspace/structured-file-inventory/v1",
  "schema_version": "structured-file-inventory/v1",
  "rule": "Tracked JSON, TOML, YAML, and YML files are machine-readable surfaces. Each must be classified as schema-backed, typed-validator-backed, generated/derived, source-checkout diagnostic, or an explicit freeform-prohibited gap routed to an issue.",
  "statuses": [
    "schema-backed",
    "typed-validator-backed",
    "generated-derived",
    "source-checkout-diagnostic",
    "freeform-prohibited-gap"
  ],
  "entries": [
    {
      "pattern": "src/agentic_workspace/contracts/structured_file_inventory.json",
      "format": "json",
      "owner": "workspace-contracts",
      "status": "schema-backed",
      "schema_or_validator": "src/agentic_workspace/contracts/schemas/structured_file_inventory.schema.json",
      "editable_by_agents": true,
      "generated": false,
      "notes": "This inventory is validated by scripts/check/check_structured_file_inventory.py."
    },
    {
      "pattern": "src/agentic_workspace/contracts/schemas/*.schema.json",
      "format": "json",
      "owner": "workspace-contracts",
      "status": "schema-backed",
      "schema_or_validator": "JSON Schema draft 2020-12",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Schema files are the validation authority for contract manifests and generated payload shapes."
    },
    {
      "pattern": "src/agentic_workspace/contracts/operations/*.json",
      "format": "json",
      "owner": "workspace-contracts",
      "status": "schema-backed",
      "schema_or_validator": "src/agentic_workspace/contracts/schemas/operation.schema.json",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Operation contracts are validated by contract tooling checks."
    },
    {
      "pattern": "src/agentic_workspace/contracts/conformance/*.json",
      "format": "json",
      "owner": "workspace-contracts",
      "status": "schema-backed",
      "schema_or_validator": "src/agentic_workspace/contracts/schemas/conformance.schema.json",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Conformance process contracts are validated by contract tooling checks."
    },
    {
      "pattern": "src/agentic_workspace/contracts/*.json",
      "format": "json",
      "owner": "workspace-contracts",
      "status": "freeform-prohibited-gap",
      "schema_or_validator": "mixed existing schema coverage; see routed issue",
      "editable_by_agents": true,
      "generated": false,
      "routed_to": "#508",
      "notes": "Root contract manifests need complete schema or typed-validator coverage."
    },
    {
      "pattern": "src/agentic_workspace/_payload/.agentic-workspace/OWNERSHIP.toml",
      "format": "toml",
      "owner": "workspace-payload",
      "status": "typed-validator-backed",
      "schema_or_validator": "workspace install/doctor ownership checks",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Payload ownership metadata is consumed by lifecycle checks."
    },
    {
      "pattern": ".agentic-workspace/config.toml",
      "format": "toml",
      "owner": "workspace-config",
      "status": "schema-backed",
      "schema_or_validator": "src/agentic_workspace/contracts/schemas/workspace_config.schema.json",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Resolved workspace config is validated through config/start/report paths."
    },
    {
      "pattern": ".agentic-workspace/OWNERSHIP.toml",
      "format": "toml",
      "owner": "workspace-lifecycle",
      "status": "typed-validator-backed",
      "schema_or_validator": "workspace ownership and doctor checks",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Repo ownership metadata is a lifecycle surface."
    },
    {
      "pattern": ".agentic-workspace/system-intent/intent.toml",
      "format": "toml",
      "owner": "system-intent",
      "status": "typed-validator-backed",
      "schema_or_validator": "agentic-workspace system-intent refresh/report path",
      "editable_by_agents": true,
      "generated": false,
      "notes": "System intent is compact repo-owned policy state."
    },
    {
      "pattern": ".agentic-workspace/docs/capability-contract.json",
      "format": "json",
      "owner": "planning-payload",
      "status": "typed-validator-backed",
      "schema_or_validator": "planning payload verification",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Installed planning payload capability contract is checked during payload verification."
    },
    {
      "pattern": ".agentic-workspace/memory/repo/manifest.toml",
      "format": "toml",
      "owner": "memory",
      "status": "freeform-prohibited-gap",
      "schema_or_validator": "memory manifest typed validator pending",
      "editable_by_agents": true,
      "generated": false,
      "routed_to": "#504",
      "notes": "Memory manifest TOML needs an explicit schema or typed validator."
    },
    {
      "pattern": ".agentic-workspace/memory/UPGRADE-SOURCE.toml",
      "format": "toml",
      "owner": "memory-payload",
      "status": "typed-validator-backed",
      "schema_or_validator": "memory upgrade/source checks",
      "editable_by_agents": false,
      "generated": false,
      "notes": "Upgrade source metadata is payload-managed."
    },
    {
      "pattern": ".agentic-workspace/memory/**/REGISTRY.json",
      "format": "json",
      "owner": "memory-skills",
      "status": "typed-validator-backed",
      "schema_or_validator": "agentic-workspace skills discovery",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Skill registries are consumed by the skills command and package verification."
    },
    {
      "pattern": ".agentic-workspace/memory/skills/*/agents/openai.yaml",
      "format": "yaml",
      "owner": "memory-skills",
      "status": "source-checkout-diagnostic",
      "schema_or_validator": "OpenAI agent skill metadata convention",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Agent-specific skill hints are optional source metadata, not core package state."
    },
    {
      "pattern": ".agentic-workspace/planning/state.toml",
      "format": "toml",
      "owner": "planning",
      "status": "typed-validator-backed",
      "schema_or_validator": "planning-state/v1 parser and planning surface checker",
      "editable_by_agents": true,
      "generated": false,
      "notes": "Planning state is checked by summary, doctor, and planning-surface validation."
    },
    {
      "pattern": ".agentic-workspace/planning/execplans/*.plan.json",
      "format": "json",
      "owner": "planning",
      "status": "freeform-prohibited-gap",
      "schema_or_validator": "planning execplan JSON schema pending",
      "editable_by_agents": true,
      "generated": false,
      "routed_to": "#505",
      "notes": "Active execplan records need a dedicated schema."
    },
    {
      "pattern": ".agentic-workspace/planning/execplans/archive/*.plan.json",
