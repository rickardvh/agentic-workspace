  "advanced_features": [
    {
      "id": "review_artifacts",
      "label": "Review artifacts and promotion",
      "tier": "reusable-diagnostics",
      "default_enabled": false,
      "activation": "Enable when a host repo intentionally keeps review artifacts and promotion evidence.",
      "default_surface_policy": "Evidence/history only; not ordinary startup input.",
      "selector_hint": "agentic-workspace report --target ./repo --section closeout_trust --format json"
    },
    {
      "id": "external_adapters",
