{
  "schema_version": "agentic-workspace/module-registry/v1",
  "package_footprint": {
    "decision": "bundle-first-party-modules-for-now",
    "status": "intentional-temporary",
    "python_package_dependency_model": "root package currently depends on the bundled planning and memory module packages unconditionally.",
    "repo_footprint_rule": "Presets choose checked-in repository footprint; routing-only minimizes installed repo state, not Python package dependencies.",
    "why": "Keeping first-party modules installed with the root command preserves simple uvx/pipx lifecycle orchestration while generic module manifests and optional-module loading are still being shaped.",
    "bounded_by": [
      "#490",
      "#510"
    ],
    "future_options": [
      "keep bundled first-party distribution intentionally",
      "add optional extras for selected first-party modules",
      "load module packages lazily from generic module declarations",
      "publish a separate core orchestrator and first-party bundle"
    ],
    "must_preserve": [
      "simple root lifecycle invocation",
      "routing-only as smallest checked-in repo footprint",
      "planning and memory as first-party examples of the same module contract third parties use"
    ]
  },
  "component_model": {
    "schema_version": "agentic-workspace/module-components/v1",
    "alignment": "mcp-style-adapter-ready",
    "runtime_dependency": "none",
    "source_of_truth": "module_registry.json",
    "rule": "Module components are declarative projection metadata. A future adapter may project them to MCP resources, tools, prompts, schemas, and roots, but core package operation must not require an MCP runtime.",
    "component_classes": [
      {
        "id": "resource",
        "maps_to": "mcp.resource",
        "semantics": "read-only queryable context, state, or report output",
        "required_fields": [
          "uri",
          "description",
          "read_only",
          "result_schema"
        ]
      },
      {
        "id": "tool",
        "maps_to": "mcp.tool",
        "semantics": "executable operation, including mutating lifecycle work",
        "required_fields": [
          "name",
          "description",
          "read_only",
          "destructive",
          "idempotent",
          "requires_dry_run",
          "input_schema",
          "result_schema",
          "safety"
        ]
      },
      {
        "id": "prompt",
        "maps_to": "mcp.prompt",
        "semantics": "reusable skill, handoff, or operating template",
        "required_fields": [
          "name",
          "description",
          "template"
        ]
      },
      {
        "id": "schema",
        "maps_to": "mcp.schema",
        "semantics": "input, output, or structured-result contract referenced by resources and tools",
        "required_fields": [
          "id",
          "path",
          "schema_kind"
        ]
      },
      {
        "id": "root",
        "maps_to": "mcp.root",
        "semantics": "owned path or boundary used to scope resources and tools",
        "required_fields": [
          "id",
          "path",
          "ownership"
        ]
      }
    ],
    "adapter_boundary": {
      "future_adapter": "optional separate adapter package or wrapper",
      "adapter_consumes": [
        "module_registry.component_model",
        "modules[*].components",
        "component schema references",
        "tool safety metadata",
        "owned roots and path boundaries"
      ],
      "adapter_must_not": [
        "become the source of truth for module behavior",
        "add FastMCP or MCP runtime dependencies to the core package",
        "expose source-checkout-only maintainer tooling as host-repo components by default"
      ],
      "blocking_prerequisites": [
        "stable component vocabulary",
        "schema or typed-validator coverage for referenced structured results",
        "explicit safety metadata for mutating tools"
      ]
    }
  },
  "module_profiles": [
    {
      "id": "routing-only",
      "label": "Routing only",
      "profile_kind": "root-routing",
      "selected_modules": [],
      "preset": null,
      "default_active": true,
      "activation": "Use when the repo only needs compact entrypoint, config, and report routing surfaces.",
      "cost_model": "smallest checked-in repo footprint; no module state selected.",
      "selection_rule": "absence of selected modules plus root routing surfaces"
    },
    {
      "id": "planning",
      "label": "Planning",
      "profile_kind": "installer-preset",
      "selected_modules": [
        "planning"
      ],
      "preset": "planning",
      "default_active": true,
      "activation": "Use when active execution state, execplan routing, or lane closeout must be recoverable.",
      "cost_model": "adds checked-in planning state and active-work proof surfaces.",
      "selection_rule": "expands to the bundled planning module"
    },
    {
      "id": "memory",
      "label": "Memory",
      "profile_kind": "installer-preset",
      "selected_modules": [
        "memory"
      ],
      "preset": "memory",
      "default_active": true,
      "activation": "Use when durable repo knowledge should prevent repeated rediscovery.",
      "cost_model": "adds checked-in routed knowledge surfaces without active execution planning.",
      "selection_rule": "expands to the bundled memory module"
    },
    {
      "id": "full",
      "label": "Full",
      "profile_kind": "installer-preset",
      "selected_modules": [
        "planning",
        "memory"
      ],
      "preset": "full",
      "default_active": true,
      "activation": "Use when both active execution state and durable repo knowledge are worth the shared footprint.",
      "cost_model": "installer convenience profile; does not imply source-checkout maintainer tooling or optional advanced surfaces.",
      "selection_rule": "expands to every bundled module marked include_in_full_preset"
    }
  ],
  "feature_tiers": [
