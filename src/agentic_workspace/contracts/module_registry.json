  "modules": [
    {
      "name": "planning",
      "description": "Repo-native execution planning bootstrap and maintenance.",
      "selection_rank": 10,
      "include_in_full_preset": true,
      "install_signals": [
        ".agentic-workspace/planning/state.toml",
        ".agentic-workspace/planning/execplans"
      ],
      "workflow_surfaces": [
        "AGENTS.md",
        ".agentic-workspace/planning/state.toml",
        ".agentic-workspace/planning/execplans",
        "docs/contributor-playbook.md"
      ],
      "generated_artifacts": [],
      "startup_steps": [
        "Read `.agentic-workspace/planning/state.toml` via `agentic-workspace summary`.",
        "Read the active feature plan in `.agentic-workspace/planning/execplans/` when the TODO surface points there.",
        "Check the roadmap in `state.toml` (authoritative) only when promoting work."
      ],
      "sources_of_truth": [
        "Active queue: `.agentic-workspace/planning/state.toml` (authoritative)",
        "Roadmap: `.agentic-workspace/planning/state.toml` (authoritative)"
      ],
      "root_agents_cleanup_blocks": [],
      "capabilities": [
        "active-execution-state",
        "execplan-routing"
      ],
      "dependencies": [],
      "conflicts": [],
      "components": {
        "resources": [
          {
            "uri": "planning://state",
            "description": "Current planning state, active items, queued items, and roadmap lanes.",
            "read_only": true,
            "source": ".agentic-workspace/planning/state.toml",
            "command": "agentic-workspace summary --format json",
            "result_schema": "typed-validator:planning-summary"
          },
          {
            "uri": "planning://summary",
            "description": "Compact current-work and execution-readiness projection.",
            "read_only": true,
            "source": "agentic-workspace summary",
            "command": "agentic-workspace summary --format json",
            "result_schema": "typed-validator:planning-summary"
          },
          {
            "uri": "planning://execplans",
            "description": "Active and archived execution plans, opened only when compact state points there.",
            "read_only": true,
            "source": ".agentic-workspace/planning/execplans",
            "command": "agentic-workspace summary --profile full --format json",
            "result_schema": "typed-validator:planning-execplan"
          }
        ],
        "tools": [
          {
            "name": "planning.install",
            "description": "Install planning bootstrap surfaces in a host repository.",
            "command": "agentic-workspace install --modules planning --target <repo> --dry-run",
            "read_only": false,
            "destructive": false,
            "idempotent": true,
            "requires_dry_run": true,
            "input_schema": "typed-validator:lifecycle-command-options",
            "result_schema": "workspace-module-report/v1",
            "safety": {
              "requires_approval_when": [
                "ambiguous_ownership",
                "manual_review"
              ],
              "owned_paths": [
                ".agentic-workspace/planning/**",
                "managed AGENTS.md fences"
              ],
              "dry_run_command": "agentic-workspace install --modules planning --target <repo> --dry-run --format json"
            }
          },
          {
            "name": "planning.upgrade",
            "description": "Refresh managed planning bootstrap surfaces.",
            "command": "agentic-workspace upgrade --modules planning --target <repo> --dry-run",
            "read_only": false,
            "destructive": false,
            "idempotent": true,
            "requires_dry_run": true,
            "input_schema": "typed-validator:lifecycle-command-options",
            "result_schema": "workspace-module-report/v1",
            "safety": {
              "requires_approval_when": [
                "ambiguous_ownership",
                "manual_review"
              ],
              "owned_paths": [
                ".agentic-workspace/planning/**",
                "managed AGENTS.md fences"
              ],
              "dry_run_command": "agentic-workspace upgrade --modules planning --target <repo> --dry-run --format json"
            }
          },
          {
            "name": "planning.doctor",
            "description": "Inspect planning surface health.",
            "command": "agentic-workspace doctor --modules planning --target <repo> --format json",
            "read_only": true,
            "destructive": false,
            "idempotent": true,
            "requires_dry_run": false,
            "input_schema": "typed-validator:lifecycle-command-options",
            "result_schema": "workspace-module-report/v1",
            "safety": {
              "requires_approval_when": [],
              "owned_paths": [],
              "dry_run_command": ""
            }
          }
        ],
        "prompts": [
          {
            "name": "planning.autopilot",
            "description": "Execute one bounded planning milestone from checked-in planning surfaces.",
            "template": ".agentic-workspace/planning/skills/planning-autopilot/SKILL.md",
            "prompt_kind": "skill"
          },
          {
            "name": "planning.reporting",
            "description": "Report active planning state and proof expectations from summary JSON.",
            "template": ".agentic-workspace/planning/skills/planning-reporting/SKILL.md",
            "prompt_kind": "skill"
          }
        ],
        "schemas": [
          {
            "id": "planning-execplan",
            "path": ".agentic-workspace/planning/execplans/TEMPLATE.plan.json",
            "schema_kind": "template-backed-json"
          },
          {
            "id": "planning-summary",
            "path": "typed-validator:agentic-workspace summary",
            "schema_kind": "typed-validator"
          }
        ],
        "roots": [
          {
            "id": "planning-root",
            "path": ".agentic-workspace/planning",
            "ownership": "module-managed"
          },
          {
            "id": "planning-managed-fences",
            "path": "AGENTS.md#agentic-workspace:workflow",
            "ownership": "managed-fence-in-repo-owned-file"
          }
        ]
      },
      "result_contract": {
        "schema_version": "workspace-module-report/v1",
        "guaranteed_fields": [
          "module",
          "message",
          "target_root",
          "dry_run",
          "actions",
          "warnings"
