{
  "schema_version": "agentic-workspace/command-package-ir/v1",
  "summary": "Implementation-independent command-package view for generated Python and TypeScript CLI package targets.",
  "schema": "schemas/command_package_ir.schema.json",
  "source_contracts": [
    "cli_commands.json",
    "cli_option_groups.json",
    "operation_contracts.json",
    "operation_primitives.json",
    "command_adapter_generation.json",
    "conformance_contracts.json"
  ],
  "generation_policy": {
    "authority_rule": "Command/interface truth belongs in contracts and this package IR; generated target files are derived outputs.",
    "runtime_boundary": "Runtime primitives and live workspace inspection stay hand-owned and are referenced, not generated.",
    "ordinary_development_environment": "Python development remains sufficient for ordinary repo work.",
    "test_environment": "Generated non-Python package tests run in Docker-selected proof lanes.",
    "custom_codegen_boundary": "Custom generation code should stay small: validated IR loading, target rendering, freshness checks, and no-direct-edit sentinels.",
    "shell_adapter_policy": "Bash and PowerShell targets are deferred downstream projections for thin wrappers, help, argument validation, completion metadata, and runtime handoff only; they must not own runtime primitive behavior.",
    "direct_cli_edit_policy": "Interface shape, generated package metadata, and adapter wiring should move through contracts, IR, and generators; direct cli.py edits are for runtime primitives, migration exceptions, and uncovered urgent fixes.",
    "generated_package_maturity": {
      "routing_rule": "Weak agents may use only generated targets whose maturity level explicitly allows weak-agent routing; proof fixtures and parser/help proofs are inspection artifacts, not usable CLI surfaces.",
      "levels": [
        {
          "id": "metadata-proof-fixture",
          "summary": "Generated metadata proves projection from the command-package IR but does not provide a runnable CLI entrypoint.",
          "runnable": false,
          "runtime_backed": false,
          "weak_agent_routing": "forbidden",
          "promotion_requires": [
            "target package exposes generated parser/help or command invocation glue",
            "generated metadata remains fresh from command_package_ir.json",
            "no-direct-edit checks cover generated files"
          ]
        },
        {
          "id": "parser-help-proof",
          "summary": "Generated target can render command shape or help, but runtime command behavior is not yet callable.",
          "runnable": false,
          "runtime_backed": false,
          "weak_agent_routing": "forbidden",
          "promotion_requires": [
            "runtime binding model is declared outside universal command truth",
            "read-only command invocation has a selected conformance contract",
            "Docker-selected proof can execute the target package"
          ]
        },
        {
          "id": "runnable-read-only-adapter",
          "summary": "Generated target can be invoked for a selected read-only command and returns observable command output.",
          "runnable": true,
          "runtime_backed": false,
          "weak_agent_routing": "review-required",
          "promotion_requires": [
            "black-box conformance covers invocation, exit code, output shape, and one failure path",
            "failure output distinguishes generation drift from adapter and runtime failures",
            "ordinary Python development remains free of Node or Docker requirements"
          ]
        },
        {
          "id": "runtime-backed-read-only-adapter",
          "summary": "Generated target delegates to hand-owned runtime primitives for read-only behavior without reimplementing live inspection.",
          "runnable": true,
          "runtime_backed": true,
          "weak_agent_routing": "review-required",
          "promotion_requires": [
            "runtime delegation envelope and error mapping are contract-backed",
            "selected conformance contract passes against canonical process behavior",
            "runtime primitive ownership remains explicit"
          ]
        },
        {
          "id": "weak-agent-safe-adapter",
          "summary": "Generated target is safe to route to weaker agents for supported read-only commands.",
          "runnable": true,
          "runtime_backed": true,
          "weak_agent_routing": "allowed-read-only",
          "promotion_requires": [
            "help, errors, and recovery guidance route weak agents back to compact safe paths",
            "black-box conformance covers normal and off-happy-path read-only behavior",
            "proof route advertises the target as weak-agent-safe"
          ]
        },
        {
          "id": "mutation-capable-adapter",
          "summary": "Generated target can invoke mutation-capable behavior through guarded runtime primitives.",
          "runnable": true,
          "runtime_backed": true,
          "weak_agent_routing": "allowed-mutation-with-review",
          "promotion_requires": [
            "dry-run and apply behavior are separately covered",
            "preflight and destructive-refusal guards have black-box conformance",
            "human review requirements are surfaced before unsafe mutation"
          ]
        },
        {
          "id": "deferred",
          "summary": "Target is intentionally not generated yet.",
          "runnable": false,
          "runtime_backed": false,
          "weak_agent_routing": "forbidden",
          "promotion_requires": [
            "a prior maturity level is proven for Python and TypeScript read-only targets",
            "target-specific projection requirements are defined",
            "ordinary development remains independent of target-specific tooling"
          ]
        }
      ]
    },
    "non_python_runtime_binding": {
      "selected_model": "generated parser/help with process handoff to canonical Python CLI",
      "scope": "Read-only generated non-Python adapters may invoke the existing Python command surface as the runtime boundary; mutation-capable commands remain deferred until lifecycle dry-run, preflight, and refusal conformance are explicit.",
      "universal_contract_owns": [
        "command identity",
        "operation reference",
        "input and output schema references",
        "effect hints",
        "runtime primitive reference identity",
        "conformance references"
      ],
      "target_projection_owns": [
        "target package entrypoint wiring",
        "argv spelling and help rendering",
        "subprocess invocation envelope",
        "stdout and stderr forwarding",
        "exit-code propagation"
      ],
      "runtime_owns": [
        "live workspace inspection",
        "operation primitive implementation",
        "payload assembly",
        "canonical JSON or text output behavior"
      ],
      "error_mapping": [
        "Generated adapter failures before process handoff are adapter failures.",
        "Non-zero exits returned by the delegated canonical process are runtime failures unless the conformance case expects the error.",
        "Generation freshness and no-direct-edit failures remain generation-layer failures before runtime execution starts."
      ]
    }
  },
  "packages": [
    {
      "id": "root-workspace",
      "program": "agentic-workspace",
      "package_role": "root-workspace-cli",
      "targets": [
        {
          "kind": "python",
          "package_name": "agentic-workspace",
          "generated_root": "src/agentic_workspace/generated_cli_package",
          "entrypoints": [
            "agentic-workspace"
          ],
          "test_environment": "python-dev",
          "maturity_level_ref": "metadata-proof-fixture",
          "generation_status": "supported-now"
        },
        {
          "kind": "typescript",
          "package_name": "@agentic-workspace/workspace-cli",
          "generated_root": "generated/typescript/workspace-cli",
          "entrypoints": [
            "agentic-workspace"
          ],
          "test_environment": "docker",
          "maturity_level_ref": "runnable-read-only-adapter",
          "generation_status": "runnable-read-only-adapter"
        },
        {
          "kind": "bash",
          "package_name": "agentic-workspace-shell",
          "generated_root": "generated/shell/bash",
          "entrypoints": [
            "agentic-workspace"
          ],
          "test_environment": "docker",
          "maturity_level_ref": "deferred",
          "generation_status": "deferred"
        },
        {
          "kind": "powershell",
          "package_name": "AgenticWorkspace.PowerShell",
          "generated_root": "generated/shell/powershell",
          "entrypoints": [
            "agentic-workspace"
          ],
          "test_environment": "docker",
          "maturity_level_ref": "deferred",
          "generation_status": "deferred"
        }
      ],
      "commands": [
        {
          "adapter_id": "defaults.report.cli",
          "status": "generated",
          "command": {
            "name": "defaults",
            "manifest_ref": "cli_commands.json"
          },
          "operation_ref": {
            "id": "defaults.report",
            "path": "operations/defaults.report.json"
          },
          "runtime_binding": {
            "kind": "operation-primitive-sequence",
            "primitive_refs": [
              "workspace.defaults.load",
              "workspace.defaults.select",
              "output.emit"
            ]
          },
          "schemas": {
            "input": [],
            "output": [
              "compact_contract_answer.schema.json"
            ]
          },
          "effect_hints": {
            "read_only": true,
            "destructive": false,
            "idempotent": true,
            "writes_repo_state": false,
            "requires_preflight_gate": false
          },
          "conformance_refs": [
            "defaults.report.process"
          ],
          "projection_boundary": {
            "universal": [
              "command identity",
              "option semantics",
              "operation reference",
              "runtime primitive reference",
              "effect hints",
              "schema refs",
              "conformance refs"
            ],
            "target_specific": [
              "parser library",
              "package entrypoint wiring",
              "help text layout",
              "test container image"
            ],
            "runtime_owned": [
              "defaults payload assembly",
              "section selection",
              "output emission"
            ]
          }
        }
      ]
    },
    {
      "id": "planning-bootstrap",
      "program": "agentic-planning-bootstrap",
      "package_role": "planning-module-cli",
      "targets": [
        {
          "kind": "python",
          "package_name": "agentic-planning-bootstrap",
          "generated_root": "packages/planning/src/repo_planning_bootstrap/generated_cli_package",
          "entrypoints": [
            "agentic-planning-bootstrap"
          ],
          "test_environment": "python-dev",
          "maturity_level_ref": "metadata-proof-fixture",
          "generation_status": "supported-now"
        },
        {
          "kind": "typescript",
          "package_name": "@agentic-workspace/planning-cli",
          "generated_root": "generated/typescript/planning-cli",
          "entrypoints": [
            "agentic-planning-bootstrap"
          ],
          "test_environment": "docker",
          "maturity_level_ref": "metadata-proof-fixture",
          "generation_status": "proof-fixture"
        }
      ],
      "commands": [
        {
          "adapter_id": "planning.status.cli",
          "status": "generated",
          "command": {
            "name": "status",
            "manifest_ref": "package:planning:cli"
          },
          "operation_ref": {
            "id": "planning.status.report",
            "path": "operations/planning.status.report.json"
          },
          "runtime_binding": {
            "kind": "operation-primitive-sequence",
            "primitive_refs": [
              "planning.bootstrap.status.load",
              "output.emit"
            ]
          },
          "schemas": {
            "input": [],
