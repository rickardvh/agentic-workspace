          "effect_hints": {
            "read_only": true,
            "destructive": false,
            "idempotent": true,
            "writes_repo_state": false,
            "requires_preflight_gate": false
          },
          "conformance_refs": [
            "memory.status.process"
          ],
          "projection_boundary": {
            "universal": [
              "command identity",
              "operation reference",
              "runtime primitive reference",
              "effect hints",
              "conformance refs"
            ],
            "target_specific": [
              "parser library",
              "package entrypoint wiring",
              "help text layout",
              "test container image"
            ],
            "runtime_owned": [
              "memory bootstrap inspection",
