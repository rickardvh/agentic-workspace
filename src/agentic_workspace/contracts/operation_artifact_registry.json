    },
    {
      "artifact_id": "memory-bootstrap.list-skills.typescript",
      "operation_id": "memory.list-skills.report",
      "package_id": "memory-bootstrap",
      "target": "typescript",
      "adapter_id": "cli.process",
      "proof_role": "wrapper-smoke",
      "source_ref": "command_package_ir:memory-bootstrap/list-skills",
      "wrapper_refs": [
        "memory.list-skills.cli"
      ],
      "case_ids": [
        "memory.list-skills.parity"
      ],
      "path_refs": [
        "generated/memory/typescript/src/cli.mjs",
        "src/agentic_workspace/contracts/conformance/memory.list-skills.process.json"
      ],
      "stale_when": [
        "memory.list-skills operation contract changes",
        "memory list-skills TypeScript wrapper changes",
        "memory.list-skills.process conformance expectations change"
      ]
    }
  ],
  "proof_routing": {
    "rule": "Select the cheapest proof layer that covers the changed surface; do not use wrapper execution as the default proof for operation semantics.",
    "routes": [
      {
        "changed_surface": "operation-contract",
        "proof": [
          "validate affected operation conformance cases",
          "run affected operation conformance artifacts"
        ]
      },
      {
        "changed_surface": "implementation-artifact",
        "proof": [
          "run adapter checks",
          "run representative operation cases for affected artifacts"
        ]
      },
      {
        "changed_surface": "implementation-adapter",
        "proof": [
          "run adapter checks",
          "run a small artifact conformance smoke set"
        ]
      },
      {
        "changed_surface": "cli-wrapper",
        "proof": [
          "run CLI boundary tests",
          "run operation cases only when operation semantics changed"
        ]
      },
      {
        "changed_surface": "schema",
        "proof": [
          "validate affected cases",
          "run affected operation cases"
        ]
      },
      {
        "changed_surface": "generated-artifact-freshness",
        "proof": [
          "run generated freshness and parity checks",
          "run affected conformance cases"
        ]
      }
    ]
  }
}
