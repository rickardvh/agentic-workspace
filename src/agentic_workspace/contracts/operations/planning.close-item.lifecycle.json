{
  "schema_version": "agentic-workspace/operation/v1",
  "id": "planning.close-item.lifecycle",
  "command_surface": {
    "command": "planning",
    "subcommand": "close-item",
    "format_option": "format"
  },
  "summary": "Close completed Planning residue by id through the workspace front door.",
  "classification": "lifecycle-mutation",
  "inputs": [
    {
      "name": "item",
      "source": "cli-option",
      "required": true
    },
    {
      "name": "target",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "reason",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "issue",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "dry_run",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "format",
      "source": "cli-option",
      "required": false
    }
  ],
  "output": {
    "kind": "module-result"
  },
  "effects": {
    "read_only": false,
    "destructive": false,
    "idempotent": false,
    "writes_repo_state": true,
    "requires_preflight_gate": false
  },
  "locality": {
    "requires_repo": false,
    "network": "forbidden",
    "outside_repo_writes": "forbidden"
  },
  "reads": [
    {
      "surface": "target repository Planning state",
      "required": true
    },
    {
      "surface": "target repository Planning execplans",
      "required": false
    }
  ],
  "writes": [
    {
      "surface": ".agentic-workspace/planning/state.toml",
      "required": false
    },
    {
      "surface": ".agentic-workspace/planning/execplans/",
      "required": false
    }
  ],
  "steps": [
    {
      "id": "delegate_to_planning_module",
      "uses": "output.emit",
      "description": "Route close-item through the root workspace command and emit sanitized output."
    }
  ],
  "guards": [
    "Host-facing guidance must use agentic-workspace planning close-item rather than hand-editing state.toml.",
    "Ambiguous item ids must return manual review candidates instead of mutating state."
  ],
  "proof": [
    "operation contract validates against operation.schema.json",
    "root front door translates --item to the planning module positional argument"
  ],
  "migration_status": "draft-contract-only"
}
