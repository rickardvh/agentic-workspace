{
  "schema_version": "agentic-workspace/operation/v1",
  "id": "memory.list-files.report",
  "command_surface": {
    "program": "agentic-memory",
    "command": "list-files",
    "format_option": "format"
  },
  "summary": "Preview packaged memory bootstrap files without applying them to a target repository.",
  "classification": "read-only-report",
  "inputs": [
    {
      "name": "target",
      "source": "cli-option",
      "required": false
    },
    {
      "name": "format",
      "source": "cli-option",
      "required": false
    }
  ],
  "output": {
    "kind": "text-or-json"
  },
  "effects": {
    "read_only": true,
    "destructive": false,
    "idempotent": true,
    "writes_repo_state": false,
    "requires_preflight_gate": false
  },
  "locality": {
    "requires_repo": false,
    "network": "forbidden",
    "outside_repo_writes": "forbidden"
  },
  "reads": [
    {
      "surface": "packaged memory bootstrap payload",
      "required": true
    }
  ],
  "writes": [],
  "steps": [
    {
      "id": "resolve_target",
      "uses": "path.target_root.resolve",
      "description": "Resolve the optional target root without requiring an installed workspace."
    },
    {
      "id": "list_packaged_payload",
      "uses": "filesystem.glob",
      "description": "List packaged memory bootstrap payload files as stable relative paths."
    },
    {
      "id": "assemble_payload",
      "uses": "payload.assemble",
      "description": "Build the module-result payload containing dry-run status and discovered file paths."
    },
    {
      "id": "emit_output",
      "uses": "output.emit",
      "description": "Emit file list in the requested format."
    }
  ],
  "ir_plan": {
    "status": "representative",
    "summary": "Representative target-executor IR for a read-only package-resource command from CLI input through emitted JSON/text output.",
    "steps": [
      {
        "id": "resolve_target",
        "uses": "path.target_root.resolve",
        "description": "Resolve the optional target root without requiring an installed workspace.",
        "inputs": [
          "target"
        ],
        "outputs": [
          "target_root"
        ],
        "on_error": "emit_usage_error"
      },
      {
        "id": "list_packaged_payload",
        "uses": "filesystem.glob",
        "description": "List packaged memory bootstrap payload files as stable relative paths.",
        "arguments": {
          "root": "memory.package-payload",
          "pattern": "**/*",
          "sort": "lexicographic"
        },
        "reads": [
          "packaged memory bootstrap payload"
        ],
        "outputs": [
          "files"
        ],
        "on_error": "fail"
      },
      {
        "id": "assemble_payload",
        "uses": "payload.assemble",
        "description": "Build the module-result payload containing dry-run status and discovered file paths.",
        "arguments": {
          "fields": {
            "dry_run": true,
            "message": "Packaged bootstrap file preview",
            "actions_from": "files"
          }
        },
        "inputs": [
          "target_root",
          "files"
        ],
        "outputs": [
          "result"
        ],
        "on_error": "fail"
      },
      {
        "id": "emit_output",
        "uses": "output.emit",
        "description": "Emit the result as JSON or text according to the format option.",
        "inputs": [
          "result",
          "format"
        ],
        "on_error": "emit_usage_error"
      }
    ],
    "portability_notes": [
      "Target executors can implement this representative plan with filesystem globbing and payload assembly; it does not require importing package internals.",
      "Generated command adapters consume this operation contract directly for list-files; other generated commands remain on compatibility runtime handlers until promoted."
    ]
  },
  "guards": [
    "List-files must remain read-only."
  ],
  "proof": [
    "operation contract validates against operation.schema.json",
    "operation command parity checks agentic-memory live parser"
  ],
  "migration_status": "runtime-consumed"
}
