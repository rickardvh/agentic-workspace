    "fields": [
      "outcome",
      "mutation_applied",
      "reason_code",
      "conflict_owner",
      "recovery_command"
    ],
    "outcomes": [
      "applied",
      "noop",
      "blocked",
      "failed"
    ],
    "proof_requirements": [
      "Every ordinary package-owned mutating operation is inventoried from registered operation IR effects.writes_repo_state.",
      "Representative applied, noop, blocked, and failed behavior must pass for Python and TypeScript generated targets.",
      "Recovery commands must use configured CLI invocation authority and repository-relative targets."
    ],
