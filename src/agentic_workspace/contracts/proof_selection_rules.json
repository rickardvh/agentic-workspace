{
  "schema_version": "agentic-workspace/proof-selection-rules/v1",
  "lane_proof_kinds": {
    "generated_command_packages": "full-test",
    "cli_authority": "diff-review",
    "contract_tooling": "surface-check",
    "agent_aid_manifests": "surface-check",
    "repo_docs_review": "diff-review",
    "workspace_cli": "targeted-test",
    "planning_package": "targeted-test",
    "memory_package": "targeted-test",
    "planning_surfaces": "surface-check",
    "maintainer_surfaces": "surface-check"
  },
  "docs_only_reducer": {
    "lane": "repo_docs_review",
    "source_lanes": [
      "planning_package",
      "memory_package"
    ],
    "extensions": [
      ".md"
    ],
    "exact": [
      "packages/planning/README.md",
      "packages/memory/README.md"
    ],
    "prefixes": [
      "packages/planning/docs/",
      "packages/memory/docs/"
    ],
    "rule": "Markdown-only package documentation edits use review proof unless behavior, generated payload, install contracts, or implementation semantics also changed."
  },
  "supplemental_lanes": [
    {
      "id": "schema_reference_docs",
      "path_match": {
        "prefixes": [
          "src/agentic_workspace/contracts/schemas/"
        ],
        "extensions": [
          ".json",
          ".schema.json"
        ]
      },
      "when": "changed workspace contract schema can affect generated docs/reference/*.md output",
      "enough_proof": [
        "make schema-reference-docs"
      ],
      "proof_kind": "surface-check",
      "proof_responsibility": "local-closeout",
      "execution_mode": "parallel-ok",
      "ci_relationship": "CI may repeat schema reference checks; local proof should catch stale generated reference docs before PR.",
      "recovery_signal": "Schema metadata changes should prove generated reference docs directly instead of waiting for broad CI wrappers to teach the missing rule."
    },
    {
      "id": "planning_schema_reference_docs",
      "path_match": {
        "prefixes": [
          "packages/planning/src/repo_planning_bootstrap/contracts/schemas/"
        ],
        "extensions": [
          ".json",
          ".schema.json"
        ]
      },
      "when": "changed Planning package schema can affect package schema reference or check-planning freshness",
      "enough_proof": [
        "make check-planning"
      ],
      "proof_kind": "surface-check",
      "proof_responsibility": "local-closeout",
      "execution_mode": "parallel-ok",
      "ci_relationship": "Planning CI may repeat package checks; local proof should include the package wrapper that owns schema-reference freshness.",
      "recovery_signal": "Planning package schema changes should not rely on unrelated tests alone; use the package wrapper that owns reference-doc freshness."
    },
    {
      "id": "planning_source_typecheck_ci_parity",
      "path_match": {
        "prefixes": [
          "packages/planning/src/"
        ],
        "extensions": [
          ".py",
          ".pyi"
        ]
      },
      "when": "changed Planning package Python source can fail package CI typecheck even when tests and lint pass",
      "enough_proof": [
        "make typecheck-planning"
      ],
      "proof_kind": "surface-check",
      "proof_responsibility": "local-closeout",
      "execution_mode": "parallel-ok",
      "ci_relationship": "Planning CI includes typecheck through the package check wrapper; local source closeout should prove that obligation directly.",
      "recovery_signal": "Planning source changes should not rely on tests and lint alone when type errors can fail CI."
    }
  ],
  "rules": [
    {
      "id": "workspace-codegen-runtime",
      "lane": "workspace_cli",
      "exact": [
        "generated/workspace/python/cli.py"
      ]
    },
    {
      "id": "planning-codegen-runtime",
      "lane": "planning_package",
      "exact": [
        "generated/planning/python/cli.py"
      ]
    },
    {
      "id": "memory-codegen-runtime",
      "lane": "memory_package",
      "exact": [
        "generated/memory/python/cli.py"
      ]
    },
    {
      "id": "generated-command-packages",
      "lane": "generated_command_packages",
      "exact": [
        "src/agentic_workspace/contracts/command_package_ir.json"
      ],
      "prefixes": [
        "generated/workspace/python/",
        "generated/planning/python/",
        "generated/memory/python/",
        "generated/verification/python/",
        "generated/workspace/typescript/",
        "generated/planning/typescript/",
        "generated/memory/typescript/",
        "generated/verification/typescript/",
        "scripts/generate/generate_command_packages.py",
        "scripts/check/check_generated_command_packages.py",
        "command_generation/"
      ]
    },
    {
      "id": "package-readme-docs",
      "lane": "repo_docs_review",
      "exact": [
        "packages/planning/README.md",
        "packages/memory/README.md"
      ]
    },
    {
      "id": "planning-package",
      "lane": "planning_package",
      "prefixes": [
        "packages/planning/"
      ]
    },
    {
      "id": "agent-aid-manifests",
      "lane": "agent_aid_manifests",
      "prefixes": [
        ".agentic-workspace/agent-aids/"
      ]
    },
    {
      "id": "memory-package",
      "lane": "memory_package",
      "prefixes": [
        "packages/memory/"
      ]
    },
    {
      "id": "repo-docs-review",
      "lane": "repo_docs_review",
      "exact": [
        "README.md"
      ],
      "prefixes": [
        ".agentic-workspace/docs/",
        "docs/package/",
        "docs/architecture.md",
        "docs/collaboration-safety.md",
        "docs/design-principles.md",
        "docs/documentation-status.md",
        "docs/ecosystem-roadmap.md",
        "docs/extension-boundary.md",
        "docs/index.md",
        "docs/integration-contract.md",
        "docs/jumpstart-contract.md",
        "docs/maturity-model.md",
        "docs/module-capability-contract.md",
        "docs/planning-cli-naming.md",
        "docs/setup-findings-contract.md",
        "docs/which-package.md"
      ]
    },
    {
      "id": "planning-installed-surfaces",
      "lane": "planning_surfaces",
      "prefixes": [
        ".agentic-workspace/planning/"
      ]
    },
    {
      "id": "maintainer-surfaces",
      "lane": "maintainer_surfaces",
      "exact": [
        "AGENTS.md",
        "docs/agentic-workspace-install.md"
      ],
      "prefixes": [
        "docs/"
      ]
    },
    {
      "id": "contract-tooling",
      "lane": "contract_tooling",
      "exact": [
        "tests/test_structured_file_inventory.py"
      ],
      "prefixes": [
        "src/agentic_workspace/contracts/",
        "scripts/check/check_contract_tooling_surfaces.py",
        "scripts/check/check_structured_file_inventory.py"
      ]
    },
    {
      "id": "workspace-cli",
      "lane": "workspace_cli",
      "exact": [
        "pyproject.toml"
      ],
      "prefixes": [
        "src/agentic_workspace/",
        "tests/",
        "scripts/check/"
      ]
    }
  ],
  "fallback_lane": "workspace_cli",
  "cross_lane_escalation": "changed paths span multiple validation lanes; run all selected commands or split the work",
  "cli_authority": {
    "lane": "cli_authority",
    "classifications": [
      {
        "id": "root-workspace-cli-runtime",
        "role": "hand-owned-executable",
        "exact": [
          "generated/workspace/python/cli.py"
        ],
        "direct_edit_allowed": true,
        "source_contract": "src/agentic_workspace/contracts/operation_contracts.json + src/agentic_workspace/contracts/cli_commands.json + src/agentic_workspace/contracts/python_runtime_boundary.json",
        "generator_contract": null,
        "regeneration_path": null,
        "edit_policy": "Direct edits are allowed only for runtime primitives, live inspection, dispatch glue, or explicit migration exceptions; visible interface authority should route to contracts or generated metadata, and any cli.py edit must select generated command package proof so interface drift cannot bypass the generated package gate."
      },
      {
        "id": "package-cli-runtime",
        "role": "hand-owned-executable",
        "exact": [
          "generated/planning/python/cli.py",
          "generated/memory/python/cli.py"
        ],
        "direct_edit_allowed": true,
        "source_contract": "package-local CLI source plus package bootstrap payload checks",
        "generator_contract": null,
        "regeneration_path": null,
        "edit_policy": "Direct edits are package-source work and may require package payload and install-surface proof before closeout. Any package cli.py edit must also select generated command package proof so command/interface drift cannot bypass command_package_ir and generated command package checks."
      },
      {
        "id": "generated-command-package-output",
        "role": "projection",
        "prefixes": [
          "generated/workspace/python/",
          "generated/planning/python/",
          "generated/memory/python/",
          "generated/workspace/typescript/",
          "generated/planning/typescript/",
          "generated/memory/typescript/",
          "generated/verification/typescript/"
        ],
        "direct_edit_allowed": false,
        "source_contract": "src/agentic_workspace/contracts/command_package_ir.json",
        "generator_contract": "src/agentic_workspace/contracts/command_adapter_generation.json",
        "regeneration_path": "uv run python scripts/check/check_generated_command_packages.py",
        "edit_policy": "Do not hand-edit generated command package outputs; change the command package IR or generator and regenerate/prove the projection."
      },
      {
        "id": "python-generated-package-loader",
        "role": "generator",
        "prefixes": [
          "command_generation/"
        ],
        "direct_edit_allowed": true,
        "source_contract": "src/agentic_workspace/contracts/command_package_ir.json",
        "generator_contract": "command_generation/",
        "regeneration_path": "uv run python scripts/generate/generate_command_packages.py",
        "edit_policy": "Package-local source must not own generated CLI bridges. Codegen-owned loader changes must prove generated package import behavior, generated output freshness, and packaging entry points."
      }
    ]
  }
}
